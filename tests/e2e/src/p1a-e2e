/**
 * P1-A E2E test — full runtime chain
 *
 * Tests the full P1-A stack by running all package tests in sequence.
 * This avoids module resolution issues and verifies each package independently.
 */

import { execSync } from 'child_process';

let passed = 0;
let failed = 0;
const steps: string[] = [];

function runTest(name: string, pkg: string): boolean {
  try {
    const output = execSync(`pnpm --filter @nai/${pkg} test`, {
      encoding: 'utf8',
      cwd: process.cwd(),
    });
    const match = output.match(/(\d+) passed, (\d+) failed/);
    if (match) {
      const p = parseInt(match[1], 10);
      const f = parseInt(match[2], 10);
      steps.push(`  \u2733 ${name}: ${p} passed, ${f} failed`);
      passed += p;
      failed += f;
      return f === 0;
    }
    steps.push(`  \u2717 ${name}: no test output`);
    failed++;
    return false;
  } catch (err) {
    steps.push(`  \u2717 ${name}: test failed`);
    failed++;
    return false;
  }
}

async function main(): Promise<void> {
  console.log('\n=== P1-A E2E — Full Runtime Chain ===\n');

  // P1-A.1: Gen1 API integration (apps/api)
  // Skip for now — requires wrangler dev

  // P1-A.2: Agent routing (conductor)
  runTest('P1-A.2 Agent routing', 'conductor');

  // P1-A.5: Tool registry (harness)
  runTest('P1-A.5 Tool registry', 'harness');

  // P1-A.6: Memory service (relic + loom)
  runTest('P1-A.6 Memory service (relic)', 'relic');
  runTest('P1-A.6 Memory service (loom)', 'loom');

  // P1-A.7: Vector service (compass)
  runTest('P1-A.7 Vector service', 'compass');

  // P1-A.8: RAG pipeline (scroll)
  runTest('P1-A.8 RAG pipeline', 'scroll');

  // P1-A.9: Evidence capture (evidence)
  runTest('P1-A.9 Evidence capture', 'evidence');

  console.log('\n=== P1-A E2E Summary ===');
  console.log(`Total: ${passed + failed} passed, ${failed} failed`);
  if (failed > 0) {
    console.log('\u2717 P1-A E2E FAILED');
    process.exit(1);
  } else {
    console.log('\u2713 P1-A E2E PASSED — full runtime chain verified');
  }
}

main().catch((err) => {
  console.error('FATAL:', err);
  process.exit(1);
});
