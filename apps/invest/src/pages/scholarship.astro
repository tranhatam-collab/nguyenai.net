---
import InvestLayout from '../layouts/InvestLayout.astro';
import Disclosure from '../components/Disclosure.astro';
---

<InvestLayout
  title="Scholarship Fund — 99 đầu · Mục tiêu 1.000/năm"
  titleVi="Quỹ học bổng — 99 đầu · Mục tiêu 1.000/năm"
  description="Nguyen AI Edu — 99 học bổng toàn phần (9 × 11) khởi động. Mục tiêu 1.000 học bổng/năm, ưu tiên họ Nguyễn tại Việt Nam. Tuổi 20–49."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Hero -->
    <div class="text-center max-w-4xl mx-auto mb-16">
      <div class="inline-block px-3 py-1 mb-6 text-xs font-semibold text-gold border border-gold/30 rounded-full uppercase tracking-wider">
        Scholarship Fund / Quỹ học bổng
      </div>
      <h1 class="text-4xl md:text-6xl font-serif font-bold text-gold-gradient mb-4">
        99 suất đầu — Mục tiêu 1.000/năm
      </h1>
      <p class="text-xl text-ink-muted">
        99 học bổng toàn phần (9 programs × 11 suất) khởi động. Mục tiêu 1.000 học bổng/năm — ưu tiên họ Nguyễn tại Việt Nam.
      </p>
      <p class="text-lg text-ink-dim mt-2">
        99 full scholarships (9 × 11) launch batch. Target 1,000/year — prioritizing the Nguyen family in Vietnam.
      </p>
      <p class="text-sm text-ink-dim mt-4 italic max-w-2xl mx-auto">
        Lưu ý: 1.000 suất/năm là mục tiêu gây quỹ và triển khai, không phải lời hứa chắc chắn nếu quỹ chưa có đủ nguồn lực.
      </p>
    </div>

    <!-- Key metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
      <div class="bg-bg-card border border-bg-border rounded-xl p-6 text-center">
        <div class="text-4xl font-serif font-bold text-gold">99</div>
        <div class="text-sm text-ink-muted mt-1">Suất khởi động</div>
        <div class="text-xs text-ink-dim">Launch batch</div>
      </div>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6 text-center">
        <div class="text-4xl font-serif font-bold text-gold">1.000</div>
        <div class="text-sm text-ink-muted mt-1">Mục tiêu/năm</div>
        <div class="text-xs text-ink-dim">Target/year</div>
      </div>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6 text-center">
        <div class="text-4xl font-serif font-bold text-gold">9</div>
        <div class="text-sm text-ink-muted mt-1">Programs</div>
        <div class="text-xs text-ink-dim">Certification tracks</div>
      </div>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6 text-center">
        <div class="text-4xl font-serif font-bold text-gold">20–49</div>
        <div class="text-sm text-ink-muted mt-1">Tuổi</div>
        <div class="text-xs text-ink-dim">Age range</div>
      </div>
    </div>

    <!-- Mission statement -->
    <div class="bg-bg-card border border-gold/20 rounded-xl p-8 mb-12 max-w-4xl mx-auto">
      <blockquote class="text-xl font-serif text-ink-muted italic text-center">
        "Mỗi suất học bổng không chỉ trao quyền học một khóa học.
        Mỗi suất học bổng trao cho một người cơ hội xây năng lực, tạo sản phẩm
        và bước vào nền kinh tế trí tuệ nhân tạo."
      </blockquote>
      <p class="text-center mt-4 text-sm text-gold">— Nguyen AI Founder Statement</p>
    </div>

    <!-- 99 launch batch: group structure -->
    <div class="mb-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-4">Cấu trúc 11 người / program</h2>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {[
            { group: 'Người trẻ đang tìm việc hoặc chuyển nghề', count: 3 },
            { group: 'Người làm tự do hoặc sáng tạo', count: 2 },
            { group: 'Nhà sáng lập hoặc chủ doanh nghiệp nhỏ', count: 2 },
            { group: 'Người có hoàn cảnh tài chính hạn chế', count: 2 },
            { group: 'Người làm giáo dục hoặc cộng đồng', count: 1 },
            { group: 'Suất đặc biệt do Hội đồng học bổng lựa chọn', count: 1 },
          ].map((g) => (
            <div class="flex items-center gap-3 p-3 bg-bg-soft rounded-lg">
              <div class="w-10 h-10 rounded-full bg-gold/10 text-gold flex items-center justify-center font-bold shrink-0">
                {g.count}
              </div>
              <div class="text-sm font-semibold text-ink">{g.group}</div>
            </div>
          ))}
        </div>
        <p class="mt-4 text-sm text-ink-muted text-center">
          9 programs × 11 suất = <strong class="text-gold">99 học bổng toàn phần</strong>
        </p>
      </div>
    </div>

    <!-- Annual 1,000 allocation -->
    <div class="mb-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-4">Phân bổ 1.000 suất/năm</h2>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6">
        <div class="space-y-4">
          {[
            { group: '9 chương trình cốt lõi (9 × 90)', count: 810 },
            { group: 'Học bổng giáo viên và người làm giáo dục', count: 50 },
            { group: 'Học bổng phụ nữ quay lại thị trường lao động', count: 50 },
            { group: 'Học bổng nhà sáng lập trẻ', count: 30 },
            { group: 'Học bổng cộng đồng và vùng hạn chế cơ hội', count: 30 },
            { group: 'Học bổng nghiên cứu và dự án đặc biệt', count: 20 },
            { group: 'Quỹ dự phòng và suất Founder', count: 10 },
          ].map((a) => (
            <div>
              <div class="flex justify-between mb-1">
                <span class="text-sm font-semibold text-ink">{a.group}</span>
                <span class="text-sm text-ink-muted">{a.count} xuất</span>
              </div>
              <div class="w-full bg-bg-soft rounded-full h-3 border border-bg-border">
                <div class="bg-gold h-3 rounded-full" style={`width: ${(a.count / 1000) * 100}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Fund tiers -->
    <div class="mb-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-4">Gói tài trợ / Sponsorship Tiers</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { tier: '1 học viên', vnd: '8.000.000₫', usd: '~$320', desc: 'Tài trợ 1 suất học bổng toàn phần' },
          { tier: '1 nhóm 11 người', vnd: '88.000.000₫', usd: '~$3,520', desc: 'Tài trợ 1 nhóm trong 1 program', highlight: true },
          { tier: '1 cohort 30 người', vnd: '240.000.000₫', usd: '~$9,600', desc: 'Tài trợ 1 cohort hoàn chỉnh' },
          { tier: '1 chương trình/năm', vnd: '720.000.000₫', usd: '~$28,800', desc: 'Tài trợ 1 program trọn năm (90 suất)' },
          { tier: 'Đối tác 1.000 học bổng', vnd: 'Theo thỏa thuận', usd: 'Custom', desc: 'Đối tác chiến lược toàn hệ sinh thái' },
        ].map((t) => (
          <div class={`border rounded-xl p-5 ${t.highlight ? 'border-gold/40 bg-gold/5' : 'border-bg-border bg-bg-card'}`}>
            <h3 class="font-bold text-ink text-lg">{t.tier}</h3>
            <div class="text-2xl font-serif font-bold text-gold mt-2">{t.vnd}</div>
            <div class="text-xs text-ink-dim">{t.usd}</div>
            <p class="text-sm text-ink-muted mt-3">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Sponsor rights + restrictions -->
    <div class="mb-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-bg-card border border-green-500/20 rounded-xl p-6">
        <h3 class="font-bold text-green-400 mb-3">Quyền lợi nhà tài trợ</h3>
        <ul class="space-y-2 text-sm text-ink-muted">
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Xuất hiện trong danh sách đối tác</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Báo cáo tác động định kỳ</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Tham dự ngày trình bày sản phẩm (Demo Day)</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Kết nối học viên phù hợp</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Đồng hành mentor</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Tài trợ đề bài thực tế</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Ưu tiên tuyển dụng</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Báo cáo sử dụng tài trợ</li>
        </ul>
      </div>
      <div class="bg-bg-card border border-red-500/20 rounded-xl p-6">
        <h3 class="font-bold text-red-400 mb-3">KHÔNG được trao quyền</h3>
        <ul class="space-y-2 text-sm text-ink-muted">
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Can thiệp kết quả học tập</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Mua chứng nhận</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Ép học viên làm việc</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Sử dụng dữ liệu cá nhân trái phép</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Biến học viên thành công cụ quảng cáo</li>
        </ul>
      </div>
    </div>

    <!-- PR timeline 12 months -->
    <div class="mb-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-4">Chiến dịch truyền thông 12 tháng</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { phase: '1. Công bố 99 suất', period: 'T1–T2', activity: 'Công bố 9 programs, 99 học bổng, hội đồng xét, mở hồ sơ, nhà tài trợ, tiêu chí' },
          { phase: '2. Hành trình người học', period: 'T3–T5', activity: 'Hồ sơ học viên, dự án, mentor, nhật ký, sản phẩm, bài học, khó khăn' },
          { phase: '3. Demo Day', period: 'T6', activity: 'Demo day, triển lãm, báo cáo tác động, kết nối doanh nghiệp/việc làm/đầu tư' },
          { phase: '4. Mở quỹ 1.000', period: 'T7–T9', activity: 'Hồ sơ tác động 99, ngân sách, mục tiêu 1.000, gói tài trợ, đối tác' },
          { phase: '5. Chiến dịch toàn cầu', period: 'T10–T12', activity: 'Cộng đồng VN ở nước ngoài, họ Nguyễn toàn cầu, mentor quốc tế, chapter, song ngữ' },
        ].map((p) => (
          <div class="bg-bg-card border border-bg-border rounded-xl p-5">
            <div class="text-xs text-gold font-semibold">{p.period}</div>
            <h3 class="font-bold text-ink mt-1">{p.phase}</h3>
            <p class="text-sm text-ink-muted mt-2">{p.activity}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Messaging -->
    <div class="mb-12 bg-bg-card border border-gold/20 rounded-xl p-8">
      <h2 class="text-2xl font-serif font-bold text-ink mb-6">Thông điệp truyền thông</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-sm font-semibold text-gold mb-1">Thông điệp trung tâm</h3>
          <p class="text-ink-muted italic">"Mỗi suất học bổng trao cho một người cơ hội xây năng lực, tạo sản phẩm và bước vào nền kinh tế trí tuệ nhân tạo."</p>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-gold mb-1">Thông điệp họ Nguyễn</h3>
          <p class="text-ink-muted italic">"Người mang họ Nguyễn không chỉ được kết nối bởi một cái tên. Chúng ta có thể được kết nối bởi tri thức, công nghệ, trách nhiệm và những cơ hội trao lại cho thế hệ sau."</p>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-gold mb-1">Thông điệp doanh nghiệp</h3>
          <p class="text-ink-muted italic">"Tài trợ học bổng là đầu tư vào nguồn nhân lực công nghệ, không chỉ là hoạt động thiện nguyện."</p>
        </div>
      </div>
    </div>

    <!-- Legal disclaimer -->
    <div class="mb-12 bg-bg-soft border border-bg-border rounded-xl p-6">
      <h3 class="text-sm font-bold text-ink mb-2">Lưu ý pháp lý</h3>
      <p class="text-xs text-ink-dim">
        Chương trình tài trợ học bổng do hệ sinh thái Nguyễn AI vận hành. Chưa phải quỹ xã hội hoặc quỹ từ thiện được cấp phép độc lập.
        1.000 suất/năm là mục tiêu gây quỹ, không phải lời hứa chắc chắn. Học bổng không bảo đảm việc làm, thu nhập, đầu tư hoặc nhận vào đội ngũ Nguyễn AI.
      </p>
    </div>

    <!-- CTA -->
    <div class="text-center py-12">
      <a href="/scholarship/fund" class="inline-block px-8 py-3 text-sm font-semibold text-bg bg-gold hover:bg-gold-light rounded-lg transition-colors">
        Tài trợ quỹ học bổng →
      </a>
      <a href="https://edu.nguyenai.net/scholarship" class="inline-block ml-4 px-8 py-3 text-sm font-semibold text-gold border border-gold/30 rounded-lg hover:bg-gold/5 transition-colors">
        Xem chi tiết tại edu.nguyenai.net →
      </a>
    </div>

    <div class="mt-12"><Disclosure /></div>
  </section>
</InvestLayout>
