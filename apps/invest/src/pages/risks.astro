---
import InvestLayout from '../layouts/InvestLayout.astro';
import RiskCard from '../components/RiskCard.astro';
import Disclosure from '../components/Disclosure.astro';
---

<InvestLayout
  title="Risk Register"
  titleVi="Sổ rủi ro"
  description="Sổ rủi ro Máy Tính AI Nguyễn: tám rủi ro từ kiểm toán kỹ thuật và kinh doanh, kèm khả năng, tác động và giảm thiểu."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Tổng quan sổ rủi ro">
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Sổ rủi ro</h1>

    <p class="mt-6 text-lg text-ink-muted max-w-3xl">
      Tám rủi ro được xác định trong kiểm toán kỹ thuật và kinh doanh, kèm khả năng xảy ra, tác động và biện pháp giảm thiểu.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
      <RiskCard
        locale="vi"
        risk="Thương hiệu cũ còn sót"
        likelihood="Medium"
        impact="Medium"
        mitigation="Kiểm toán thương hiệu Giai đoạn 0. Xóa mọi bề mặt cũ trước khi ra mắt công khai."
      />
      <RiskCard
        locale="vi"
        risk="IP chưa chuyển nhượng"
        likelihood="High"
        impact="High"
        mitigation="Giai đoạn 1: thành lập thực thể (HoldCo) và chuyển nhượng IP chính thức. Điều kiện tiên quyết để chốt đầu tư."
      />
      <RiskCard
        locale="vi"
        risk="Chưa có thực thể pháp lý"
        likelihood="High"
        impact="High"
        mitigation="Giai đoạn 1: thành lập công ty với tư vấn pháp lý. Định nghĩa cấu trúc, thuế và bảng cổ phần."
      />
      <RiskCard
        locale="vi"
        risk="Khoảng trống sản phẩm"
        likelihood="Medium"
        impact="High"
        mitigation="Giai đoạn 2: khung Console với xác thực, kho dữ liệu, đội Agent và Model Mesh. Ưu tiên phạm vi MVP."
      />
      <RiskCard
        locale="vi"
        risk="Chưa có người dùng beta"
        likelihood="High"
        impact="Medium"
        mitigation="Giai đoạn 5: beta kín với thành viên cộng đồng Nguyễn. Thu thập phản hồi trước khi ra mắt."
      />
      <RiskCard
        locale="vi"
        risk="Sai lệch giá"
        likelihood="Medium"
        impact="Medium"
        mitigation="Giá V2 đã khóa: 8 gói từ Start (miễn phí) đến Enterprise. Kiểm tra nhất quán trên mọi bề mặt."
      />
      <RiskCard
        locale="vi"
        risk="Lỗi JSON-LD"
        likelihood="Medium"
        impact="Low"
        mitigation="Kiểm toán SEO song ngữ trước khi ra mắt. Xác thực structured data và hreflang."
      />
      <RiskCard
        locale="vi"
        risk="Vấn đề sitemap / lập chỉ mục"
        likelihood="Medium"
        impact="Low"
        mitigation="Sitemap loại trừ /private/. robots.txt và noindex cho trang riêng tư. Kiểm tra Search Console."
      />
    </div>

    <div class="mt-12"><Disclosure locale="vi" /></div>
  </section>
</InvestLayout>
