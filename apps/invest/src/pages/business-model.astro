---
import InvestLayout from '../layouts/InvestLayout.astro';
import PricingTable from '../components/PricingTable.astro';
import Disclosure from '../components/Disclosure.astro';
---

<InvestLayout
  title="Business Model"
  titleVi="Mô hình kinh doanh"
  description="Mô hình kinh doanh Máy Tính AI Nguyễn: 8 gói đăng ký từ miễn phí đến doanh nghiệp, nhiều dòng doanh thu và kinh tế đơn vị giả thuyết."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Tổng quan mô hình kinh doanh">
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Mô hình kinh doanh</h1>

    <p class="mt-6 text-lg text-ink-muted max-w-3xl">
      SaaS đăng ký với tám gói — từ miễn phí đến doanh nghiệp tùy chỉnh. Nhiều dòng doanh thu tạo đa dạng hóa.
    </p>

    <div class="mt-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-6">8 gói (giá V2)</h2>
      <PricingTable locale="vi" />
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-6">Dòng doanh thu</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { name: 'Đăng ký', desc: 'Doanh thu định kỳ hàng tháng 8 bậc' },
          { name: 'Hợp đồng doanh nghiệp', desc: 'Giá tùy chỉnh, theo năm, SLA' },
          { name: 'Chứng nhận Academy', desc: 'Chương trình chứng nhận trả phí' },
          { name: 'Cấp phép hội đồng', desc: 'Cấp phép Nguyen Chapter OS' },
          { name: 'Phí API &amp; nền tảng', desc: 'Truy cập developer, tích hợp' },
          { name: 'Kho dữ liệu cao cấp', desc: 'Lưu trữ và tính toán bổ sung' },
        ].map((stream) => (
          <div class="bg-bg-card border border-bg-border rounded-lg p-5 card-hover">
            <h3 class="font-semibold text-ink">{stream.name}</h3>
            <p class="text-sm text-ink-muted mt-2">{stream.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-6">Kinh tế đơn vị (giả thuyết)</h2>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-bg-border">
            <tr>
              <td class="py-3 text-ink-muted">Giá khởi điểm (Personal)</td>
              <td class="py-3 text-right font-semibold text-gold">299K VND/tháng (~$12/tháng)</td>
            </tr>
            <tr>
              <td class="py-3 text-ink-muted">Bậc giữa (Founder)</td>
              <td class="py-3 text-right font-semibold text-gold">1.999M VND/tháng (~$80/tháng)</td>
            </tr>
            <tr>
              <td class="py-3 text-ink-muted">Bậc cao (Chapter)</td>
              <td class="py-3 text-right font-semibold text-gold">7.999M VND/tháng (~$320/tháng)</td>
            </tr>
            <tr>
              <td class="py-3 text-ink-muted">Enterprise</td>
              <td class="py-3 text-right font-semibold text-gold">Tùy chỉnh (hợp đồng năm)</td>
            </tr>
            <tr>
              <td class="py-3 text-ink-muted">Thị trường chính</td>
              <td class="py-3 text-right text-ink">Việt Nam + kiều bào Việt toàn cầu</td>
            </tr>
            <tr>
              <td class="py-3 text-ink-muted">Biên gộp (mục tiêu)</td>
              <td class="py-3 text-right font-semibold text-gold">70%+ (SaaS, hạ tầng đám mây)</td>
            </tr>
          </tbody>
        </table>
        <p class="mt-4 text-xs text-ink-dim italic">
          Lưu ý: Kinh tế đơn vị là giả thuyết dựa trên chuẩn SaaS, không phải số liệu đã xác minh.
        </p>
      </div>
    </div>

    <div class="mt-12"><Disclosure locale="vi" /></div>
  </section>
</InvestLayout>
