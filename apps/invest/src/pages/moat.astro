---
import InvestLayout from '../layouts/InvestLayout.astro';
import Disclosure from '../components/Disclosure.astro';
---

<InvestLayout
  title="Competitive Moat"
  titleVi="Lợi thế cạnh tranh"
  description="Lợi thế cạnh tranh Máy Tính AI Nguyễn: kiến trúc bốn lớp, hồ sơ vận hành Nguyễn, song ngữ, cộng đồng, kho dữ liệu, phương pháp bằng chứng."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Tổng quan lợi thế cạnh tranh">
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Lợi thế cạnh tranh</h1>

    <p class="mt-6 text-lg text-ink-muted max-w-3xl">
      Sáu lợi thế liên kết tạo vị thế phòng thủ khó sao chép bởi đối thủ hiện hữu hay người mới.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
      {[
        { num: '01', title: 'Kiến trúc bốn lớp', desc: 'Nền tảng độc lập → Academy. Mỗi lớp cộng hưởng giá trị và tạo chi phí chuyển đổi. Đối thủ phải xây từ đầu.' },
        { num: '02', title: 'Hồ sơ vận hành Nguyễn', desc: 'Hồ sơ vận hành, hệ giá trị, dữ liệu, công cụ, đội Agent và quy trình chuyên biệt cho cộng đồng Nguyễn — không phải công cụ AI chung.' },
        { num: '03', title: 'Song ngữ VI/EN', desc: 'Hỗ trợ tiếng Việt và tiếng Anh gốc với SEO hreflang. Chưa có nền tảng AI/gia phả toàn cầu làm điều này cho kiều bào Việt.' },
        { num: '04', title: 'Mạng lưới cộng đồng', desc: 'Nguyen Chapters, Nguyen Founders, Nguyen Network — phân phối gắn cộng đồng, tăng trưởng và giữ chân tự nhiên.' },
        { num: '05', title: 'Kho dữ liệu riêng tư', desc: 'Mỗi người dùng sở hữu kho dữ liệu. Riêng tư mặc định cho người đang sống và cây gia đình. Tuân thủ 91/2025 tạo lợi thế quy định.' },
        { num: '06', title: 'Phương pháp bằng chứng', desc: 'Nhãn bằng chứng bắt buộc. Không tuyên bố huyết thống hay dòng dõi hoàng tộc. Niềm tin nhờ sự nghiêm ngặt.' },
      ].map((m) => (
        <div class="bg-bg-card border border-bg-border rounded-xl p-6 card-hover">
          <div class="flex items-start gap-4">
            <span class="text-3xl font-serif font-bold text-gold shrink-0">{m.num}</span>
            <div>
              <h3 class="text-lg font-bold text-ink">{m.title}</h3>
              <p class="text-sm text-ink-muted mt-3">{m.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12"><Disclosure locale="vi" /></div>
  </section>
</InvestLayout>
