---
import InvestLayout from '../layouts/InvestLayout.astro';
import Disclosure from '../components/Disclosure.astro';
---

<InvestLayout
  title="Team"
  titleVi="Đội ngũ"
  description="Đội ngũ Máy Tính AI Nguyễn: nhà sáng lập, cố vấn (chưa công bố), và kế hoạch tuyển dụng."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Tổng quan đội ngũ">
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Đội ngũ</h1>

    <div class="mt-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-6">Nhà sáng lập</h2>
      <div class="bg-bg-card border border-bg-border rounded-xl p-8 card-hover">
        <div class="flex items-start gap-6">
          <div class="w-20 h-20 rounded-full bg-bg-soft border-2 border-gold/40 flex items-center justify-center shrink-0">
            <span class="text-3xl font-serif font-bold text-gold">N</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-ink">Nhà sáng lập &amp; CEO</h3>
            <p class="text-sm text-ink-muted mt-3">
              <em>Tiểu sử chi tiết sẽ được thêm sau khi thành lập thực thể pháp lý và xem xét công bố.</em>
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-6">Cố vấn</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          'Cố vấn kỹ thuật',
          'Cố vấn pháp lý & IP',
          'Cố vấn go-to-market',
        ].map((role) => (
          <div class="bg-bg-card border border-bg-border rounded-xl p-6 card-hover">
            <div class="w-16 h-16 rounded-full bg-bg-soft border border-bg-border flex items-center justify-center mb-4">
              <span class="text-ink-dim text-xl">?</span>
            </div>
            <h3 class="font-semibold text-ink">{role}</h3>
            <p class="text-sm text-ink-muted mt-2"><em>Chưa công bố.</em></p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-serif font-bold text-ink mb-6">Kế hoạch tuyển dụng</h2>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-bg-border">
              <th class="text-left py-3 text-ink-muted uppercase text-xs">Vai trò</th>
              <th class="text-left py-3 text-ink-muted uppercase text-xs">Giai đoạn</th>
              <th class="text-left py-3 text-ink-muted uppercase text-xs">Ưu tiên</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-bg-border">
            {[
              { role: 'Kỹ sư full-stack', phase: 'Giai đoạn 2', priority: 'Cao' },
              { role: 'Kỹ sư AI/ML', phase: 'Giai đoạn 2', priority: 'Cao' },
              { role: 'Kỹ sư bảo mật', phase: 'Giai đoạn 2–3', priority: 'Cao' },
              { role: 'Thiết kế sản phẩm', phase: 'Giai đoạn 2', priority: 'Trung bình' },
              { role: 'Quản lý cộng đồng', phase: 'Giai đoạn 3–5', priority: 'Trung bình' },
              { role: 'Bán hàng doanh nghiệp', phase: 'Giai đoạn 6', priority: 'Trung bình' },
            ].map((h) => (
              <tr>
                <td class="py-3 text-ink">{h.role}</td>
                <td class="py-3 text-ink-muted">{h.phase}</td>
                <td class="py-3">
                  <span class={`text-xs px-2 py-1 rounded ${h.priority === 'Cao' ? 'text-gold bg-gold/10' : 'text-ink-muted bg-bg-soft'}`}>{h.priority}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-12"><Disclosure locale="vi" /></div>
  </section>
</InvestLayout>
