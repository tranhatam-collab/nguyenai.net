---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout title="Investor Qualification" titleVi="Xác nhận nhà đầu tư" noindex={true}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-3 py-1 text-xs font-semibold text-red-400 border border-red-400/30 rounded-full">Private / Riêng tư</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Investor Qualification</h1>
    <p class="mt-2 text-xl text-ink-muted" lang="vi">Xác nhận nhà đầu tư</p>

    <p class="mt-6 text-ink-muted">
      Complete this form to request access to the private data room. All fields are required.
      <span class="block mt-2" lang="vi">Hoàn thành form để yêu cầu truy cập data room riêng tư.</span>
    </p>

    <form id="qual-form" class="mt-10 space-y-6 bg-bg-card border border-bg-border rounded-xl p-8">
      <div>
        <label for="q-name" class="block text-sm font-semibold text-ink mb-1">Full name / Họ tên <span class="text-gold">*</span></label>
        <input type="text" id="q-name" name="name" required class="w-full bg-bg border border-bg-border rounded-lg px-4 py-2.5 text-ink placeholder-ink-dim focus:border-gold focus:outline-none transition-colors" />
      </div>
      <div>
        <label for="q-email" class="block text-sm font-semibold text-ink mb-1">Email <span class="text-gold">*</span></label>
        <input type="email" id="q-email" name="email" required class="w-full bg-bg border border-bg-border rounded-lg px-4 py-2.5 text-ink placeholder-ink-dim focus:border-gold focus:outline-none transition-colors" />
      </div>
      <div>
        <label for="q-entity" class="block text-sm font-semibold text-ink mb-1">Entity type / Loại thực thể <span class="text-gold">*</span></label>
        <select id="q-entity" name="entity" required class="w-full bg-bg border border-bg-border rounded-lg px-4 py-2.5 text-ink focus:border-gold focus:outline-none transition-colors">
          <option value="">— Select / Chọn —</option>
          <option value="individual">Individual / Cá nhân</option>
          <option value="angel">Angel investor / Thiên thần</option>
          <option value="vc">Venture capital / Quỹ</option>
          <option value="family-office">Family office</option>
          <option value="strategic">Strategic / Chiến lược</option>
          <option value="other">Other / Khác</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-semibold text-ink mb-2">Accredited investor status / Tình trạng <span class="text-gold">*</span></label>
        <div class="space-y-2">
          <label class="flex items-center gap-3"><input type="radio" name="accredited" value="yes" required class="text-gold" /><span class="text-sm text-ink-muted">Yes / Có</span></label>
          <label class="flex items-center gap-3"><input type="radio" name="accredited" value="no" class="text-gold" /><span class="text-sm text-ink-muted">No / Không</span></label>
          <label class="flex items-center gap-3"><input type="radio" name="accredited" value="unsure" class="text-gold" /><span class="text-sm text-ink-muted">Not sure / Không chắc</span></label>
        </div>
      </div>
      <div>
        <label for="q-range" class="block text-sm font-semibold text-ink mb-1">Investment range / Phạm vi <span class="text-gold">*</span></label>
        <select id="q-range" name="range" required class="w-full bg-bg border border-bg-border rounded-lg px-4 py-2.5 text-ink focus:border-gold focus:outline-none transition-colors">
          <option value="">— Select / Chọn —</option>
          <option value="25-50">$25K – $50K</option>
          <option value="50-100">$50K – $100K</option>
          <option value="100-250">$100K – $250K</option>
          <option value="250+">$250K+</option>
        </select>
      </div>
      <button type="submit" class="w-full py-3 text-base font-semibold text-bg bg-gold hover:bg-gold-light rounded-lg transition-colors">
        Gửi xác nhận →
      </button>
    </form>

    <div id="qual-thank-you" class="hidden mt-10 bg-bg-card border border-gold/30 rounded-xl p-8 text-center border-gold-glow">
      <div class="text-4xl mb-4">✓</div>
      <h2 class="text-2xl font-serif font-bold text-ink">Đã gửi xác nhận</h2>
      <p class="mt-2 text-ink-muted">Chúng tôi sẽ phản hồi trong 48 giờ.</p>
      <a href="/private/data-room" class="inline-block mt-6 text-gold hover:text-gold-light text-sm">→ Tiếp tục vào data room</a>
    </div>

    <div class="mt-12"><Disclosure /></div>
  </section>

  <script>
    const form = document.getElementById('qual-form');
    const thankYou = document.getElementById('qual-thank-you');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      form.classList.add('hidden');
      thankYou?.classList.remove('hidden');
    });
  </script>
</InvestLayout>
