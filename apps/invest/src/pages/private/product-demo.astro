---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout title="Product Demo" titleVi="Demo sản phẩm" noindex={true}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-3 py-1 text-xs font-semibold text-red-400 border border-red-400/30 rounded-full">Private / Riêng tư</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Product Demo</h1>
    <p class="mt-2 text-xl text-ink-muted" lang="vi">Demo sản phẩm</p>

    <!-- Video embed area -->
    <div class="mt-10">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Video Walkthrough / Hướng dẫn video</h2>
      <div class="aspect-video bg-bg-card border border-bg-border rounded-xl flex items-center justify-center">
        <div class="text-center">
          <div class="text-5xl text-ink-dim mb-3">▶</div>
          <p class="text-ink-muted text-sm">Video embed area — demo to be added</p>
          <p class="text-ink-dim text-xs" lang="vi">Khu vực nhúng video — demo sẽ được thêm</p>
        </div>
      </div>
    </div>

    <!-- Screenshot gallery -->
    <div class="mt-12">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Screenshot Gallery / Thư viện ảnh chụp</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[1, 2, 3, 4, 5, 6].map((i) => (
          <div class="aspect-video bg-bg-card border border-bg-border rounded-lg flex items-center justify-center">
            <span class="text-ink-dim text-sm">Screenshot {i}</span>
          </div>
        ))}
      </div>
      <p class="mt-4 text-xs text-ink-dim italic">Screenshots to be added upon beta availability. <span lang="vi">Ảnh chụp sẽ được thêm khi có beta.</span></p>
    </div>

    <div class="mt-12"><Disclosure /></div>
  </section>
</InvestLayout>
