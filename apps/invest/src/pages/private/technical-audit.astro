---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout title="Technical Audit" titleVi="Kiểm toán kỹ thuật" noindex={true}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Kiểm toán kỹ thuật">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-3 py-1 text-xs font-semibold text-red-400 border border-red-400/30 rounded-full">Riêng tư</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Kiểm toán kỹ thuật</h1>

    <div class="mt-10">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Trạng thái nền tảng độc lập</h2>
      <div class="bg-bg-card border border-bg-border rounded-lg p-5">
        <h3 class="font-semibold text-ink">Nguyen AI Computer (nguyenai.net) — Độc lập</h3>
        <ul class="mt-3 space-y-2 text-sm text-ink-muted">
          <li class="flex items-start gap-2"><span class="text-gold">▸</span> Runtime, agent, model routing — backend riêng</li>
          <li class="flex items-start gap-2"><span class="text-gold">▸</span> Memory, tool, workflow, evidence — triển khai riêng</li>
          <li class="flex items-start gap-2"><span class="text-gold">▸</span> Auth: magic-link + passkey (SSO riêng)</li>
          <li class="flex items-start gap-2"><span class="text-gold">▸</span> Billing: Stripe (tài khoản riêng)</li>
          <li class="flex items-start gap-2"><span class="text-ink-dim">▸</span> Live runtime: chờ deploy</li>
        </ul>
      </div>
    </div>

    <div class="mt-8">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Kiểm toán bảo mật</h2>
      <div class="bg-bg-card border border-bg-border rounded-lg p-5">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-bg-border">
            <tr><td class="py-2 text-ink-muted">Trạng thái</td><td class="py-2 text-right text-gold">Đang chờ</td></tr>
            <tr><td class="py-2 text-ink-muted">Mã hóa khi lưu trữ</td><td class="py-2 text-right text-ink-muted">Đã lên kế hoạch</td></tr>
            <tr><td class="py-2 text-ink-muted">Mã hóa khi truyền</td><td class="py-2 text-right text-gold">TLS (Cloudflare)</td></tr>
            <tr><td class="py-2 text-ink-muted">Xác thực</td><td class="py-2 text-right text-ink-muted">Đã lên kế hoạch (Phase 2)</td></tr>
            <tr><td class="py-2 text-ink-muted">Kiểm thử xâm nhập</td><td class="py-2 text-right text-ink-muted">Trước production</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-8">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Kiểm toán quyền riêng tư</h2>
      <div class="bg-bg-card border border-bg-border rounded-lg p-5">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-bg-border">
            <tr><td class="py-2 text-ink-muted">Tuân thủ PDPD 91/2025</td><td class="py-2 text-right text-gold">Kiến trúc privacy-by-design</td></tr>
            <tr><td class="py-2 text-ink-muted">Dữ liệu người đang sống</td><td class="py-2 text-right text-gold">Riêng tư mặc định</td></tr>
            <tr><td class="py-2 text-ink-muted">Cây gia đình</td><td class="py-2 text-right text-gold">Riêng tư mặc định</td></tr>
            <tr><td class="py-2 text-ink-muted">Sở hữu data vault</td><td class="py-2 text-right text-gold">Người dùng sở hữu</td></tr>
            <tr><td class="py-2 text-ink-muted">Kiểm toán chính thức</td><td class="py-2 text-right text-ink-muted">Đang chờ</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-12"><Disclosure locale="vi" /></div>
  </section>
</InvestLayout>
