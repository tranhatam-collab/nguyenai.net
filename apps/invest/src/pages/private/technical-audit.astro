---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout title="Technical Audit" titleVi="Kiểm toán kỹ thuật" noindex={true}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-3 py-1 text-xs font-semibold text-red-400 border border-red-400/30 rounded-full">Private / Riêng tư</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Technical Audit</h1>
    <p class="mt-2 text-xl text-ink-muted" lang="vi">Kiểm toán kỹ thuật</p>

    <!-- Gen1/Gen2 status -->
    <div class="mt-10">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Gen1 / Gen2 Status</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-bg-card border border-bg-border rounded-lg p-5">
          <h3 class="font-semibold text-ink">Gen1 Core Engine (computer.iai.one)</h3>
          <ul class="mt-3 space-y-2 text-sm text-ink-muted">
            <li class="flex items-start gap-2"><span class="text-gold">▸</span> Runtime, agent, model routing — inherited</li>
            <li class="flex items-start gap-2"><span class="text-gold">▸</span> Memory, tool, workflow, evidence — inherited</li>
            <li class="flex items-start gap-2"><span class="text-ink-dim">▸</span> Live runtime: unverified</li>
          </ul>
        </div>
        <div class="bg-bg-card border border-bg-border rounded-lg p-5">
          <h3 class="font-semibold text-ink">Gen2 Product System (maytinhai.org)</h3>
          <ul class="mt-3 space-y-2 text-sm text-ink-muted">
            <li class="flex items-start gap-2"><span class="text-ink-dim">▸</span> AI Computer Console: not yet scaffolded</li>
            <li class="flex items-start gap-2"><span class="text-ink-dim">▸</span> Authentication: not yet implemented</li>
            <li class="flex items-start gap-2"><span class="text-ink-dim">▸</span> Data vault: not yet implemented</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Security audit -->
    <div class="mt-8">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Security Audit / Kiểm toán bảo mật</h2>
      <div class="bg-bg-card border border-bg-border rounded-lg p-5">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-bg-border">
            <tr><td class="py-2 text-ink-muted">Status</td><td class="py-2 text-right text-gold">Pending</td></tr>
            <tr><td class="py-2 text-ink-muted">Encryption at rest</td><td class="py-2 text-right text-ink-muted">Planned</td></tr>
            <tr><td class="py-2 text-ink-muted">Encryption in transit</td><td class="py-2 text-right text-gold">TLS (Cloudflare)</td></tr>
            <tr><td class="py-2 text-ink-muted">Authentication</td><td class="py-2 text-right text-ink-muted">Planned (Phase 2)</td></tr>
            <tr><td class="py-2 text-ink-muted">Penetration testing</td><td class="py-2 text-right text-ink-muted">Pre-production</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Privacy audit -->
    <div class="mt-8">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Privacy Audit / Kiểm toán quyền riêng tư</h2>
      <div class="bg-bg-card border border-bg-border rounded-lg p-5">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-bg-border">
            <tr><td class="py-2 text-ink-muted">PDPD 91/2025 compliance</td><td class="py-2 text-right text-gold">Privacy-by-design architecture</td></tr>
            <tr><td class="py-2 text-ink-muted">Living-person data</td><td class="py-2 text-right text-gold">Private by default</td></tr>
            <tr><td class="py-2 text-ink-muted">Family trees</td><td class="py-2 text-right text-gold">Private by default</td></tr>
            <tr><td class="py-2 text-ink-muted">Data vault ownership</td><td class="py-2 text-right text-gold">User-owned</td></tr>
            <tr><td class="py-2 text-ink-muted">Formal audit</td><td class="py-2 text-right text-ink-muted">Pending</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-12"><Disclosure /></div>
  </section>
</InvestLayout>
