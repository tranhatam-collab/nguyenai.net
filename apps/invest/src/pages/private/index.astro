---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout title="Data Room" titleVi="Data room" noindex={true}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-3 py-1 text-xs font-semibold text-red-400 border border-red-400/30 rounded-full">Private / Riêng tư</span>
      <span class="px-3 py-1 text-xs font-semibold text-gold border border-gold/30 rounded-full">Requires qualification</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Data Room</h1>
    <p class="mt-2 text-xl text-ink-muted" lang="vi">Phòng dữ liệu</p>

    <div class="mt-8 bg-bg-card border border-gold/20 rounded-xl p-6 border-gold-glow">
      <p class="text-ink-muted">
        This is the private investor data room. Access requires investor qualification. All access is logged, expiring, and revocable.
        <span class="block mt-2" lang="vi">Đây là data room nhà đầu tư riêng tư. Truy cập yêu cầu xác nhận. Mọi truy cập được ghi nhật ký, có thời hạn và có thể thu hồi.</span>
      </p>
      <div class="mt-4 flex flex-col sm:flex-row gap-3">
        <a href="/private/qualification" class="px-5 py-2.5 text-sm font-semibold text-bg bg-gold hover:bg-gold-light rounded-lg transition-colors text-center">
          Complete qualification / Hoàn thành xác nhận →
        </a>
        <a href="/private/data-room" class="px-5 py-2.5 text-sm font-semibold text-gold border border-gold/30 rounded-lg hover:bg-gold/10 transition-colors text-center">
          Browse documents / Xem tài liệu →
        </a>
      </div>
    </div>

    <!-- Quick links -->
    <div class="mt-12">
      <h2 class="text-xl font-serif font-bold text-ink mb-6">Data Room Sections / Phần data room</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/private/data-room', label: 'Document index', vi: 'Mục lục tài liệu' },
          { href: '/private/product-demo', label: 'Product demo', vi: 'Demo sản phẩm' },
          { href: '/private/financial-model', label: 'Financial model', vi: 'Mô hình tài chính' },
          { href: '/private/cap-table', label: 'Cap table', vi: 'Bảng cổ phần' },
          { href: '/private/technical-audit', label: 'Technical audit', vi: 'Kiểm toán kỹ thuật' },
          { href: '/private/ip', label: 'IP ownership', vi: 'Sở hữu IP' },
          { href: '/private/security', label: 'Security overview', vi: 'Tổng quan bảo mật' },
          { href: '/private/contracts', label: 'Legal documents', vi: 'Tài liệu pháp lý' },
        ].map((link) => (
          <a href={link.href} class="bg-bg-card border border-bg-border rounded-lg p-4 card-hover flex items-center justify-between">
            <div>
              <span class="font-semibold text-ink text-sm">{link.label}</span>
              <span class="block text-xs text-ink-dim" lang="vi">{link.vi}</span>
            </div>
            <span class="text-gold">→</span>
          </a>
        ))}
      </div>
    </div>

    <div class="mt-12"><Disclosure /></div>
  </section>
</InvestLayout>
