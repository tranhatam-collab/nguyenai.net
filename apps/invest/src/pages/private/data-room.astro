---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout title="Document Index" titleVi="Mục lục tài liệu" noindex={true}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Mục lục tài liệu">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-3 py-1 text-xs font-semibold text-red-400 border border-red-400/30 rounded-full">Riêng tư</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Mục lục tài liệu</h1>

    <div class="mt-10 space-y-3">
      {[
        { href: '/private/product-demo', label: 'Demo sản phẩm', desc: 'Video hướng dẫn và thư viện ảnh chụp' },
        { href: '/private/financial-model', label: 'Mô hình tài chính', desc: 'Giả thuyết doanh thu, phân tích độ nhạy' },
        { href: '/private/cap-table', label: 'Bảng cổ phần', desc: 'Pre-money, vòng gọi vốn, post-money, pha loãng' },
        { href: '/private/technical-audit', label: 'Kiểm toán kỹ thuật', desc: 'Trạng thái nền tảng, bảo mật, quyền riêng tư' },
        { href: '/private/ip', label: 'Sở hữu IP', desc: 'Mô hình HoldCo, điều khoản cấp phép' },
        { href: '/private/security', label: 'Tổng quan bảo mật', desc: 'PDPD 91/2025, luồng dữ liệu, mã hóa' },
        { href: '/private/contracts', label: 'Tài liệu pháp lý', desc: 'Term sheet, SAFE, thỏa thuận đăng ký' },
      ].map((doc) => (
        <a href={doc.href} class="block bg-bg-card border border-bg-border rounded-lg p-5 card-hover">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="font-semibold text-ink">{doc.label}</h3>
              <p class="text-sm text-ink-muted mt-1">{doc.desc}</p>
            </div>
            <span class="text-gold text-xl">→</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Chính sách truy cập</h2>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6">
        <ul class="space-y-3 text-sm text-ink-muted">
          <li class="flex items-start gap-2"><span class="text-gold mt-0.5">▸</span> <strong class="text-ink">Yêu cầu xác nhận:</strong> Mọi khách phải hoàn thành xác nhận nhà đầu tư trước khi xem tài liệu.</li>
          <li class="flex items-start gap-2"><span class="text-gold mt-0.5">▸</span> <strong class="text-ink">Nhật ký kiểm toán:</strong> Mọi truy cập tài liệu được ghi với thời gian, IP và danh tính.</li>
          <li class="flex items-start gap-2"><span class="text-gold mt-0.5">▸</span> <strong class="text-ink">Truy cập có thời hạn:</strong> Quyền truy cập hết hạn sau 90 ngày trừ khi gia hạn.</li>
          <li class="flex items-start gap-2"><span class="text-gold mt-0.5">▸</span> <strong class="text-ink">Có thể thu hồi:</strong> Founder có thể thu hồi quyền truy cập bất cứ lúc nào, vì bất kỳ lý do nào.</li>
          <li class="flex items-start gap-2"><span class="text-gold mt-0.5">▸</span> <strong class="text-ink">Không tải xuống:</strong> Tài liệu chỉ xem. Không in, tải xuống hay chụp màn hình.</li>
          <li class="flex items-start gap-2"><span class="text-gold mt-0.5">▸</span> <strong class="text-ink">NDA:</strong> Truy cập đồng nghĩa chấp nhận điều khoản bảo mật.</li>
        </ul>
      </div>
    </div>

    <div class="mt-8">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Nhật ký truy cập gần đây</h2>
      <div class="bg-bg-card border border-bg-border rounded-xl p-5">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-bg-border">
              <th class="text-left py-2 text-ink-muted uppercase text-xs">Thời gian</th>
              <th class="text-left py-2 text-ink-muted uppercase text-xs">Khách</th>
              <th class="text-left py-2 text-ink-muted uppercase text-xs">Tài liệu</th>
              <th class="text-right py-2 text-ink-muted uppercase text-xs">Trạng thái</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-bg-border">
            <tr><td class="py-2 text-ink-dim">—</td><td class="py-2 text-ink-dim">Chưa có truy cập</td><td class="py-2 text-ink-dim">—</td><td class="py-2 text-right text-ink-dim">—</td></tr>
          </tbody>
        </table>
        <p class="mt-3 text-xs text-ink-dim italic">Nhật ký sẽ có khi nhà đầu tư thật truy cập.</p>
      </div>
    </div>

    <div class="mt-12"><Disclosure locale="vi" /></div>
  </section>
</InvestLayout>
