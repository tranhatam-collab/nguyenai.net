---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout title="Security Overview" titleVi="Tổng quan bảo mật" noindex={true}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Tổng quan bảo mật">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-3 py-1 text-xs font-semibold text-red-400 border border-red-400/30 rounded-full">Riêng tư</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Tổng quan bảo mật</h1>

    <div class="mt-10 bg-bg-card border border-bg-border rounded-xl p-6">
      <h2 class="text-xl font-serif font-bold text-ink mb-2">Tuân thủ PDPD 91/2025</h2>
      <ul class="space-y-2 text-sm text-ink-muted">
        <li class="flex items-start gap-2"><span class="text-gold">▸</span> Kiến trúc privacy-by-design</li>
        <li class="flex items-start gap-2"><span class="text-gold">▸</span> Dữ liệu người đang sống riêng tư mặc định</li>
        <li class="flex items-start gap-2"><span class="text-gold">▸</span> Cây gia đình riêng tư mặc định</li>
        <li class="flex items-start gap-2"><span class="text-gold">▸</span> Data vault do người dùng sở hữu, cần đồng ý rõ ràng</li>
        <li class="flex items-start gap-2"><span class="text-gold">▸</span> Nguyên tắc tối thiểu hóa dữ liệu</li>
        <li class="flex items-start gap-2"><span class="text-ink-dim">▸</span> Kiểm toán tuân thủ chính thức: đang chờ</li>
      </ul>
    </div>

    <div class="mt-8">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Luồng dữ liệu</h2>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6">
        <div class="space-y-3">
          {[
            'Người dùng → AI Computer Instance (mã hóa TLS)',
            'Instance → Model Mesh (định tuyến mã hóa)',
            'Model Mesh → nhà cung cấp AI (API, không rò rỉ PII)',
            'Instance → Data vault (mã hóa khi lưu trữ)',
            'Instance → Đội Agent (thực thi trong sandbox)',
          ].map((step, i) => (
            <div class="flex items-center gap-3 p-3 bg-bg-soft rounded-lg border border-bg-border">
              <span class="text-gold font-mono text-xs shrink-0">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-sm text-ink-muted">{step}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-8">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Mã hóa</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-bg-card border border-bg-border rounded-lg p-5">
          <h3 class="font-semibold text-ink text-sm">Khi truyền</h3>
          <p class="text-sm text-ink-muted mt-2">TLS 1.3 qua Cloudflare. Mọi gọi API đều được mã hóa.</p>
          <span class="inline-block mt-2 text-xs text-gold">Đang hoạt động</span>
        </div>
        <div class="bg-bg-card border border-bg-border rounded-lg p-5">
          <h3 class="font-semibold text-ink text-sm">Khi lưu trữ</h3>
          <p class="text-sm text-ink-muted mt-2">Mã hóa AES-256 cho lưu trữ data vault.</p>
          <span class="inline-block mt-2 text-xs text-ink-dim">Đã lên kế hoạch (Phase 2)</span>
        </div>
      </div>
    </div>

    <div class="mt-12"><Disclosure locale="vi" /></div>
  </section>
</InvestLayout>
