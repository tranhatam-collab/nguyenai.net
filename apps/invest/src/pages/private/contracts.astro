---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout title="Legal Documents" titleVi="Tài liệu pháp lý" noindex={true}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Tài liệu pháp lý">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-3 py-1 text-xs font-semibold text-red-400 border border-red-400/30 rounded-full">Riêng tư</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Tài liệu pháp lý</h1>

    <div class="mt-6 p-4 bg-gold/10 border border-gold/30 rounded-lg">
      <p class="text-sm text-gold">
        ⚠ Mọi tài liệu là mẫu. Chưa có term sheet, SAFE hay thỏa thuận đăng ký nào được ký kết.
      </p>
    </div>

    <div class="mt-10 space-y-4">
      {[
        { name: 'Term Sheet', desc: 'Điều khoản chính: định giá, vốn gọi, pha loãng, hội đồng, ưu tiên thanh lý', status: 'Placeholder', terms: [
          { k: 'Định giá pre-money', v: '$4.5M USD' },
          { k: 'Số vốn gọi', v: '$750K USD' },
          { k: 'Công cụ', v: 'SAFE hoặc equity (thương lượng)' },
          { k: 'Chiết khấu', v: '20% (SAFE) — thương lượng' },
          { k: 'Valuation cap', v: '$4.5M (SAFE) — thương lượng' },
          { k: 'Điều khoản MFN', v: 'Có — chuẩn' },
          { k: 'Quyền pro-rata', v: 'Có — cho nhà đầu tư > $50K' },
          { k: 'Hội đồng', v: 'Founder kiểm soát, 1 ghế quan sát cho lead investor' },
          { k: 'Ưu tiên thanh lý', v: '1x non-participating (vòng equity)' },
          { k: 'Chống pha loãng', v: 'Broad-based weighted average' },
          { k: 'Điều kiện đóng', v: 'Thành lập thực thể + chuyển IP + KYC/AML' },
        ] },
        { name: 'SAFE Agreement', desc: 'Simple Agreement for Future Equity — mẫu YC SAFE chuẩn (post-money)', status: 'Placeholder', terms: [
          { k: 'Mẫu', v: 'Y Combinator Post-Money SAFE (chuẩn)' },
          { k: 'Cap', v: '$4.5M post-money' },
          { k: 'Chiết khấu', v: '20%' },
          { k: 'MFN', v: 'Có — điều khoản chuẩn' },
          { k: 'Pro-rata', v: 'Side letter cho nhà đầu tư > $50K' },
          { k: 'Luật áp dụng', v: 'Singapore hoặc Việt Nam (TBD với tư vấn)' },
          { k: 'Tiền tệ', v: 'USD' },
          { k: 'Đầu tư tối thiểu', v: '$25K' },
        ] },
        { name: 'Subscription Agreement', desc: 'Điều khoản đăng ký cổ phần, điều kiện, tuyên bố và bảo đảm', status: 'Placeholder', terms: [
          { k: 'Loại cổ phần', v: 'Ordinary shares (vòng equity)' },
          { k: 'Giá mỗi cổ phần', v: 'Dựa trên post-money / tổng cổ phần' },
          { k: 'Lock-up', v: '12 tháng sau đóng' },
          { k: 'Hạn chế chuyển nhượng', v: 'Right of first refusal + co-sale' },
          { k: 'Quyền thông tin', v: 'Báo cáo quý + năm cho > $50K' },
          { k: 'Tuyên bố', v: 'Reps chuẩn của nhà đầu tư + công ty' },
          { k: 'Điều kiện', v: 'Thành lập thực thể + chuyển IP + tài khoản ngân hàng' },
          { k: 'Đóng', v: 'Trong 30 ngày sau ký term sheet' },
        ] },
        { name: 'IP Assignment Agreement', desc: 'Chuyển toàn bộ IP từ founder sang HoldCo — điều kiện tiên quyết để chốt đầu tư', status: 'Placeholder', terms: [
          { k: 'Từ', v: 'Founder(s) — tư cách cá nhân' },
          { k: 'Đến', v: 'HoldCo (thực thể nắm IP)' },
          { k: 'Phạm vi', v: 'Toàn bộ code, brand, trademarks, docs, datasets, thiết kế Agent' },
          { k: 'Đối giá', v: 'Cổ phần Founders trong HoldCo' },
          { k: 'Ngày hiệu lực', v: 'Ngày đóng' },
          { k: 'Bảo đảm', v: 'Founder sở hữu toàn bộ IP, không có khiếu nại bên thứ ba' },
          { k: 'Trạng thái', v: '⚠ ĐANG CHỜ — điều kiện tiên quyết để đóng' },
        ] },
        { name: 'Data Processing Agreement', desc: 'DPA tuân thủ PDPD 91/2025 cho xử lý dữ liệu người dùng', status: 'Placeholder', terms: [
          { k: 'Controller', v: 'Người dùng (chủ dữ liệu)' },
          { k: 'Processor', v: 'Nguyen AI OpCo' },
          { k: 'Luật', v: 'Vietnam PDPD 91/2025 + GDPR (người dùng EU)' },
          { k: 'Sub-processors', v: 'Cloudflare, Neon, Stripe — liệt kê trong phụ lục DPA' },
          { k: 'Vị trí dữ liệu', v: 'Cloudflare edge + Singapore (Neon primary)' },
          { k: 'Lưu trữ', v: 'Theo chính sách phân loại dữ liệu' },
          { k: 'Thông báo vi phạm', v: '72 giờ' },
        ] },
      ].map((doc) => (
        <div class="bg-bg-card border border-bg-border rounded-xl p-6 card-hover">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-3">
                <h3 class="text-lg font-bold text-ink">{doc.name}</h3>
                <span class="text-xs px-2 py-0.5 text-ink-dim bg-bg-soft rounded border border-bg-border">{doc.status}</span>
              </div>
              <p class="text-sm text-ink-muted mt-2">{doc.desc}</p>
            </div>
            <span class="text-ink-dim text-2xl">📄</span>
          </div>
          <div class="mt-4 overflow-x-auto">
            <table class="w-full text-sm">
              <tbody class="divide-y divide-bg-border">
                {doc.terms.map((t) => (
                  <tr>
                    <td class="py-2 text-ink-muted text-xs uppercase">{t.k}</td>
                    <td class="py-2 text-right text-ink text-sm">{t.v}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="mt-4 p-3 bg-bg-soft rounded-lg border border-bg-border">
            <p class="text-xs text-ink-dim italic">
              Tài liệu sẽ được soạn với tư vấn pháp lý khi thành lập thực thể. Chưa có tài khoản ngân hàng hay văn bản ký kết.
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12">
      <h2 class="text-xl font-serif font-bold text-ink mb-4">Điều kiện tiên quyết pháp lý</h2>
      <div class="bg-bg-card border border-bg-border rounded-xl p-6">
        <ul class="space-y-3 text-sm">
          {[
            { item: 'Thành lập thực thể (HoldCo + OpCo)', status: 'Đang chờ' },
            { item: 'Chuyển nhượng IP sang HoldCo', status: 'Đang chờ — điều kiện tiên quyết' },
            { item: 'Tài khoản ngân hàng (USD + VND)', status: 'Đang chờ' },
            { item: 'KYC/AML cho nhà đầu tư', status: 'Theo từng nhà đầu tư' },
            { item: 'Thuê tư vấn pháp lý', status: 'Đang chờ' },
            { item: 'Quyết định luật áp dụng (SG vs VN)', status: 'Đang chờ' },
          ].map((p) => (
            <li class="flex items-center justify-between p-3 bg-bg-soft rounded-lg border border-bg-border">
              <span class="text-ink">{p.item}</span>
              <span class="text-xs px-2 py-1 text-red-400 bg-red-400/10 rounded border border-red-400/30">{p.status}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12"><Disclosure locale="vi" /></div>
  </section>
</InvestLayout>
