---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout title="Legal Documents" titleVi="Tài liệu pháp lý" noindex={true}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-3 py-1 text-xs font-semibold text-red-400 border border-red-400/30 rounded-full">Private / Riêng tư</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Legal Documents</h1>
    <p class="mt-2 text-xl text-ink-muted" lang="vi">Tài liệu pháp lý</p>

    <div class="mt-6 p-4 bg-gold/10 border border-gold/30 rounded-lg">
      <p class="text-sm text-gold">
        ⚠ All documents are placeholders. No real term sheet, SAFE, or subscription agreement has been executed.
        <span class="block" lang="vi">Mọi tài liệu là mẫu. Chưa có văn bản nào được ký kết.</span>
      </p>
    </div>

    <div class="mt-10 space-y-4">
      {[
        { name: 'Term Sheet', vi: 'Bản điều khoản', desc: 'Key terms: valuation, raise, dilution, board, liquidation preferences', status: 'Placeholder' },
        { name: 'SAFE Agreement', vi: 'Thỏa thuận SAFE', desc: 'Simple Agreement for Future Equity — standard YC SAFE template', status: 'Placeholder' },
        { name: 'Subscription Agreement', vi: 'Thỏa thuận đăng ký', desc: 'Share subscription terms, conditions, representations', status: 'Placeholder' },
      ].map((doc) => (
        <div class="bg-bg-card border border-bg-border rounded-xl p-6 card-hover">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-3">
                <h3 class="text-lg font-bold text-ink">{doc.name}</h3>
                <span class="text-xs px-2 py-0.5 text-ink-dim bg-bg-soft rounded border border-bg-border">{doc.status}</span>
              </div>
              <p class="text-sm text-gold" lang="vi">{doc.vi}</p>
              <p class="text-sm text-ink-muted mt-2">{doc.desc}</p>
            </div>
            <span class="text-ink-dim text-2xl">📄</span>
          </div>
          <div class="mt-4 p-3 bg-bg-soft rounded-lg border border-bg-border">
            <p class="text-xs text-ink-dim italic">
              Document to be prepared with legal counsel upon entity formation. No bank account or executed documents exist yet.
              <span class="block" lang="vi">Tài liệu sẽ được soạn với tư vấn pháp lý. Chưa có tài khoản ngân hàng hay văn bản ký kết.</span>
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12"><Disclosure /></div>
  </section>
</InvestLayout>
