---
import InvestLayout from '../layouts/InvestLayout.astro';
import RoadmapPhase from '../components/RoadmapPhase.astro';
import Disclosure from '../components/Disclosure.astro';
---

<InvestLayout
  title="Roadmap"
  titleVi="Lộ trình"
  description="Lộ trình Máy Tính AI Nguyễn: Giai đoạn 0 đến 6 — từ căn chỉnh thương hiệu đến mở rộng nền tảng."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Tổng quan lộ trình">
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-gold-gradient">Lộ trình</h1>

    <p class="mt-6 text-lg text-ink-muted max-w-3xl">
      Bảy giai đoạn từ nền tảng đến mở rộng. Trọng tâm hiện tại là Giai đoạn 0–1: thương hiệu, thực thể pháp lý và sở hữu IP.
    </p>

    <div class="mt-12 max-w-3xl">
      <RoadmapPhase
        locale="vi"
        phase="Giai đoạn 0"
        title="Sửa chữa &amp; căn chỉnh"
        status="active"
        items={[
          'Kiểm toán thương hiệu và làm sạch nhiễm clone',
          'Gỡ bề mặt thương hiệu cũ',
          'Khóa định vị (Master Positioning)',
          'Thiết lập quy tắc AGENTS.md',
        ]}
      />
      <RoadmapPhase
        locale="vi"
        phase="Giai đoạn 1"
        title="Thực thể pháp lý &amp; sở hữu IP"
        status="planned"
        items={[
          'Thành lập thực thể (mô hình HoldCo)',
          'Chuyển nhượng IP sang thực thể',
          'Chính thức hóa bảng cổ phần',
          'Term sheet và tài liệu đầu tư',
        ]}
      />
      <RoadmapPhase
        locale="vi"
        phase="Giai đoạn 2"
        title="Khung ứng dụng"
        status="planned"
        items={[
          'Console Máy Tính AI (app.nguyenai.net)',
          'Xác thực và kho dữ liệu',
          'Tích hợp đội Agent',
          'Định tuyến Model Mesh',
        ]}
      />
      <RoadmapPhase
        locale="vi"
        phase="Giai đoạn 3"
        title="Khởi động Academy"
        status="planned"
        items={[
          'edu.nguyenai.net — học AI miễn phí',
          'Chương trình chứng nhận',
          'Giáo trình song ngữ (VI/EN)',
        ]}
      />
      <RoadmapPhase
        locale="vi"
        phase="Giai đoạn 4"
        title="Đầu tư &amp; gọi vốn"
        status="planned"
        items={[
          'Site nhà đầu tư live (invest.nguyenai.net)',
          'Data room cho nhà đầu tư đủ điều kiện',
          'Đóng vòng seed 750K USD',
        ]}
      />
      <RoadmapPhase
        locale="vi"
        phase="Giai đoạn 5"
        title="Chương trình beta"
        status="planned"
        items={[
          'Beta kín với thành viên cộng đồng Nguyễn',
          'Vòng phản hồi và lặp lại',
          'Kiểm toán bảo mật và quyền riêng tư',
          'Xác minh tuân thủ Nghị định 91/2025',
        ]}
      />
      <RoadmapPhase
        locale="vi"
        phase="Giai đoạn 6"
        title="Mở rộng"
        status="planned"
        items={[
          'Ra mắt công khai',
          'Triển khai chương trình Chapter',
          'Bán hàng doanh nghiệp',
          'Mở rộng kiều bào quốc tế',
        ]}
      />
    </div>

    <div class="mt-12"><Disclosure locale="vi" /></div>
  </section>
</InvestLayout>
