---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout
  title="Risks"
  locale="en"
  description="Risks — Nguyen AI Computer investor information."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Risks information">
    <div class="bg-bg-card border border-gold/20 rounded-xl p-8 text-center">
      <h1 class="text-2xl font-serif font-bold text-gold mb-3">English version coming soon</h1>
      <p class="text-ink-muted mb-4">This page is being translated. Please see the <a href="/risks" class="text-gold underline">Vietnamese version</a> in the meantime.</p>
    </div>
    <div class="mt-8"><Disclosure locale="en" /></div>
  </section>
</InvestLayout>
