---
import InvestLayout from '../../layouts/InvestLayout.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout
  title="Team"
  locale="en"
  description="Team — Nguyen AI Computer investor information."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Team information">
    <div class="bg-bg-card border border-gold/20 rounded-xl p-8 text-center">
      <h1 class="text-2xl font-serif font-bold text-gold mb-3">English version coming soon</h1>
      <p class="text-ink-muted mb-4">This page is being translated. Please see the <a href="/team" class="text-gold underline">Vietnamese version</a> in the meantime.</p>
      <p class="text-sm text-ink-dim" lang="vi">Trang tiếng Anh đang được xây dựng. Vui lòng xem <a href="/team" class="text-gold underline">phiên bản tiếng Việt</a>.</p>
    </div>
    <div class="mt-8"><Disclosure /></div>
  </section>
</InvestLayout>
