---
import InvestLayout from '../../layouts/InvestLayout.astro';
import MetricCard from '../../components/MetricCard.astro';
import Disclosure from '../../components/Disclosure.astro';
---

<InvestLayout
  title="Investment Thesis"
  locale="en"
  description="Nguyen AI Computer — raising 750K USD at 4.5M pre-money valuation. Specialized cloud AI Computer for the global Nguyen ecosystem."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24" aria-label="Investment thesis overview">
    <!-- Hero -->
    <div class="text-center max-w-4xl mx-auto">
      <div class="inline-block px-3 py-1 mb-6 text-xs font-semibold text-gold border border-gold/30 rounded-full uppercase tracking-wider">
        Investor Opportunity
      </div>
      <h1 class="text-4xl md:text-6xl font-serif font-bold leading-tight">
        <span class="text-gold-gradient">Nguyen AI Computer</span>
      </h1>
      <p class="mt-4 text-xl md:text-2xl text-ink-muted">
        A specialized cloud AI Computer for the global Nguyen ecosystem.
      </p>
    </div>

    <!-- Key metrics -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16">
      <MetricCard value="$4.5M" label="Pre-money valuation" />
      <MetricCard value="$750K" label="Target raise" />
      <MetricCard value="Seed" label="Round type" />
    </div>

    <!-- Thesis summary -->
    <div class="mt-16 max-w-3xl mx-auto">
      <h2 class="text-2xl font-serif font-bold text-ink mb-6">Thesis Summary</h2>
      <div class="space-y-4 text-ink-muted">
        <p>Nguyen AI Computer is a specialized cloud AI Computer line built for the global Nguyen ecosystem — one of the world's largest surname communities with an estimated 4M+ people across Vietnam and the diaspora.</p>
        <p>The product is NOT only a genealogy site, NOT only a heritage network, NOT a chatbot, and NOT a generic AI tool catalog. It is a full AI Computer — with multi-model intelligence, an Agent team, tools, memory, data vault, workflows, evidence, approval gates, and a secure execution environment.</p>
        <p>Heritage and genealogy are important Super Apps, not the whole product. The platform also includes AI Office, AI Research, AI Content, AI Code, AI Founder OS, AI Business OS, and more.</p>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-16 text-center">
      <a href="/en/request-access" class="inline-block px-8 py-3 text-sm font-semibold text-bg bg-gold hover:bg-gold-light rounded-lg transition-colors">
        Request Investor Access →
      </a>
      <p class="mt-3 text-xs text-ink-dim">Qualified investors only. All access is logged and revocable.</p>
    </div>

    <div class="mt-16"><Disclosure locale="en" /></div>
  </section>
</InvestLayout>
