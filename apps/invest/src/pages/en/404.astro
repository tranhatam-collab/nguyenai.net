---
import InvestLayout from '../../layouts/InvestLayout.astro';
---

<InvestLayout title="404 — Page Not Found" locale="en" noindex={true}>
  <section class="max-w-3xl mx-auto px-4 py-24 text-center" aria-label="Page not found">
    <div class="text-6xl font-serif font-bold text-gold-gradient mb-4">404</div>
    <h1 class="text-2xl font-serif font-bold text-ink mb-3">Page Not Found</h1>
    <p class="text-ink-muted mb-8">The page you are looking for does not exist or has been moved.</p>
    <a href="/en" class="inline-block px-6 py-2.5 text-sm font-semibold text-bg bg-gold hover:bg-gold-light rounded-lg transition-colors">
      ← Back to Investor Home
    </a>
  </section>
</InvestLayout>
