---
/**
 * PricingTable.astro — 8-plan pricing table (V2). Single-locale.
 */
interface Props {
  locale?: 'vi' | 'en';
}
const { locale = 'vi' } = Astro.props;
const isVi = locale === 'vi';

const plans = [
  {
    name: 'Nguyen Start',
    price: isVi ? 'Miễn phí' : 'Free',
    period: '',
    target: isVi ? 'Người dùng mới' : 'New users',
    features: isVi
      ? ['Máy Tính AI cốt lõi', '1 Agent', 'Truy cập cộng đồng']
      : ['Core AI Computer', '1 Agent', 'Community access'],
  },
  {
    name: 'Nguyen Personal',
    price: '299K',
    period: isVi ? '/tháng' : '/mo',
    target: isVi ? 'Cá nhân' : 'Individuals',
    features: isVi
      ? ['5 Agent', 'AI Office', 'Kho nhớ']
      : ['5 Agents', 'AI Office', 'Memory vault'],
  },
  {
    name: 'Nguyen Family',
    price: '599K',
    period: isVi ? '/tháng' : '/mo',
    target: isVi ? 'Gia đình' : 'Families',
    features: isVi
      ? ['Cây gia đình', 'Kho dùng chung', 'Nguyen Roots']
      : ['Family tree', 'Shared vault', 'Nguyen Roots'],
  },
  {
    name: 'Nguyen Creator',
    price: '999K',
    period: isVi ? '/tháng' : '/mo',
    target: isVi ? 'Nhà sáng tạo' : 'Content creators',
    features: isVi
      ? ['AI Content', 'AI Media', 'Công cụ xuất bản']
      : ['AI Content', 'AI Media', 'Publishing tools'],
  },
  {
    name: 'Nguyen Founder',
    price: '1.999M',
    period: isVi ? '/tháng' : '/mo',
    target: isVi ? 'Nhà sáng lập' : 'Founders',
    features: isVi
      ? ['Founder OS', 'AI Finance', 'AI Legal']
      : ['Founder OS', 'AI Finance', 'AI Legal'],
  },
  {
    name: 'Nguyen Business',
    price: '4.999M',
    period: isVi ? '/tháng' : '/mo',
    target: isVi ? 'Doanh nghiệp nhỏ' : 'SMBs',
    features: isVi
      ? ['Business OS', 'AI Sales', 'Ghế đội ngũ']
      : ['Business OS', 'AI Sales', 'Team seats'],
  },
  {
    name: 'Nguyen Chapter',
    price: '7.999M',
    period: isVi ? '/tháng' : '/mo',
    target: isVi ? 'Hội đồng Nguyễn' : 'Nguyen chapters',
    features: isVi
      ? ['Chapter OS', 'Công cụ mạng lưới', 'Sự kiện']
      : ['Chapter OS', 'Network tools', 'Events'],
  },
  {
    name: 'Nguyen Enterprise',
    price: isVi ? 'Tùy chỉnh' : 'Custom',
    period: '',
    target: isVi ? 'Tổ chức lớn' : 'Large orgs',
    features: isVi
      ? ['Instance riêng', 'Agent tùy chỉnh', 'SLA']
      : ['Dedicated instance', 'Custom Agents', 'SLA'],
  },
];
---

<div class="overflow-x-auto">
  <table class="w-full text-sm border-collapse">
    <thead>
      <tr class="border-b border-bg-border">
        <th class="text-left py-3 px-4 text-ink-muted font-semibold uppercase text-xs tracking-wide">
          {isVi ? 'Gói' : 'Plan'}
        </th>
        <th class="text-left py-3 px-4 text-ink-muted font-semibold uppercase text-xs tracking-wide">
          {isVi ? 'Giá' : 'Price'}
        </th>
        <th class="text-left py-3 px-4 text-ink-muted font-semibold uppercase text-xs tracking-wide">
          {isVi ? 'Đối tượng' : 'Target'}
        </th>
        <th class="text-left py-3 px-4 text-ink-muted font-semibold uppercase text-xs tracking-wide">
          {isVi ? 'Tính năng chính' : 'Key features'}
        </th>
      </tr>
    </thead>
    <tbody>
      {plans.map((plan) => (
        <tr class="border-b border-bg-border/50 hover:bg-bg-soft/50 transition-colors">
          <td class="py-4 px-4">
            <div class="font-semibold text-ink">{plan.name}</div>
          </td>
          <td class="py-4 px-4">
            <span class="text-gold font-bold text-base">{plan.price}</span>
            {plan.period && <span class="text-ink-muted text-xs">{plan.period}</span>}
          </td>
          <td class="py-4 px-4 text-ink-muted">{plan.target}</td>
          <td class="py-4 px-4">
            <ul class="space-y-1">
              {plan.features.map((f) => (
                <li class="text-ink-muted text-xs flex items-start gap-1.5">
                  <span class="text-gold mt-0.5">▸</span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
