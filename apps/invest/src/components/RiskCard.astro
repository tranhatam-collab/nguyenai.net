---
/**
 * RiskCard.astro — Risk with mitigation.
 * Props: risk, likelihood, impact, mitigation
 */
interface Props {
  risk: string;
  riskVi?: string;
  likelihood: 'Low' | 'Medium' | 'High';
  impact: 'Low' | 'Medium' | 'High';
  mitigation: string;
  mitigationVi?: string;
}
const { risk, riskVi, likelihood, impact, mitigation, mitigationVi } = Astro.props;

const levelColor = (level: string) => {
  if (level === 'High') return 'text-red-400 bg-red-400/10 border-red-400/30';
  if (level === 'Medium') return 'text-gold bg-gold/10 border-gold/30';
  return 'text-green-400 bg-green-400/10 border-green-400/30';
};
---

<div class="bg-bg-card border border-bg-border rounded-xl p-5 card-hover">
  <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
    <h3 class="text-base font-bold text-ink flex-1">{risk}</h3>
    <div class="flex gap-2 shrink-0">
      <span class={`text-xs px-2 py-1 rounded border ${levelColor(likelihood)}`}>L: {likelihood}</span>
      <span class={`text-xs px-2 py-1 rounded border ${levelColor(impact)}`}>I: {impact}</span>
    </div>
  </div>
  {riskVi && <p class="text-sm text-ink-muted mb-3" lang="vi">{riskVi}</p>}
  <div class="mt-3 pt-3 border-t border-bg-border">
    <div class="text-xs font-semibold text-gold uppercase tracking-wide mb-1">Mitigation / Giảm thiểu</div>
    <p class="text-sm text-ink-muted">{mitigation}</p>
    {mitigationVi && <p class="text-sm text-ink-dim mt-1" lang="vi">{mitigationVi}</p>}
  </div>
</div>
