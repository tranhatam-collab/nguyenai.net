---
/**
 * RiskCard.astro — Risk with mitigation (single-locale).
 */
interface Props {
  risk: string;
  likelihood: 'Low' | 'Medium' | 'High';
  impact: 'Low' | 'Medium' | 'High';
  mitigation: string;
  locale?: 'vi' | 'en';
}
const { risk, likelihood, impact, mitigation, locale = 'vi' } = Astro.props;
const isVi = locale === 'vi';

const levelColor = (level: string) => {
  if (level === 'High') return 'text-red-400 bg-red-400/10 border-red-400/30';
  if (level === 'Medium') return 'text-gold bg-gold/10 border-gold/30';
  return 'text-green-400 bg-green-400/10 border-green-400/30';
};

const likelihoodLabel = isVi
  ? { Low: 'Thấp', Medium: 'Trung bình', High: 'Cao' }[likelihood]
  : likelihood;
const impactLabel = isVi
  ? { Low: 'Thấp', Medium: 'Trung bình', High: 'Cao' }[impact]
  : impact;
---

<div class="bg-bg-card border border-bg-border rounded-xl p-5 card-hover">
  <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
    <h3 class="text-base font-bold text-ink flex-1">{risk}</h3>
    <div class="flex gap-2 shrink-0">
      <span class={`text-xs px-2 py-1 rounded border ${levelColor(likelihood)}`}>
        {isVi ? 'X' : 'L'}: {likelihoodLabel}
      </span>
      <span class={`text-xs px-2 py-1 rounded border ${levelColor(impact)}`}>
        {isVi ? 'T' : 'I'}: {impactLabel}
      </span>
    </div>
  </div>
  <div class="mt-3 pt-3 border-t border-bg-border">
    <div class="text-xs font-semibold text-gold uppercase tracking-wide mb-1">
      {isVi ? 'Giảm thiểu' : 'Mitigation'}
    </div>
    <p class="text-sm text-ink-muted">{mitigation}</p>
  </div>
</div>
