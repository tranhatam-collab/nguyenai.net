---
/**
 * InvestLayout.astro — Professional investor-facing layout.
 * Dark theme with gold accents. Bilingual VI/EN.
 * Disclosure line required on every page.
 */
import '../styles/global.css';
import Disclosure from '../components/Disclosure.astro';

interface Props {
  title: string;
  titleVi?: string;
  description?: string;
  noindex?: boolean;
}
const { title, titleVi, description, noindex = false } = Astro.props;

const navLinks = [
  { href: '/why-now', label: 'Why Now', vi: 'Vì sao ngay bây giờ' },
  { href: '/ai-computer', label: 'AI Computer', vi: 'AI Computer' },
  { href: '/market', label: 'Market', vi: 'Thị trường' },
  { href: '/business-model', label: 'Business Model', vi: 'Mô hình' },
  { href: '/moat', label: 'Moat', vi: 'Lợi thế' },
  { href: '/roadmap', label: 'Roadmap', vi: 'Lộ trình' },
  { href: '/team', label: 'Team', vi: 'Đội ngũ' },
  { href: '/governance', label: 'Governance', vi: 'Quản trị' },
  { href: '/risks', label: 'Risks', vi: 'Rủi ro' },
  { href: '/impact', label: 'Impact', vi: 'Tác động' },
];

const fullTitle = titleVi ? `${title} — ${titleVi}` : title;
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{fullTitle} | invest.nguyenai.net</title>
  {description && <meta name="description" content={description} />}
  {noindex ? (
    <meta name="robots" content="noindex, nofollow, noarchive" />
  ) : (
    <meta name="robots" content="index, follow" />
  )}
  <link rel="canonical" href={`https://invest.nguyenai.net${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="vi" href={`https://invest.nguyenai.net${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="en" href={`https://invest.nguyenai.net/en${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="x-default" href={`https://invest.nguyenai.net${Astro.url.pathname}`} />
  <meta name="generator" content={Astro.generator} />
</head>
<body class="min-h-screen flex flex-col">
  <!-- Top nav -->
  <header class="sticky top-0 z-50 bg-bg/90 backdrop-blur-md border-b border-bg-border">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 shrink-0">
          <span class="text-2xl font-serif font-bold text-gold-gradient">N</span>
          <span class="hidden sm:inline text-sm font-semibold text-ink">Nguyen AI <span class="text-gold">Invest</span></span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden lg:flex items-center gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="px-3 py-2 text-sm text-ink-muted hover:text-gold transition-colors rounded-md"
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- CTA -->
        <div class="flex items-center gap-3">
          <a
            href="/request-access"
            class="px-4 py-2 text-sm font-semibold text-bg bg-gold hover:bg-gold-light rounded-lg transition-colors"
          >
            Request Access
          </a>
          <!-- Mobile menu toggle -->
          <button
            id="menu-toggle"
            class="lg:hidden text-ink-muted hover:text-gold p-2"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden lg:hidden pb-4">
        <div class="grid grid-cols-2 gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="px-3 py-2 text-sm text-ink-muted hover:text-gold transition-colors rounded-md"
            >
              {link.label}
              <span class="block text-xs text-ink-dim" lang="vi">{link.vi}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>
  </header>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-bg-border bg-bg-soft mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <!-- Disclosure line (required on every page) -->
      <div class="mb-6 p-4 bg-bg border border-bg-border rounded-lg">
        <Disclosure />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl font-serif font-bold text-gold-gradient">N</span>
            <span class="text-sm font-semibold text-ink">Nguyen AI <span class="text-gold">Invest</span></span>
          </div>
          <p class="text-sm text-ink-muted">
            Investor site for Nguyen AI Computer.
            <span class="block" lang="vi">Trang nhà đầu tư cho Nguyen AI Computer.</span>
          </p>
        </div>
        <div>
          <h4 class="text-xs font-semibold text-gold uppercase tracking-wide mb-3">Links / Liên kết</h4>
          <ul class="space-y-2">
            <li><a href="https://nguyenai.net" class="text-sm text-ink-muted hover:text-gold transition-colors">nguyenai.net — Main site</a></li>
            <li><a href="https://edu.nguyenai.net" class="text-sm text-ink-muted hover:text-gold transition-colors">edu.nguyenai.net — Academy</a></li>
            <li><a href="/request-access" class="text-sm text-ink-muted hover:text-gold transition-colors">Request investor access</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold text-gold uppercase tracking-wide mb-3">Legal / Pháp lý</h4>
          <ul class="space-y-2">
            <li><a href="/risks" class="text-sm text-ink-muted hover:text-gold transition-colors">Risk register / Rủi ro</a></li>
            <li><a href="/governance" class="text-sm text-ink-muted hover:text-gold transition-colors">Governance / Quản trị</a></li>
            <li><a href="/private/" class="text-sm text-ink-muted hover:text-gold transition-colors">Data room (qualified investors)</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-bg-border text-center">
        <p class="text-xs text-ink-dim">
          © {new Date().getFullYear()} Nguyen AI Computer. invest.nguyenai.net.
          <span class="block mt-1" lang="vi">Mọi quyền được bảo lưu. Trang nhà đầu tư.</span>
        </p>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
