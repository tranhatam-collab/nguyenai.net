---
/**
 * InvestLayout.astro — Professional investor-facing layout.
 * Dark theme with gold accents. Bilingual VI/EN.
 * Disclosure line required on every page.
 */
import '../styles/global.css';
import Disclosure from '../components/Disclosure.astro';

interface Props {
  title: string;
  titleVi?: string;
  description?: string;
  noindex?: boolean;
  locale?: 'vi' | 'en';
}
const { title, titleVi, description, noindex = false, locale = 'vi' } = Astro.props;
const isEn = locale === 'en';

const navLinks = [
  { href: isEn ? '/en/why-now' : '/why-now', label: 'Why Now', vi: 'Vì sao ngay bây giờ' },
  { href: isEn ? '/en/ai-computer' : '/ai-computer', label: 'AI Computer', vi: 'AI Computer' },
  { href: isEn ? '/en/market' : '/market', label: 'Market', vi: 'Thị trường' },
  { href: isEn ? '/en/business-model' : '/business-model', label: 'Business Model', vi: 'Mô hình' },
  { href: isEn ? '/en/moat' : '/moat', label: 'Moat', vi: 'Lợi thế' },
  { href: isEn ? '/en/roadmap' : '/roadmap', label: 'Roadmap', vi: 'Lộ trình' },
  { href: isEn ? '/en/team' : '/team', label: 'Team', vi: 'Đội ngũ' },
  { href: isEn ? '/en/governance' : '/governance', label: 'Governance', vi: 'Quản trị' },
  { href: isEn ? '/en/risks' : '/risks', label: 'Risks', vi: 'Rủi ro' },
  { href: isEn ? '/en/impact' : '/impact', label: 'Impact', vi: 'Tác động' },
  { href: '/scholarship', label: 'Scholarship', vi: 'Học bổng' },
];

const fullTitle = titleVi ? `${title} — ${titleVi}` : title;
const SITE = 'https://invest.nguyenai.net';
// INVEST-P0-1: robust VI/EN path computation (no /en/en/* double prefix).
const pathname = Astro.url.pathname;
const viPath = isEn ? pathname.replace(/^\/en\/?/, '/') : pathname;
const enPath = isEn ? pathname : `/en${pathname === '/' ? '/' : pathname}`;
const canonicalPath = isEn ? pathname : viPath;
const ogImage = isEn ? `${SITE}/og-invest.png` : `${SITE}/og-invest.png`;
---

<!doctype html>
<html lang={isEn ? 'en' : 'vi'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Noto+Serif:ital,wght@0,400;0,700;1,400&display=swap" />
  <meta name="theme-color" content="#7A2212" />
  <title>{fullTitle} | invest.nguyenai.net</title>
  {description && <meta name="description" content={description} />}
  {noindex ? (
    <meta name="robots" content="noindex, nofollow, noarchive" />
  ) : (
    <meta name="robots" content="index, follow" />
  )}
  <link rel="canonical" href={`${SITE}${canonicalPath}`} />
  <link rel="alternate" hreflang="vi" href={`${SITE}${viPath}`} />
  <link rel="alternate" hreflang="en" href={`${SITE}${enPath}`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE}${viPath}`} />
  <meta name="generator" content={Astro.generator} />
  <!-- INVEST-P0-1: Open Graph + Twitter Card (previously missing entirely) -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Nguyen AI Invest" />
  <meta property="og:title" content={fullTitle} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={`${SITE}${canonicalPath}`} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content={isEn ? 'en_US' : 'vi_VN'} />
  <meta property="og:locale:alternate" content={isEn ? 'vi_VN' : 'en_US'} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImage} />
</head>
<body class="min-h-screen flex flex-col">
  <!-- Skip to content link (WCAG 2.4.1) -->
  <a href="#main-content" class="skip-link">{isEn ? 'Skip to content' : 'Bỏ qua đến nội dung'}</a>
  <!-- Top nav — V3.0 brand: heritage-dark background, white text, gold accents -->
  <header class="sticky top-0 z-50 bg-bg/96 border-b border-white/12" style="backdrop-filter: blur(16px);">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo — Arch of Light (monochrome white for dark header) -->
        <a href={isEn ? '/en' : '/'} class="flex items-center gap-2 shrink-0 no-underline">
          <img src="/logo-mark-mono-white.svg" alt="" width="32" height="32" />
          <span class="hidden sm:inline text-sm font-semibold text-white">Nguyen AI <span class="text-gold">Invest</span></span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden lg:flex items-center gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="px-3 py-2 text-sm text-white/82 hover:text-gold transition-colors rounded-md no-underline"
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- CTA + Language switcher -->
        <div class="flex items-center gap-3">
          <!-- Language switcher -->
          {(() => {
            const path = Astro.url.pathname;
            const switchHref = isEn ? path.replace('/en', '') || '/' : '/en' + path;
            return <a href={switchHref} class="px-3 py-1.5 text-sm font-medium text-white/82 hover:text-gold transition-colors rounded-md no-underline">{isEn ? 'Tiếng Việt' : 'English'}</a>;
          })()}
          <a
            href="/request-access"
            class="px-4 py-2 text-sm font-semibold text-ink bg-gold hover:bg-gold-light rounded-lg transition-colors no-underline"
          >
            Request Access
          </a>
          <!-- Mobile menu toggle -->
          <button
            id="menu-toggle"
            class="lg:hidden text-white/82 hover:text-gold p-2"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden lg:hidden pb-4">
        <div class="grid grid-cols-2 gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="px-3 py-2 text-sm text-white/82 hover:text-gold transition-colors rounded-md no-underline"
            >
              {link.label}
              <span class="block text-xs text-white/50" lang="vi">{link.vi}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>
  </header>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer — V3.0 brand: heritage-dark background, white text, gold accents -->
  <footer class="border-t border-white/12 bg-bg-soft mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <!-- Disclosure line (required on every page) -->
      <div class="mb-6 p-4 bg-bg border border-white/12 rounded-lg">
        <Disclosure />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <img src="/logo-mark-mono-white.svg" alt="" width="28" height="28" />
            <span class="text-sm font-semibold text-white">Nguyen AI <span class="text-gold">Invest</span></span>
          </div>
          <p class="text-sm text-white/70">
            Investor site for Nguyen AI Computer.
            <span class="block" lang="vi">Trang nhà đầu tư cho Nguyen AI Computer.</span>
          </p>
        </div>
        <div>
          <h4 class="text-xs font-semibold text-gold uppercase tracking-wide mb-3">Links / Liên kết</h4>
          <ul class="space-y-2">
            <li><a href="https://nguyenai.net" class="text-sm text-white/78 hover:text-gold transition-colors no-underline">nguyenai.net — Main site</a></li>
            <li><a href="https://edu.nguyenai.net" class="text-sm text-white/78 hover:text-gold transition-colors no-underline">edu.nguyenai.net — Academy</a></li>
            <li><a href="/request-access" class="text-sm text-white/78 hover:text-gold transition-colors no-underline">Request investor access</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold text-gold uppercase tracking-wide mb-3">Legal / Pháp lý</h4>
          <ul class="space-y-2">
            <li><a href="/risks" class="text-sm text-white/78 hover:text-gold transition-colors no-underline">Sổ rủi ro</a></li>
            <li><a href="/governance" class="text-sm text-white/78 hover:text-gold transition-colors no-underline">Governance / Quản trị</a></li>
            <li><a href="/private/" class="text-sm text-white/78 hover:text-gold transition-colors no-underline">Data room (qualified investors)</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-bg-border text-center">
        <p class="text-xs text-ink-dim">
          © {new Date().getFullYear()} Nguyen AI Computer. invest.nguyenai.net.
          <span class="block mt-1" lang="vi">Mọi quyền được bảo lưu. Trang nhà đầu tư.</span>
        </p>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
