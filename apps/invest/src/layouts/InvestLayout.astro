---
/**
 * InvestLayout.astro — Investor-facing layout.
 * Single-locale UI: VI routes show Vietnamese only; EN routes show English only.
 */
import '../styles/global.css';
import Disclosure from '../components/Disclosure.astro';

interface Props {
  title: string;
  titleVi?: string;
  description?: string;
  noindex?: boolean;
  locale?: 'vi' | 'en';
}
const { title, titleVi, description, noindex = false, locale = 'vi' } = Astro.props;
const isEn = locale === 'en';

const navLinks = isEn
  ? [
      { href: '/en/why-now', label: 'Why Now' },
      { href: '/en/ai-computer', label: 'AI Computer' },
      { href: '/en/market', label: 'Market' },
      { href: '/en/business-model', label: 'Business Model' },
      { href: '/en/moat', label: 'Moat' },
      { href: '/en/roadmap', label: 'Roadmap' },
      { href: '/en/team', label: 'Team' },
      { href: '/en/governance', label: 'Governance' },
      { href: '/en/risks', label: 'Risks' },
      { href: '/en/impact', label: 'Impact' },
      { href: '/scholarship', label: 'Scholarship' },
    ]
  : [
      { href: '/why-now', label: 'Vì sao ngay bây giờ' },
      { href: '/ai-computer', label: 'Máy Tính AI' },
      { href: '/market', label: 'Thị trường' },
      { href: '/business-model', label: 'Mô hình' },
      { href: '/moat', label: 'Lợi thế' },
      { href: '/roadmap', label: 'Lộ trình' },
      { href: '/team', label: 'Đội ngũ' },
      { href: '/governance', label: 'Quản trị' },
      { href: '/risks', label: 'Rủi ro' },
      { href: '/impact', label: 'Tác động' },
      { href: '/scholarship', label: 'Học bổng' },
    ];

// Single-locale title: VI uses titleVi when provided, else title; EN uses title only
const fullTitle = isEn ? title : (titleVi ?? title);
const SITE = 'https://invest.nguyenai.net';
const pathname = Astro.url.pathname;
const viPath = isEn ? pathname.replace(/^\/en\/?/, '/') : pathname;
const enPath = isEn ? pathname : `/en${pathname === '/' ? '/' : pathname}`;
const canonicalPath = isEn ? pathname : viPath;
const ogImage = `${SITE}/og-invest.png`;

const t = {
  skip: isEn ? 'Skip to content' : 'Bỏ qua đến nội dung',
  nav: isEn ? 'Main navigation' : 'Điều hướng chính',
  switchLabel: isEn ? 'Tiếng Việt' : 'English',
  cta: isEn ? 'Request Access' : 'Yêu cầu truy cập',
  menu: isEn ? 'Toggle menu' : 'Mở menu',
  blurb: isEn
    ? 'Investor site for Nguyen AI Computer.'
    : 'Trang nhà đầu tư cho Máy Tính AI Nguyễn.',
  links: isEn ? 'Links' : 'Liên kết',
  legal: isEn ? 'Legal' : 'Pháp lý',
  mainSite: isEn ? 'nguyenai.net — Main site' : 'nguyenai.net — Trang chính',
  academy: isEn ? 'edu.nguyenai.net — Academy' : 'edu.nguyenai.net — Academy',
  requestAccess: isEn ? 'Request investor access' : 'Yêu cầu quyền nhà đầu tư',
  risks: isEn ? 'Risks' : 'Sổ rủi ro',
  governance: isEn ? 'Governance' : 'Quản trị',
  dataRoom: isEn ? 'Data room (qualified investors)' : 'Data room (nhà đầu tư đủ điều kiện)',
  copyright: isEn
    ? `© ${new Date().getFullYear()} Nguyen AI Computer. invest.nguyenai.net.`
    : `© ${new Date().getFullYear()} Máy Tính AI Nguyễn. invest.nguyenai.net. Mọi quyền được bảo lưu.`,
};
---

<!doctype html>
<html lang={isEn ? 'en' : 'vi'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Noto+Serif:ital,wght@0,400;0,700;1,400&display=swap" />
  <meta name="theme-color" content="#7A2212" />
  <title>{fullTitle} | invest.nguyenai.net</title>
  {description && <meta name="description" content={description} />}
  {noindex ? (
    <meta name="robots" content="noindex, nofollow, noarchive" />
  ) : (
    <meta name="robots" content="index, follow" />
  )}
  <link rel="canonical" href={`${SITE}${canonicalPath}`} />
  <link rel="alternate" hreflang="vi" href={`${SITE}${viPath}`} />
  <link rel="alternate" hreflang="en" href={`${SITE}${enPath}`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE}${viPath}`} />
  <meta name="generator" content={Astro.generator} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Nguyen AI Invest" />
  <meta property="og:title" content={fullTitle} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={`${SITE}${canonicalPath}`} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content={isEn ? 'en_US' : 'vi_VN'} />
  <meta property="og:locale:alternate" content={isEn ? 'vi_VN' : 'en_US'} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImage} />
</head>
<body class="min-h-screen flex flex-col">
  <a href="#main-content" class="skip-link">{t.skip}</a>
  <header class="invest-header sticky top-0 z-50 border-b border-white/20">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label={t.nav}>
      <div class="flex items-center justify-between gap-2 h-16">
        <a href={isEn ? '/en' : '/'} class="flex items-center gap-2 shrink-0 no-underline text-white">
          <img src="/logo-mark-mono-white.svg" alt="" width="32" height="32" />
          <span class="hidden sm:inline text-sm font-semibold text-white">Nguyen AI <span class="text-gold">Invest</span></span>
        </a>

        <div class="hidden lg:flex items-center gap-1 flex-1 justify-center min-w-0">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="px-2 xl:px-3 py-2 text-sm text-white hover:text-gold transition-colors rounded-md no-underline whitespace-nowrap"
            >
              {link.label}
            </a>
          ))}
        </div>

        <div class="flex items-center gap-2 sm:gap-3 shrink-0">
          <a
            href={isEn ? (viPath || '/') : enPath}
            class="hidden sm:inline-flex px-3 py-1.5 text-sm font-medium text-white hover:text-gold transition-colors rounded-md no-underline"
          >{t.switchLabel}</a>
          <a
            href={isEn ? '/en/request-access' : '/request-access'}
            class="px-3 sm:px-4 py-2 text-sm font-semibold text-ink bg-gold hover:bg-gold-light rounded-lg transition-colors no-underline whitespace-nowrap"
          >
            {t.cta}
          </a>
          <button
            type="button"
            id="menu-toggle"
            class="invest-mobile-toggle lg:hidden"
            aria-label={t.menu}
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <div id="mobile-menu" class="invest-mobile-panel hidden lg:hidden pb-4 pt-2">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="px-3 py-3 text-sm text-white hover:text-gold hover:bg-white/10 transition-colors rounded-md no-underline"
            >
              {link.label}
            </a>
          ))}
          <a
            href={isEn ? (viPath || '/') : enPath}
            class="sm:hidden px-3 py-3 text-sm text-white hover:text-gold hover:bg-white/10 transition-colors rounded-md no-underline"
          >{t.switchLabel}</a>
        </div>
      </div>
    </nav>
  </header>

  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <footer class="border-t border-white/20 bg-bg-soft mt-16 text-light-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="mb-6 p-4 bg-bg border border-white/20 rounded-lg">
        <Disclosure locale={isEn ? 'en' : 'vi'} />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <img src="/logo-mark-mono-white.svg" alt="" width="28" height="28" />
            <span class="text-sm font-semibold text-white">Nguyen AI <span class="text-gold">Invest</span></span>
          </div>
          <p class="text-sm text-white/80">{t.blurb}</p>
        </div>
        <div>
          <h4 class="text-xs font-semibold text-gold uppercase tracking-wide mb-3">{t.links}</h4>
          <ul class="space-y-2">
            <li><a href="https://nguyenai.net" class="text-sm text-white/90 hover:text-gold transition-colors no-underline">{t.mainSite}</a></li>
            <li><a href="https://edu.nguyenai.net" class="text-sm text-white/90 hover:text-gold transition-colors no-underline">{t.academy}</a></li>
            <li><a href={isEn ? '/en/request-access' : '/request-access'} class="text-sm text-white/90 hover:text-gold transition-colors no-underline">{t.requestAccess}</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold text-gold uppercase tracking-wide mb-3">{t.legal}</h4>
          <ul class="space-y-2">
            <li><a href={isEn ? '/en/risks' : '/risks'} class="text-sm text-white/90 hover:text-gold transition-colors no-underline">{t.risks}</a></li>
            <li><a href={isEn ? '/en/governance' : '/governance'} class="text-sm text-white/90 hover:text-gold transition-colors no-underline">{t.governance}</a></li>
            <li><a href="/private/" class="text-sm text-white/90 hover:text-gold transition-colors no-underline">{t.dataRoom}</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-white/20 text-center">
        <p class="text-xs text-white/70">{t.copyright}</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        const open = menu.classList.toggle('hidden') === false;
        toggle.setAttribute('aria-expanded', String(open));
      });
    }
  </script>
</body>
</html>
