---
/**
 * Sidebar.astro — Navigation sidebar for the console
 * Sections: Dashboard, Command Center, Agent Team, Super Apps,
 *           Model Mesh, Data Vault, Memory, Settings
 */

const navItems = [
  { href: '/dashboard', label: 'Dashboard', labelVi: 'Bảng điều khiển', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { href: '/command-center', label: 'Command Center', labelVi: 'Trung tâm chỉ huy', icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { href: '/agents', label: 'Agent Team', labelVi: 'Đội ngũ Agent', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
  { href: '/super-apps', label: 'Super Apps', labelVi: 'Super Apps', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
  { href: '/models', label: 'Model Mesh', labelVi: 'Model Mesh', icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10' },
  { href: '/data-vault', label: 'Data Vault', labelVi: 'Kho dữ liệu', icon: 'M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4' },
  { href: '/memory', label: 'Memory', labelVi: 'Bộ nhớ', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
  { href: '/settings', label: 'Settings', labelVi: 'Cài đặt', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z' },
];

const currentPath = Astro.url.pathname;
---

<!-- Mobile overlay -->
<div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/60 lg:hidden"></div>

<!-- Sidebar -->
<aside
  id="console-sidebar"
  class="fixed left-0 top-0 z-40 flex h-screen w-64 flex-col border-r border-slate-800 bg-bg-sidebar transition-transform duration-300 lg:translate-x-0 -translate-x-full"
>
  <!-- Logo -->
  <div class="flex h-16 items-center gap-3 border-b border-slate-800 px-6">
    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent font-bold text-white">N</div>
    <div>
      <div class="text-sm font-bold text-slate-100">Nguyen AI</div>
      <div class="text-xs text-slate-500">Computer Console</div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto px-3 py-4">
    <ul class="space-y-1">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
        return (
          <li>
            <a
              href={item.href}
              class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors ${
                isActive
                  ? 'bg-accent/15 text-accent font-medium'
                  : 'text-slate-400 hover:bg-bg-hover hover:text-slate-200'
              }`}
            >
              <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
              <span class="flex-1">{item.label}</span>
            </a>
            {isActive && (
              <div class="ml-9 mt-0.5 text-xs text-slate-500">{item.labelVi}</div>
            )}
          </li>
        );
      })}
    </ul>
  </nav>

  <!-- Footer -->
  <div class="border-t border-slate-800 p-4">
    <div class="rounded-lg bg-bg-card p-3 text-xs text-slate-400">
      <div class="font-medium text-slate-300">Instance · Phiên bản</div>
      <div class="mt-1">v0.1.0 — Console Preview</div>
    </div>
  </div>
</aside>

<script>
  // Mobile sidebar toggle
  const sidebar = document.getElementById('console-sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  const toggle = document.getElementById('sidebar-toggle');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    overlay?.classList.remove('hidden');
  }

  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    overlay?.classList.add('hidden');
  }

  toggle?.addEventListener('click', openSidebar);
  overlay?.addEventListener('click', closeSidebar);
</script>
