---
/**
 * TopBar.astro — Top bar with user info, plan badge, language switch
 */
---

<header class="sticky top-0 z-20 flex h-16 items-center justify-between border-b border-slate-800 bg-bg/80 px-4 backdrop-blur-sm lg:px-6">
  <!-- Left: mobile menu + breadcrumb -->
  <div class="flex items-center gap-3">
    <button
      id="sidebar-toggle"
      class="rounded-lg p-2 text-slate-400 hover:bg-bg-hover hover:text-slate-200 lg:hidden"
      aria-label="Toggle sidebar · Mở menu"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
    <div class="hidden text-sm text-slate-500 sm:block">
      <span>Bảng điều khiển</span>
      <span class="mx-2">/</span>
      <span class="text-slate-300">Trang chính</span>
    </div>
  </div>

  <!-- Right: language switch, plan badge, user avatar -->
  <div class="flex items-center gap-3">
    <!-- Language switch VI/EN -->
    <div class="flex items-center rounded-lg border border-slate-700 bg-bg-card text-xs">
      <button class="rounded-l-lg px-2.5 py-1.5 font-medium text-accent bg-accent/10">VI</button>
      <button class="rounded-r-lg px-2.5 py-1.5 font-medium text-slate-400 hover:text-slate-200">EN</button>
    </div>

    <!-- Plan badge -->
    <div class="hidden items-center gap-2 rounded-lg border border-accent/30 bg-accent/10 px-3 py-1.5 text-xs font-medium text-accent sm:flex">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
      </svg>
      <span>Gói Founder</span>
    </div>

    <!-- User avatar -->
    <div class="flex items-center gap-2">
      <div class="flex h-8 w-8 items-center justify-center rounded-full bg-accent/20 text-sm font-semibold text-accent">
        U
      </div>
      <span class="hidden text-sm font-medium text-slate-200 md:block">Người dùng</span>
    </div>
  </div>
</header>
