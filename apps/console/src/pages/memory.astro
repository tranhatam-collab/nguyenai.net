---
export const prerender = false;
/**
 * memory.astro — Memory timeline, search bar. Loads from /v1/memory (real API).
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import MemoryPanel from '../components/react/MemoryPanel.tsx';
---

<ConsoleLayout title="Bộ nhớ · Nguyễn AI">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Bộ nhớ</h1>
    <p class="text-sm text-slate-400">Bộ nhớ Máy Tính AI — 6 loại (phiên, sở thích, dự án, quyết định, gia đình, founder)</p>
  </div>

  <!-- Memory panel (React island — loads from /v1/memory) -->
  <MemoryPanel client:load />
</ConsoleLayout>
