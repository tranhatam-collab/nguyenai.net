---
export const prerender = false;
/**
 * memory.astro — Memory timeline, search bar. Loads from /v1/memory (real API).
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import MemoryPanel from '../components/react/MemoryPanel.tsx';
---

<ConsoleLayout title="Memory · Nguyen AI Console">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Memory</h1>
    <p class="text-sm text-slate-400">Bộ nhớ · AI Computer memory — 6 types (session, preference, project, decision, family, founder)</p>
  </div>

  <!-- Memory panel (React island — loads from /v1/memory) -->
  <MemoryPanel client:load />
</ConsoleLayout>
