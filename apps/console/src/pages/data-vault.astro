---
export const prerender = false;
/**
 * data-vault.astro — Vault file list, upload area, privacy controls
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
---

<ConsoleLayout title="Kho dữ liệu · Nguyễn AI">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Kho dữ liệu</h1>
    <p class="text-sm text-slate-400">Lưu trữ riêng tư cho Máy Tính AI của bạn</p>
  </div>

  <!-- Upload area -->
  <div class="console-card mb-6">
    <h2 class="console-section-title mb-1">Tải lên</h2>
    <p class="console-section-subtitle mb-4">Kéo thả tệp hoặc bấm để chọn</p>
    <div class="rounded-lg border-2 border-dashed border-slate-700 p-12 text-center transition-colors hover:border-accent">
      <svg class="mx-auto mb-3 h-12 w-12 text-slate-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
      </svg>
      <p class="text-sm text-slate-400">Kéo tệp vào đây</p>
      <p class="mt-1 text-xs text-slate-500">Tất cả tệp được mã hóa khi lưu trữ</p>
      <button class="console-btn console-btn-secondary mt-4" aria-label="Chọn tệp">Chọn tệp</button>
    </div>
  </div>

  <!-- Two column: File list + Privacy controls -->
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <!-- File list -->
    <div class="console-card lg:col-span-2">
      <div class="mb-4 flex items-center justify-between">
        <div>
          <h2 class="console-section-title">Tệp tin</h2>
          <p class="console-section-subtitle">0 tệp đã lưu</p>
        </div>
        <input id="file-search" type="text" class="console-input max-w-xs text-sm" placeholder="Tìm tệp..." />
      </div>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-800 text-left text-xs text-slate-500">
            <th class="pb-3 font-medium">Tên</th>
            <th class="pb-3 font-medium">Dung lượng</th>
            <th class="pb-3 font-medium">Ngày tải</th>
            <th class="pb-3 font-medium">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td colspan="4" class="py-8 text-center text-slate-500">
              Kho dữ liệu trống
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Privacy controls -->
    <div class="console-card">
      <h2 class="console-section-title mb-1">Kiểm soát quyền riêng tư</h2>
      <p class="console-section-subtitle mb-4">Quản lý quyền truy cập dữ liệu</p>
      <div class="space-y-4">
        <div>
          <label class="flex items-center justify-between">
            <span class="text-sm text-slate-300">Mã hóa dữ liệu lưu trữ</span>
            <input type="checkbox" checked class="rounded border-slate-600 bg-bg-card text-accent focus:ring-accent" aria-label="Mã hóa dữ liệu lưu trữ" />
          </label>
        </div>
        <div>
          <label class="flex items-center justify-between">
            <span class="text-sm text-slate-300">Cho phép Agent truy cập</span>
            <input type="checkbox" class="rounded border-slate-600 bg-bg-card text-accent focus:ring-accent" aria-label="Cho phép Agent truy cập" />
          </label>
        </div>
        <div>
          <label class="flex items-center justify-between">
            <span class="text-sm text-slate-300">Tự xóa sau 30 ngày</span>
            <input type="checkbox" class="rounded border-slate-600 bg-bg-card text-accent focus:ring-accent" aria-label="Tự xóa sau 30 ngày" />
          </label>
        </div>
        <div>
          <label class="flex items-center justify-between">
            <span class="text-sm text-slate-300">Chia sẻ với mạng lưới Nguyễn</span>
            <input type="checkbox" class="rounded border-slate-600 bg-bg-card text-accent focus:ring-accent" aria-label="Chia sẻ với mạng lưới Nguyễn" />
          </label>
        </div>
      </div>
    </div>
  </div>
</ConsoleLayout>
