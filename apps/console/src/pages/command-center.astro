---
export const prerender = false;
/**
 * command-center.astro — Command input, run history, status indicators
 * Interactive React islands for command input and history.
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import StatusBadge from '../components/StatusBadge.astro';
import CommandInput from '../components/react/CommandInput.tsx';
import CommandHistory from '../components/react/CommandHistory.tsx';
---

<ConsoleLayout title="Trung tâm chỉ huy · Nguyễn AI">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Trung tâm chỉ huy</h1>
    <p class="text-sm text-slate-400">Ra lệnh cho Máy Tính AI của bạn</p>
  </div>

  <!-- Command input (React island) -->
  <CommandInput client:load />

  <!-- Status indicators -->
  <div class="mb-6 grid grid-cols-2 gap-4 lg:grid-cols-4">
    <div class="console-card flex items-center gap-3">
      <StatusBadge status="idle" />
      <div>
        <p class="text-xs text-slate-400">Hàng đợi</p>
        <p class="text-sm font-medium text-slate-200">0 đang chờ</p>
      </div>
    </div>
    <div class="console-card flex items-center gap-3">
      <StatusBadge status="active" />
      <div>
        <p class="text-xs text-slate-400">Đang xử lý</p>
        <p class="text-sm font-medium text-slate-200">0 đang chạy</p>
      </div>
    </div>
    <div class="console-card flex items-center gap-3">
      <StatusBadge status="offline" />
      <div>
        <p class="text-xs text-slate-400">Hoàn thành</p>
        <p class="text-sm font-medium text-slate-200">0 xong</p>
      </div>
    </div>
    <div class="console-card flex items-center gap-3">
      <StatusBadge status="offline" />
      <div>
        <p class="text-xs text-slate-400">Lỗi</p>
        <p class="text-sm font-medium text-slate-200">0 lỗi</p>
      </div>
    </div>
  </div>

  <!-- Run history (React island) -->
  <CommandHistory client:load />
</ConsoleLayout>
