---
export const prerender = false;
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
---

<ConsoleLayout locale="vi" routeKey="dashboard" title="404 — Không tìm thấy trang / Page Not Found" description="Trang bạn tìm không tồn tại.">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="text-6xl font-bold text-accent mb-4">404</div>
    <h1 class="text-2xl font-semibold mb-2">Không tìm thấy trang</h1>
    <p class="text-gray-400 mb-2">Page not found</p>
    <p class="text-gray-500 mb-8">Trang bạn tìm không tồn tại hoặc đã được di chuyển.<br />The page you're looking for doesn't exist or has been moved.</p>
    <a href="/dashboard" class="console-btn">← Về Dashboard / Back to Dashboard</a>
  </div>
</ConsoleLayout>
