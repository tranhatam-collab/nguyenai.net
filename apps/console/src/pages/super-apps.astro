---
export const prerender = false;
/**
 * super-apps.astro — Super App launcher grid
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import SuperAppCard from '../components/SuperAppCard.astro';

const superApps = [
  { name: 'AI Office', icon: '🏢', description: 'Bộ công cụ văn phòng' },
  { name: 'AI Research', icon: '🔬', description: 'Công cụ nghiên cứu' },
  { name: 'AI Browser', icon: '🌐', description: 'Duyệt web thông minh' },
  { name: 'AI Content', icon: '✍️', description: 'Sáng tạo nội dung' },
  { name: 'AI Media', icon: '🎬', description: 'Sản xuất media' },
  { name: 'AI Code', icon: '💻', description: 'Trợ lý lập trình' },
  { name: 'AI Automation', icon: '⚙️', description: 'Tự động hóa quy trình' },
  { name: 'AI Founder OS', icon: '🚀', description: 'Hệ điều hành Founder' },
  { name: 'AI Business OS', icon: '📊', description: 'Vận hành doanh nghiệp' },
  { name: 'Nguyen Roots', icon: '🌳', description: 'Cội nguồn gia đình' },
  { name: 'Nguyen Memory', icon: '🧠', description: 'Kho bộ nhớ' },
  { name: 'Nguyen Knowledge', icon: '📚', description: 'Cơ sở tri thức' },
  { name: 'Nguyen Trust', icon: '🛡️', description: 'Xác minh tin cậy' },
  { name: 'Nguyen Network', icon: '🔗', description: 'Mạng lưới cộng đồng' },
  { name: 'Nguyen Founders', icon: '👑', description: 'Cộng đồng Founder' },
  { name: 'Nguyen Chapter OS', icon: '📖', description: 'Quản lý Chapter' },
];
---

<ConsoleLayout title="Siêu ứng dụng · Nguyễn AI">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Siêu ứng dụng</h1>
    <p class="text-sm text-slate-400">Khởi động các ứng dụng AI chuyên biệt</p>
  </div>

  <!-- Super App grid -->
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
    {superApps.map((app) => (
      <SuperAppCard name={app.name} icon={app.icon} description={app.description} />
    ))}
  </div>
</ConsoleLayout>
