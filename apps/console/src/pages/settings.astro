---
export const prerender = false;
/**
 * settings.astro — Profile, plan, billing, API keys, security
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';

const sections = [
  { id: 'profile', label: 'Hồ sơ' },
  { id: 'plan', label: 'Gói dịch vụ' },
  { id: 'billing', label: 'Thanh toán' },
  { id: 'api-keys', label: 'Khóa API' },
  { id: 'security', label: 'Bảo mật' },
];
---

<ConsoleLayout title="Cài đặt · Nguyễn AI">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Cài đặt</h1>
    <p class="text-sm text-slate-400">Quản lý tài khoản và tùy chọn</p>
  </div>

  <!-- Section navigation -->
  <div class="mb-6 flex flex-wrap gap-2">
    {sections.map((section) => (
      <a href={`#${section.id}`} class="console-btn console-btn-secondary text-xs">
        {section.label}
      </a>
    ))}
  </div>

  <div class="space-y-6">
    <!-- Profile -->
    <div class="console-card" id="profile">
      <h2 class="console-section-title mb-1">Hồ sơ</h2>
      <p class="console-section-subtitle mb-4">Thông tin tài khoản</p>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <label class="console-label" for="full-name">Họ tên</label>
          <input id="full-name" type="text" class="console-input" placeholder="Tên của bạn" />
        </div>
        <div>
          <label class="console-label" for="email">Email</label>
          <input id="email" type="email" class="console-input" placeholder="you@example.com" />
        </div>
        <div>
          <label class="console-label" for="display-name">Tên hiển thị</label>
          <input id="display-name" type="text" class="console-input" placeholder="Tên hiển thị" />
        </div>
        <div>
          <label class="console-label">Ngôn ngữ</label>
          <select class="console-input">
            <option>Tiếng Việt</option>
            <option>Tiếng Anh</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Plan -->
    <div class="console-card" id="plan">
      <h2 class="console-section-title mb-1">Gói dịch vụ</h2>
      <p class="console-section-subtitle mb-4">Gói đăng ký hiện tại</p>
      <div class="flex items-center justify-between rounded-lg border border-accent/30 bg-accent/10 p-4">
        <div>
          <p class="font-semibold text-accent">Gói Founder</p>
          <p class="text-xs text-slate-400">Gói hiện tại</p>
        </div>
        <button class="console-btn console-btn-primary">Nâng cấp</button>
      </div>
    </div>

    <!-- Billing -->
    <div class="console-card" id="billing">
      <h2 class="console-section-title mb-1">Thanh toán</h2>
      <p class="console-section-subtitle mb-4">Phương thức thanh toán và hóa đơn</p>
      <div class="rounded-lg border border-dashed border-slate-700 p-6 text-center">
        <p class="text-sm text-slate-400">Chưa có phương thức thanh toán</p>
        <button class="console-btn console-btn-primary mt-4">Thêm phương thức thanh toán</button>
      </div>
    </div>

    <!-- API Keys -->
    <div class="console-card" id="api-keys">
      <h2 class="console-section-title mb-1">Khóa API</h2>
      <p class="console-section-subtitle mb-4">Quản lý thông tin xác thực API</p>
      <div class="rounded-lg border border-dashed border-slate-700 p-6 text-center">
        <p class="text-sm text-slate-400">Chưa có khóa API nào</p>
        <button class="console-btn console-btn-primary mt-4">Tạo khóa</button>
      </div>
    </div>

    <!-- Security -->
    <div class="console-card" id="security">
      <h2 class="console-section-title mb-1">Bảo mật</h2>
      <p class="console-section-subtitle mb-4">Cài đặt bảo mật tài khoản</p>
      <div class="space-y-4">
        <div class="flex items-center justify-between rounded-lg border border-slate-800 bg-bg-card/50 p-4">
          <div>
            <p class="text-sm font-medium text-slate-200">Xác thực hai yếu tố</p>
          </div>
          <button class="console-btn console-btn-secondary text-xs">Bật</button>
        </div>
        <div class="flex items-center justify-between rounded-lg border border-slate-800 bg-bg-card/50 p-4">
          <div>
            <p class="text-sm font-medium text-slate-200">Đổi mật khẩu</p>
          </div>
          <button class="console-btn console-btn-secondary text-xs">Đổi</button>
        </div>
        <div class="flex items-center justify-between rounded-lg border border-slate-800 bg-bg-card/50 p-4">
          <div>
            <p class="text-sm font-medium text-slate-200">Phiên đăng nhập hoạt động</p>
          </div>
          <button class="console-btn console-btn-secondary text-xs">Xem</button>
        </div>
      </div>
    </div>
  </div>
</ConsoleLayout>
