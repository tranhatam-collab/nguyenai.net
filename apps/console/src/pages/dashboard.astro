---
export const prerender = false;
/**
 * dashboard.astro — Overview: Instance status, active agents, spend, commands, actions
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import StatusBadge from '../components/StatusBadge.astro';

const stats = [
  { label: 'Trạng thái phiên bản', value: 'Đang chạy', status: 'active' as const },
  { label: 'Agent hoạt động', value: '—', status: 'idle' as const },
  { label: 'Chi phí tháng', value: '—', status: 'offline' as const },
  { label: 'Lệnh hôm nay', value: '—', status: 'offline' as const },
];

const quickActions = [
  { label: 'Lệnh mới', href: '/command-center', icon: 'M12 4v16m8-8H4' },
  { label: 'Khởi động ứng dụng', href: '/super-apps', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  { label: 'Quản lý Agent', href: '/agents', icon: 'M12 4.354a4 4 0 110 5.292M15 8H3m15.333 4H7.667M19 12a2 2 0 11-4 0 2 2 0 014 0z' },
  { label: 'Tải lên kho', href: '/data-vault', icon: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12' },
];
---

<ConsoleLayout title="Bảng điều khiển · Nguyễn AI">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Bảng điều khiển</h1>
    <p class="text-sm text-slate-400">Tổng quan phiên bản Máy Tính AI</p>
  </div>

  <!-- Stats grid -->
  <div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {stats.map((stat) => (
      <div class="console-card">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs text-slate-400">{stat.label}</p>
          </div>
          {stat.status !== 'offline' && <StatusBadge status={stat.status} />}
        </div>
        <p class="mt-3 text-2xl font-bold text-slate-100">{stat.value}</p>
      </div>
    ))}
  </div>

  <!-- Quick actions -->
  <div class="mb-6">
    <h2 class="console-section-title mb-3">Thao tác nhanh</h2>
    <div class="grid grid-cols-2 gap-3 lg:grid-cols-4">
      {quickActions.map((action) => (
        <a href={action.href} class="console-card group flex flex-col items-center gap-2 text-center">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent transition-colors group-hover:bg-accent/20">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={action.icon} />
            </svg>
          </div>
          <span class="text-sm font-medium text-slate-200">{action.label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Two column: Recent commands + Active agents -->
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- Recent commands -->
    <div class="console-card">
      <div class="mb-4 flex items-center justify-between">
        <div>
          <h2 class="console-section-title">Lệnh gần đây</h2>
        </div>
        <a href="/command-center" class="text-sm text-accent hover:text-accent-hover">Xem tất cả →</a>
      </div>
      <div class="space-y-2">
        {[1, 2, 3].map(() => (
          <div class="flex items-center gap-3 rounded-lg border border-slate-800 bg-bg-card/50 p-3">
            <div class="h-2 w-2 rounded-full bg-slate-600"></div>
            <div class="flex-1">
              <p class="text-sm text-slate-300">—</p>
              <p class="text-xs text-slate-500">Chưa có lệnh</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Active agents -->
    <div class="console-card">
      <div class="mb-4 flex items-center justify-between">
        <div>
          <h2 class="console-section-title">Agent đang hoạt động</h2>
        </div>
        <a href="/agents" class="text-sm text-accent hover:text-accent-hover">Xem tất cả →</a>
      </div>
      <div class="space-y-2">
        {[1, 2, 3].map(() => (
          <div class="flex items-center gap-3 rounded-lg border border-slate-800 bg-bg-card/50 p-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-800 text-sm font-bold text-slate-400">—</div>
            <div class="flex-1">
              <p class="text-sm text-slate-300">Chưa có Agent hoạt động</p>
            </div>
            <StatusBadge status="offline" />
          </div>
        ))}
      </div>
    </div>
  </div>
</ConsoleLayout>
