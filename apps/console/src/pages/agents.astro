---
export const prerender = false;
/**
 * agents.astro — 9 Agent cards loaded from /v1/agents (real API)
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import AgentList from '../components/react/AgentList.tsx';
---

<ConsoleLayout title="Đội ngũ Agent · Nguyễn AI">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Đội ngũ Agent</h1>
    <p class="text-sm text-slate-400">9 Agent AI chuyên biệt của bạn</p>
  </div>

  <!-- Agent list (React island — loads from /v1/agents) -->
  <AgentList client:load />
</ConsoleLayout>
