---
export const prerender = false;
/**
 * agents.astro — 9 Agent cards loaded from /v1/agents (real API)
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import AgentList from '../components/react/AgentList.tsx';
---

<ConsoleLayout title="Agent Team · Nguyen AI Console">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Agent Team</h1>
    <p class="text-sm text-slate-400">Đội ngũ Agent · Your 9 specialized AI agents</p>
  </div>

  <!-- Agent list (React island — loads from /v1/agents) -->
  <AgentList client:load />
</ConsoleLayout>
