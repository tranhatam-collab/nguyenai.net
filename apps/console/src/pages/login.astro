---
export const prerender = false;
/**
 * login.astro — Login page (standalone, no ConsoleLayout)
 */
import '../styles/global.css';
---

<!doctype html>
<html lang="vi" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Sign In · Đăng nhập · Nguyen AI Console</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen items-center justify-center bg-bg p-4">
    <div class="w-full max-w-md">
      <!-- Branding -->
      <div class="mb-8 text-center">
        <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-accent text-2xl font-bold text-white">
          N
        </div>
        <h1 class="text-2xl font-bold text-slate-100">Nguyen AI</h1>
        <p class="mt-1 text-sm text-slate-400">Computer Console · app.nguyenai.net</p>
      </div>

      <!-- Login card -->
      <div class="console-card">
        <h2 class="console-section-title">Sign In · Đăng nhập</h2>
        <p class="console-section-subtitle mt-1">
          Access your AI Computer Instance
        </p>

        <!-- Login form -->
        <form class="mt-6 space-y-4" method="POST" action="/api/auth/login">
          <div>
            <label class="console-label" for="email">
              Email · Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="console-input"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label class="console-label" for="password">
              Password · Mật khẩu
            </label>
            <input
              id="password"
              name="password"
              type="password"
              required
              class="console-input"
              placeholder="••••••••"
            />
          </div>

          <div class="flex items-center justify-between text-sm">
            <label class="flex items-center gap-2 text-slate-400">
              <input type="checkbox" class="rounded border-slate-600 bg-bg-card text-accent focus:ring-accent" />
              Remember me
            </label>
            <a href="#" class="text-accent hover:text-accent-hover">Forgot password?</a>
          </div>

          <button type="submit" class="console-btn console-btn-primary w-full">
            Sign In · Đăng nhập
          </button>
        </form>

        <!-- Divider -->
        <div class="my-6 flex items-center gap-3">
          <div class="h-px flex-1 bg-slate-800"></div>
          <span class="text-xs text-slate-500">or · hoặc</span>
          <div class="h-px flex-1 bg-slate-800"></div>
        </div>

        <!-- Google sign-in -->
        <button class="console-btn console-btn-secondary w-full">
          <svg class="h-5 w-5" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Sign in with Google
        </button>
      </div>

      <!-- Footer -->
      <p class="mt-6 text-center text-xs text-slate-500">
        By signing in, you agree to the Nguyen AI Terms of Service.
        <br />
        Bằng việc đăng nhập, bạn đồng ý với Điều khoản dịch vụ Nguyen AI.
      </p>
    </div>
  </body>
</html>
