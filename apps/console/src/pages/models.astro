---
export const prerender = false;
/**
 * models.astro — Model Mesh: model selector cards, routing rules, cost estimator
 * Interactive React islands.
 */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import ModelSelector from '../components/react/ModelSelector.tsx';
import RoutingRules from '../components/react/RoutingRules.tsx';
import CostEstimator from '../components/react/CostEstimator.tsx';
---

<ConsoleLayout title="Lưới mô hình · Nguyễn AI">
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-100">Lưới mô hình</h1>
    <p class="text-sm text-slate-400">Định tuyến đa mô hình và quản lý chi phí</p>
  </div>

  <!-- Model selector (React island) -->
  <ModelSelector client:load />

  <!-- Routing rules (React island) -->
  <div class="mb-6">
    <RoutingRules client:load />
  </div>

  <!-- Cost estimator (React island) -->
  <CostEstimator client:load />
</ConsoleLayout>
