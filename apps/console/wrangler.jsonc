{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nguyenai-console",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "vars": {
    "ENVIRONMENT": "production"
  }
}
