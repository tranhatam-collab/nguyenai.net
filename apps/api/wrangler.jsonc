{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nguyenai-api-gateway",
  // FOUNDER LOCK: production resources and custom domain are owned by Anhhatam account.
  "account_id": "62d57eaa548617aeecac766e5a1cb98e",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ENVIRONMENT": "production",
    "AUTH_ISSUER": "auth.nguyenai.net",
    "VNPAY_PAY_URL": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
    "VNPAY_RETURN_URL": "https://api.nguyenai.net/v1/payment/vnpay/return",
    // pay-gateway.nguyenai.net — VietQR canonical gateway (VND, merchant of record: KASAN JSC).
    // Secrets (set via `wrangler secret put`): PAY_GATEWAY_API_KEY, PAY_NAI_HMAC.
    "PAY_GATEWAY_BASE_URL": "https://pay-gateway.nguyenai.net",
    "PAY_GATEWAY_TENANT_CODE": "nguyenai",
    "PAY_GATEWAY_SITE_CODE": "nguyenai",
    "PAY_GATEWAY_PROVIDER": "payos",
    "PAY_GATEWAY_CALLBACK_BASE": "https://api.nguyenai.net",
    // WI-1.3/WI-2.3: GEN1_GATEWAY_URL removed from vars — Gen1 proxy disabled by default.
    // To enable failoff: `wrangler secret put GEN1_GATEWAY_URL` + `wrangler secret put LEGACY_BRIDGE_ENABLED` (value: true)
    // SEC-P0-3: EVIDENCE_SIGNING_KEY removed from vars (old value leaked via git).
    // Set via `wrangler secret put EVIDENCE_SIGNING_KEY`. resolveEvidenceSigningKey()
    // throws in production when the secret is missing; dev uses a non-prod fallback.
    // WI-1.2: LLM_PROVIDER_MODE changed from 'gen1' to 'auto' (direct providers first).
    "LLM_PROVIDER_MODE": "auto",
    // P0-AI: AI Provider Gateway URL — public URL, not secret. Per AI_PROVIDER_SINGLE_SOURCE_DECISION_2026-07-16.
    // P0-AUDIT: Must use the API subdomain (api.*), NOT the web app root domain (Pages, HTML).
    "AI_PROVIDER_GATEWAY_URL": "https://api.aiagent.iai.one",
    // P0-AI: MODEL_GATEWAY_SIGNING_KEY — set via `wrangler secret put MODEL_GATEWAY_SIGNING_KEY`
    // Used by D1ModelGatewayStore to sign receipts with HMAC-SHA256.
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nguyenai-identity",
      "database_id": "704f85cb-0fa2-4d56-8659-cda65cc4d4e4",
      "migrations_dir": "../../migrations/d1"
    }
  ],
  "r2_buckets": [
    { "binding": "AUDIT_ARCHIVE", "bucket_name": "nai-audit-archive" }
  ],
  "kv_namespaces": [
    // RATE_LIMIT on Anhhatam production (62d57) — NOT the f3f9 namespace
    { "binding": "RATE_LIMIT", "id": "2e76b2d12593426ca912aabde39311b9" }
  ]
  // MAIL_GATEWAY_API_KEY via `wrangler secret put MAIL_GATEWAY_API_KEY` (primary)
  // RESEND_API_KEY deprecated fallback only
}
