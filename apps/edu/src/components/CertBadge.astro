---
interface Props {
  trackTitle?: string;
  holder?: string;
  issued?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { trackTitle = 'AI Computer Fundamentals', holder = 'Nguyen AI Subscriber', issued = '2024', size = 'md' } = Astro.props;

const sizeClass = {
  sm: 'w-48 h-64',
  md: 'w-64 h-80',
  lg: 'w-80 h-96',
}[size];
---

<div class={`${sizeClass} relative flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-gradient-to-br from-academy-accent to-academy-accentDark text-white shadow-lg`}>
  <div class="text-5xl mb-3" aria-hidden="true">🎓</div>

  <div class="text-xs uppercase tracking-widest opacity-80 mb-1">Certificate</div>
  <div class="text-lg font-bold mb-3">Nguyen AI Academy</div>

  <div class="w-16 h-px bg-white/40 mb-3"></div>

  <div class="text-sm opacity-90 mb-1">This certifies that</div>
  <div class="text-base font-semibold mb-3">{holder}</div>

  <div class="text-sm opacity-90 mb-1">has completed</div>
  <div class="text-sm font-semibold mb-4">{trackTitle}</div>

  <div class="text-xs opacity-70 mt-auto">Issued {issued}</div>
  <div class="text-xs opacity-70">edu.nguyenai.net</div>
</div>
