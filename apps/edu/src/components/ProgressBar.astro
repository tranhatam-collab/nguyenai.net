---
interface Props {
  value: number;
  max: number;
  label?: string;
}

const { value, max, label } = Astro.props;
const percent = max > 0 ? Math.min(100, Math.round((value / max) * 100)) : 0;
---

<div class="w-full">
  {label && (
    <div class="flex justify-between items-center mb-1.5">
      <span class="text-sm font-medium text-academy-muted">{label}</span>
      <span class="text-sm font-semibold text-academy-text">{percent}%</span>
    </div>
  )}
  <div
    class="w-full bg-academy-border rounded-full overflow-hidden"
    role="progressbar"
    aria-valuenow={value}
    aria-valuemin={0}
    aria-valuemax={max}
  >
    <div
      class="h-2 bg-academy-accent rounded-full transition-all duration-300"
      style={`width: ${percent}%`}
    >
    </div>
  </div>
</div>
