---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Doanh nghiệp';
const description = 'Doanh nghiệp đối tác — đăng dự án, đăng việc, nhận hồ sơ năng lực.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="doanh-nghiep">
  <main class="edu-page">
    <section class="hero">
      <h1>Doanh nghiệp đối tác</h1>
      <p>Đăng dự án, đăng việc, nhận hồ sơ năng lực.</p>
    </section>
    <section class="content-section">
      <h2>Quyền lợi doanh nghiệp</h2>
      <ul class="benefits-list">
        <li>Đăng <a href="/du-an" class="edu-link">dự án thật</a> cho người học Cấp 2+.</li>
        <li>Đăng <a href="/viec-lam" class="edu-link">việc làm</a> xác minh.</li>
        <li>Nhận <strong>hồ sơ năng lực</strong> (sản phẩm + biên nhận) thay CV.</li>
        <li>Mentor người học (tùy chọn).</li>
        <li>Tham gia hội đồng duyệt sản phẩm.</li>
      </ul>
    </section>
    <section class="content-section">
      <h2>Trách nhiệm doanh nghiệp</h2>
      <ul class="rules-list">
        <li>Dự án phải thật, có người chịu trách nhiệm.</li>
        <li>Việc làm phải có lương rõ ràng.</li>
        <li>Không tuyển dụng ảo, không "thử việc không lương".</li>
        <li>Đánh giá người học công bằng, theo rubric.</li>
      </ul>
    </section>
    <section class="content-section">
      <h2>Đăng ký đối tác</h2>
      <p>Doanh nghiệp đăng ký qua email: <a href="mailto:edu@nguyenai.net" class="edu-link">edu@nguyenai.net</a></p>
      <p>Sau khi xác minh (email domain, giấy phép), doanh nghiệp nhận tài khoản <code>edu:employer</code>.</p>
    </section>
  </main>
</AcademyLayout>
