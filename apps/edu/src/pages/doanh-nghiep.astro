---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Doanh nghiệp';
const description = 'Doanh nghiệp đối tác — đăng dự án, đăng việc, nhận hồ sơ năng lực.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="doanh-nghiep">
  <main class="edu-page">
    <section class="hero">
      <h1>Doanh nghiệp</h1>
      <p>Doanh nghiệp đối tác — đăng dự án, đăng việc, nhận hồ sơ năng lực.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
