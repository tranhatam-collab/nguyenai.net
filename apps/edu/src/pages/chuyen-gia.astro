---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Chuyên gia';
const description = 'Mentor và chuyên gia — hướng dẫn bằng câu hỏi, phản hồi xây dựng.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="chuyen-gia">
  <main class="edu-page">
    <section class="hero">
      <h1>Mentor và Chuyên gia</h1>
      <p>Hướng dẫn bằng câu hỏi, phản hồi xây dựng.</p>
    </section>
    <section class="content-section">
      <h2>Vai trò mentor</h2>
      <ul class="roles-list">
        <li><strong>Hướng dẫn bằng câu hỏi</strong> — không làm thay, mà hỏi để người học tự tìm ra đáp án.</li>
        <li><strong>Phản hồi xây dựng</strong> — theo rubric 4 mức, chỉ rõ điểm cần sửa.</li>
        <li><strong>Duyệt sản phẩm</strong> — chấm A/B/C/D theo rubric.</li>
        <li><strong>Đồng hành 90 ngày</strong> — gặp 1:1 mỗi 2 tuần (30 phút).</li>
      </ul>
    </section>
    <section class="content-section">
      <h2>Trở thành mentor</h2>
      <ol class="process-list">
        <li>Hoàn thành Cấp 3 trở lên.</li>
        <li>Được 2 mentor hiện tại giới thiệu.</li>
        <li>Hội đồng chấp thuận (mentor + founder liaison).</li>
        <li>Nhận vai trò <code>edu:mentor</code>.</li>
      </ol>
    </section>
    <section class="content-section">
      <h2>Chuyên gia đóng góp</h2>
      <p>Chuyên gia (Cấp 4) đóng góp chuẩn giáo trình, tham gia hội đồng duyệt, và hướng dẫn mentor mới.</p>
    </section>
  </main>
</AcademyLayout>
