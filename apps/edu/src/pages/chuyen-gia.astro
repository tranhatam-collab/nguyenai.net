---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Chuyên gia';
const description = 'Mentor và chuyên gia — hướng dẫn bằng câu hỏi, phản hồi xây dựng.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="chuyen-gia">
  <main class="edu-page">
    <section class="hero">
      <h1>Chuyên gia</h1>
      <p>Mentor và chuyên gia — hướng dẫn bằng câu hỏi, phản hồi xây dựng.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
