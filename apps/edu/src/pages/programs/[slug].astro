---
import AcademyLayout from '../../layouts/AcademyLayout.astro';
import { programs, getProgramBySlug, programCategories, pricingTiers, scholarshipConfig } from '../../data/programs';

export function getStaticPaths() {
  return programs.map((program) => ({
    params: { slug: program.slug },
  }));
}

const { slug } = Astro.params;
const program = getProgramBySlug(slug!);

if (!program) {
  return Astro.redirect('/programs');
}

const category = programCategories.find((c) => c.id === program.category);
const formatVND = (n: number) => n.toLocaleString('vi-VN') + '₫';
const tierKeys = ['khoiDong', 'thucHanh', 'chuyenNghiep', 'dongHanh'] as const;
---

<AcademyLayout
  title={`${program.title.vi} (${program.code})`}
  description={program.tagline.vi}
  activeNav="programs"
>
  <section class="academy-container py-12" aria-label="Program details">
    <a href="/programs" class="text-sm text-academy-accent hover:underline mb-4 inline-block">← Tất cả programs</a>

    <!-- Header -->
    <div class="flex items-start gap-6 mb-8">
      <div class="text-6xl">{program.icon}</div>
      <div class="flex-1">
        <div class="text-sm text-academy-muted font-mono">{program.code}</div>
        <h1 class="text-3xl font-bold text-academy-text">{program.title.vi}</h1>
        <p class="text-lg text-academy-accent">{program.title.en}</p>
        <p class="text-academy-muted mt-2">{program.tagline.vi}</p>
        <div class="flex flex-wrap gap-3 mt-4 text-sm text-academy-muted">
          <span class="px-3 py-1 bg-academy-bg rounded-full">📚 {program.moduleCount} modules</span>
          <span class="px-3 py-1 bg-academy-bg rounded-full">⏱ {program.duration}</span>
          <span class="px-3 py-1 bg-academy-bg rounded-full">📊 {program.difficulty}</span>
          <span class="px-3 py-1 bg-academy-bg rounded-full">{category?.icon} {category?.label.vi}</span>
          <span class="px-3 py-1 bg-academy-bg rounded-full">🖥 {program.machineProfile}</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Curriculum modules -->
      <div class="lg:col-span-2">
        <h2 class="text-xl font-bold text-academy-text mb-2">Modules / Chuyên đề</h2>
        <p class="text-academy-muted text-sm mb-4">
          {program.moduleCount} modules · Mỗi chuyên đề có 14 thành phần bắt buộc: mục tiêu, tài liệu, bài giảng, thực hành, kiểm tra, rubric, bằng chứng, điều kiện mở bài tiếp.
        </p>
        <div class="space-y-3">
          {program.modules.map((mod, i) => (
            <div class="academy-card p-4 flex items-center gap-4">
              <div class="w-8 h-8 rounded-full bg-academy-accent/10 text-academy-accent flex items-center justify-center font-bold text-sm shrink-0">
                {i + 1}
              </div>
              <div class="flex-1">
                <div class="font-semibold text-academy-text">{mod.vi}</div>
                <div class="text-sm text-academy-muted">{mod.en}</div>
              </div>
            </div>
          ))}
        </div>

        <!-- Graduation product -->
        <div class="academy-card p-6 mt-6 border-2 border-green-500/30">
          <h3 class="font-bold text-academy-text mb-2">🎓 Sản phẩm tốt nghiệp</h3>
          <p class="text-sm text-academy-text">{program.graduationProduct.vi}</p>
          <p class="text-sm text-academy-muted mt-1">{program.graduationProduct.en}</p>
          <p class="text-xs text-academy-muted mt-3">
            Tốt nghiệp chỉ khi: sản phẩm đạt rubric + bảo vệ thành công + nộp đủ hồ sơ năng lực + hội đồng phê duyệt.
          </p>
        </div>

        <!-- Target audience -->
        <div class="academy-card p-6 mt-6">
          <h3 class="font-bold text-academy-text mb-2">Đối tượng</h3>
          <p class="text-sm text-academy-text">{program.targetAudience.vi}</p>
          <p class="text-sm text-academy-muted mt-1">{program.targetAudience.en}</p>
        </div>

        <!-- Pass thresholds -->
        <div class="academy-card p-6 mt-6">
          <h3 class="font-bold text-academy-text mb-3">Điểm qua bài</h3>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
            <div class="p-3 bg-academy-bg rounded-lg">
              <div class="text-xs text-academy-muted">Kiểm tra kiến thức</div>
              <div class="font-bold text-academy-accent">≥ {scholarshipConfig.passThresholds.knowledge}%</div>
            </div>
            <div class="p-3 bg-academy-bg rounded-lg">
              <div class="text-xs text-academy-muted">Kiểm tra thao tác</div>
              <div class="font-bold text-academy-accent">≥ {scholarshipConfig.passThresholds.operation}%</div>
            </div>
            <div class="p-3 bg-academy-bg rounded-lg">
              <div class="text-xs text-academy-muted">Tình huống</div>
              <div class="font-bold text-academy-accent">≥ {scholarshipConfig.passThresholds.scenario}%</div>
            </div>
            <div class="p-3 bg-academy-bg rounded-lg">
              <div class="text-xs text-academy-muted">Thực hành</div>
              <div class="font-bold text-academy-accent">≥ {scholarshipConfig.passThresholds.practice}%</div>
            </div>
            <div class="p-3 bg-academy-bg rounded-lg">
              <div class="text-xs text-academy-muted">Mini project</div>
              <div class="font-bold text-academy-accent">≥ {scholarshipConfig.passThresholds.miniProject}%</div>
            </div>
            <div class="p-3 bg-academy-bg rounded-lg">
              <div class="text-xs text-academy-muted">Final project</div>
              <div class="font-bold text-academy-accent">≥ {scholarshipConfig.passThresholds.finalProject}%</div>
            </div>
          </div>
          <p class="text-xs text-academy-muted mt-3">
            Không qua → học lại (tối đa 4 lần). Sau lần 4: hội đồng học thuật xem xét.
          </p>
        </div>
      </div>

      <!-- Sidebar: pricing + scholarship -->
      <div class="lg:col-span-1">
        <div class="sticky top-20 space-y-6">
          <!-- 4-tier pricing -->
          <div class="academy-card p-6">
            <h3 class="font-bold text-academy-text mb-4">Học phí — 4 gói</h3>
            <div class="space-y-3">
              {tierKeys.map((key, i) => {
                const tier = pricingTiers[i];
                const price = program.pricing[key];
                return (
                  <div class={`p-3 bg-academy-bg rounded-lg ${i === 1 ? 'border border-academy-accent/20' : ''}`}>
                    <div class="flex justify-between items-center">
                      <div>
                        <div class="font-semibold text-academy-text text-sm">{tier.name.vi}</div>
                        <div class="text-xs text-academy-muted">{tier.duration.vi} · {tier.format.vi}</div>
                      </div>
                      <div class="text-right">
                        <div class="font-bold text-academy-accent">{formatVND(price.vnd)}</div>
                        <div class="text-xs text-academy-muted">~${price.usd}</div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
            <button class="w-full mt-4 academy-btn academy-btn-primary">Đăng ký học</button>
            <p class="text-xs text-academy-muted mt-2 text-center">
              Giá niêm yết (Phương án B). Cohort đầu = Phương án A.
            </p>
          </div>

          <!-- Scholarship -->
          <div class="academy-card p-6 border-2 border-green-500/30">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-2xl">🎓</span>
              <h3 class="font-bold text-academy-text">Học bổng</h3>
            </div>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-academy-muted">Học bổng/program</span>
                <span class="font-bold text-green-600">{program.scholarshipSlots} suất</span>
              </div>
              <div class="flex justify-between">
                <span class="text-academy-muted">Độ tuổi</span>
                <span class="font-bold text-academy-text">{scholarshipConfig.ageRange.min}–{scholarshipConfig.ageRange.max}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-academy-muted">Ưu tiên</span>
                <span class="font-bold text-academy-text">Họ Nguyễn VN</span>
              </div>
              <div class="flex justify-between">
                <span class="text-academy-muted">Giá trị</span>
                <span class="font-bold text-academy-text">{formatVND(scholarshipConfig.fund.perScholarshipVND)}</span>
              </div>
            </div>
            <a href="/scholarship" class="block w-full mt-4 text-center academy-btn academy-btn-secondary text-sm">
              Đăng ký học bổng →
            </a>
          </div>

          <!-- Certificate -->
          <div class="academy-card p-6">
            <h3 class="font-bold text-academy-text mb-2">Certificate</h3>
            <p class="text-sm text-academy-muted">
              Chỉ cấp khi: hoàn thành 100% bài bắt buộc + đạt điểm tối thiểu + nộp đủ bằng chứng + hội đồng duyệt + bảo vệ sản phẩm.
            </p>
            <p class="text-sm text-academy-muted mt-2">
              Certificate có mã verify công khai tại <a href="/verify" class="text-academy-accent underline">/verify</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</AcademyLayout>
