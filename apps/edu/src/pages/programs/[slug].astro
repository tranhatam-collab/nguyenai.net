---
import AcademyLayout from '../../layouts/AcademyLayout.astro';
import { programs, getProgramBySlug, programCategories } from '../../data/programs';

export function getStaticPaths() {
  return programs.map((program) => ({
    params: { slug: program.slug },
  }));
}

const { slug } = Astro.params;
const program = getProgramBySlug(slug!);

if (!program) {
  return Astro.redirect('/programs');
}

const category = programCategories.find((c) => c.id === program.category);
const formatVND = (n: number) => n.toLocaleString('vi-VN') + '₫';
---

<AcademyLayout
  title={`${program.title.vi} (${program.code})`}
  description={program.tagline.vi}
  activeNav="programs"
>
  <section class="academy-container py-12">
    <a href="/programs" class="text-sm text-academy-accent hover:underline mb-4 inline-block">← Tất cả programs</a>

    <!-- Header -->
    <div class="flex items-start gap-6 mb-8">
      <div class="text-6xl">{program.icon}</div>
      <div class="flex-1">
        <div class="text-sm text-academy-muted font-mono">{program.code}</div>
        <h1 class="text-3xl font-bold text-academy-text">{program.title.vi}</h1>
        <p class="text-lg text-academy-accent">{program.title.en}</p>
        <p class="text-academy-muted mt-2">{program.tagline.vi}</p>
        <div class="flex flex-wrap gap-3 mt-4 text-sm text-academy-muted">
          <span class="px-3 py-1 bg-academy-bg rounded-full">📚 {program.lessonCount} bài học</span>
          <span class="px-3 py-1 bg-academy-bg rounded-full">⏱ {program.duration}</span>
          <span class="px-3 py-1 bg-academy-bg rounded-full">📊 {program.difficulty}</span>
          <span class="px-3 py-1 bg-academy-bg rounded-full">{category?.icon} {category?.label.vi}</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Curriculum -->
      <div class="lg:col-span-2">
        <h2 class="text-xl font-bold text-academy-text mb-4">Curriculum / Nội dung</h2>
        <div class="space-y-3">
          {program.curriculum.map((lesson, i) => (
            <div class="academy-card p-4 flex items-center gap-4">
              <div class="w-8 h-8 rounded-full bg-academy-accent/10 text-academy-accent flex items-center justify-center font-bold text-sm shrink-0">
                {i + 1}
              </div>
              <div class="flex-1">
                <div class="font-semibold text-academy-text">{lesson.title.vi}</div>
                <div class="text-sm text-academy-muted">{lesson.title.en}</div>
              </div>
              <span class="text-xs text-academy-muted shrink-0">{lesson.duration}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Sidebar: pricing + scholarship -->
      <div class="lg:col-span-1">
        <div class="sticky top-20 space-y-6">
          <!-- Pricing -->
          <div class="academy-card p-6">
            <h3 class="font-bold text-academy-text mb-4">Học phí</h3>
            <div class="space-y-3">
              <div class="p-3 bg-academy-bg rounded-lg">
                <div class="flex justify-between items-center">
                  <div>
                    <div class="font-semibold text-academy-text text-sm">Self-paced</div>
                    <div class="text-xs text-academy-muted">Tự học + quiz + cert</div>
                  </div>
                  <div class="text-right">
                    <div class="font-bold text-academy-accent">{formatVND(program.pricing.selfPaced.vnd)}</div>
                    <div class="text-xs text-academy-muted">~${program.pricing.selfPaced.usd}</div>
                  </div>
                </div>
              </div>
              <div class="p-3 bg-academy-bg rounded-lg border border-academy-accent/20">
                <div class="flex justify-between items-center">
                  <div>
                    <div class="font-semibold text-academy-text text-sm">Cohort</div>
                    <div class="text-xs text-academy-muted">+ Instructor + 8 tuần</div>
                  </div>
                  <div class="text-right">
                    <div class="font-bold text-academy-accent">{formatVND(program.pricing.cohort.vnd)}</div>
                    <div class="text-xs text-academy-muted">~${program.pricing.cohort.usd}</div>
                  </div>
                </div>
              </div>
              <div class="p-3 bg-academy-bg rounded-lg">
                <div class="flex justify-between items-center">
                  <div>
                    <div class="font-semibold text-academy-text text-sm">Professional</div>
                    <div class="text-xs text-academy-muted">+ Mentor 1:1 + career</div>
                  </div>
                  <div class="text-right">
                    <div class="font-bold text-academy-accent">{formatVND(program.pricing.professional.vnd)}</div>
                    <div class="text-xs text-academy-muted">~${program.pricing.professional.usd}</div>
                  </div>
                </div>
              </div>
            </div>
            <button class="w-full mt-4 academy-btn academy-btn-primary">Đăng ký học</button>
          </div>

          <!-- Scholarship -->
          <div class="academy-card p-6 border-2 border-green-500/30">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-2xl">🎓</span>
              <h3 class="font-bold text-academy-text">Học bổng</h3>
            </div>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-academy-muted">Học bổng/program</span>
                <span class="font-bold text-green-600">{program.scholarshipSlots} xuất</span>
              </div>
              <div class="flex justify-between">
                <span class="text-academy-muted">Nhóm</span>
                <span class="font-bold text-academy-text">{program.scholarshipGroups} nhóm × {program.groupSize}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-academy-muted">Độ tuổi</span>
                <span class="font-bold text-academy-text">20–49</span>
              </div>
              <div class="flex justify-between">
                <span class="text-academy-muted">Ưu tiên</span>
                <span class="font-bold text-academy-text">Họ Nguyễn VN</span>
              </div>
            </div>
            <a href="/scholarship" class="block w-full mt-4 text-center academy-btn academy-btn-secondary text-sm">
              Đăng ký học bổng →
            </a>
          </div>

          <!-- Certificate -->
          <div class="academy-card p-6">
            <h3 class="font-bold text-academy-text mb-2">Certificate</h3>
            <p class="text-sm text-academy-muted">
              Hoàn thành exam ≥ 70% để nhận certificate có mã verify.
              Certificate verify tại <a href="/verify" class="text-academy-accent underline">/verify</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</AcademyLayout>
