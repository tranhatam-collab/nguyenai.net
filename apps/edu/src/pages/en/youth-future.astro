---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Youth Future';
const description = 'Youth Future and Technology in Everyday Life — the parent program.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="youth-future">
  <main class="edu-page">
    <section class="hero">
      <h1>Youth Future</h1>
      <p>Youth Future and Technology in Everyday Life — the parent program.</p>
    </section>
    <section class="content-section">
      <h2>About</h2>
      <p>Mission: Help young Vietnamese use AI technology to solve real problems, create real job opportunities, and live responsibly in the AI era. Young People at Work is the direct action program. Da Lat is the offline program.</p>
    </section>
    <section class="cta-section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
