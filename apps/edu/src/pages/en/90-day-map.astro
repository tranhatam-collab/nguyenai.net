---
import AcademyLayout from '../../layouts/AcademyLayout.astro';
import CareerMapPanel from '../../components/CareerMapPanel.astro';

const title = '90-Day Map';
const description = '30-60-90 day action map — goals, milestones, roadmap.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="90-day-map">
  <main class="edu-page">
    <section class="hero" aria-label="90-Day Map">
      <h1>90-Day Map</h1>
      <p>Goals, 30-60-90 day milestones, action roadmap.</p>
    </section>
    <CareerMapPanel />
  </main>
</AcademyLayout>
