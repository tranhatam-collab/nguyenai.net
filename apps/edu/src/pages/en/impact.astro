---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Impact';
const description = '90-day impact report — real numbers, with evidence.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="impact">
  <main class="edu-page">
    <section class="hero">
      <h1>Impact</h1>
      <p>90-day impact report — real numbers, with evidence.</p>
    </section>
    <section class="content-section">
      <h2>About</h2>
      <p>4 metric groups: Learners, Jobs and projects, Community, Quality. Principles: real numbers, evidence-backed, public, not marketing. First report after first 90-day cohort.</p>
    </section>
    <section class="cta-section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
