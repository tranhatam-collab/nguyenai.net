---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Impact';
const description = '90-day impact report — real numbers, with evidence.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="impact">
  <main class="edu-page">
    <section class="hero">
      <h1>Impact</h1>
      <p>90-day impact report — real numbers, with evidence.</p>
    </section>
    <section class="content-placeholder">
      <p>Content under construction per Master Plan V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
