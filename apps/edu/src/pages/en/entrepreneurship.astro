---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Entrepreneurship';
const description = 'Startup incubator — real problem, real customer, first revenue.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="entrepreneurship">
  <main class="edu-page">
    <section class="hero" aria-label="Entrepreneurship">
      <h1>Entrepreneurship</h1>
      <p>Startup incubator — real problem, real customer, first revenue.</p>
    </section>
    <section class="content-section" aria-label="About">
      <h2>About</h2>
      <p>3 conditions: Real problem, Real customer, First revenue within 90 days. Process: Level 1 foundations, Level 2 find problem/customer, Level 3 package and sell, Level 4 scale.</p>
    </section>
    <section class="cta-section" aria-label="Cta Section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
