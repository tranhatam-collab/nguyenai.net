---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Employers';
const description = 'Partner employers — post projects, post jobs, review portfolios.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="employers">
  <main class="edu-page">
    <section class="hero">
      <h1>Employers</h1>
      <p>Partner employers — post projects, post jobs, review portfolios.</p>
    </section>
    <section class="content-section">
      <h2>About</h2>
      <p>Benefits: Post real projects, post verified jobs, receive competence portfolios, mentor learners. Responsibilities: real projects, paid jobs, fair evaluation. Register: edu@nguyenai.net</p>
    </section>
    <section class="cta-section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
