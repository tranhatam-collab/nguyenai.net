---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Products';
const description = 'Small real products — no product = not complete.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="products">
  <main class="edu-page">
    <section class="hero">
      <h1>Products</h1>
      <p>Small real products — no product = not complete.</p>
    </section>
    <section class="content-section">
      <h2>About</h2>
      <p>Every lesson has 1 product requirement. Products must be real — usable, not fake demos. No product = lesson not complete. Products reviewed by mentor using 4-level rubric.</p>
    </section>
    <section class="cta-section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
