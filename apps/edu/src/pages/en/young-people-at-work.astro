---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Young People at Work';
const description = 'Action community: learn real, work real, live responsibly.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="young-people-at-work">
  <main class="edu-page">
    <section class="hero">
      <h1>Young People at Work</h1>
      <p>Action community: learn real, work real, live responsibly.</p>
    </section>
    <section class="content-section">
      <h2>About</h2>
      <p>Young People at Work is an action community — not just learning theory, but making real products, solving real problems, creating real value. Part of Youth Future — technology in everyday life. 3 core values: Learn real, Work real, Live responsibly. 5 levels from Kickoff to Expert.</p>
    </section>
    <section class="cta-section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
