---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Certificates';
const description = '7 certificate types — verifiable at /verify/.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="certificates">
  <main class="edu-page">
    <section class="hero">
      <h1>Certificates</h1>
      <p>7 certificate types — verifiable at /verify/.</p>
    </section>
    <section class="content-section">
      <h2>About</h2>
      <p>7 types: Lesson completion, Level completion, Pillar product, Real project, Mentor, Expert, Entrepreneurship. Each has public verification code. Not course completion — competence receipts.</p>
    </section>
    <section class="cta-section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
