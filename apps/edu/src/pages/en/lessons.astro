---
import AcademyLayout from '../../layouts/AcademyLayout.astro';
import LessonPlayer from '../../components/LessonPlayer.astro';

const title = 'Lessons';
const description = 'Every lesson has 8 components: lecture, reading, quiz, task, product, rubric, review, receipt.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="lessons">
  <main class="edu-page">
    <section class="hero" aria-label="Lessons">
      <h1>Lessons</h1>
      <p>Every lesson has 8 components: lecture, reading, quiz, task, product, rubric, review, receipt.</p>
    </section>
    <LessonPlayer lessonTitle="Sample lesson — Intro to Nguyen AI Computer" lessonLevel="0" />
  </main>
</AcademyLayout>
