---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Learning Paths';
const description = '5 levels from Kickoff to Expert — choose your path.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="learning-paths">
  <main class="edu-page">
    <section class="hero" aria-label="Learning Paths">
      <h1>Learning Paths</h1>
      <p>5 levels from Kickoff to Expert — choose your path.</p>
    </section>
    <section class="content-section" aria-label="About">
      <h2>About</h2>
      <p>5 levels: Level 0 Kickoff (4 lessons), Level 1 Pillars (16 lessons), Level 2 Specialization (20 lessons), Level 3 Leadership (10 lessons), Level 4 Expert (10 lessons). Take the entry assessment to find your level.</p>
    </section>
    <section class="cta-section" aria-label="Cta Section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
