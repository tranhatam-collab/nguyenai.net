---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Jobs';
const description = 'Verified job marketplace — no fake jobs.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="jobs">
  <main class="edu-page">
    <section class="hero">
      <h1>Jobs</h1>
      <p>Verified job marketplace — no fake jobs.</p>
    </section>
    <section class="content-section">
      <h2>About</h2>
      <p>Employers must verify (email domain, license). No fake jobs, no unpaid trials. Each job has clear description, salary, timeline. Learners apply with competence portfolio instead of traditional CV.</p>
    </section>
    <section class="cta-section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
