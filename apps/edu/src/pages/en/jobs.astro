---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Jobs';
const description = 'Verified job marketplace — no fake jobs.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="jobs">
  <main class="edu-page">
    <section class="hero">
      <h1>Jobs</h1>
      <p>Verified job marketplace — no fake jobs.</p>
    </section>
    <section class="content-placeholder">
      <p>Content under construction per Master Plan V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
