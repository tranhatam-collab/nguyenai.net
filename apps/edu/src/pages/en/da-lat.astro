---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Da Lat';
const description = 'Da Lat program — 7 days live and work, real local projects.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="da-lat">
  <main class="edu-page">
    <section class="hero" aria-label="Da Lat">
      <h1>Da Lat</h1>
      <p>Da Lat program — 7 days live and work, real local projects.</p>
    </section>
    <section class="content-section" aria-label="About">
      <h2>About</h2>
      <p>7-day offline program in Da Lat. Days 1-2: onboarding, choose project. Days 3-5: build real product, 1:1 mentoring. Day 6: present, feedback. Day 7: wrap up, receipts. Cost: 1.5M VND/person. Scholarships available.</p>
    </section>
    <section class="cta-section" aria-label="Cta Section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
