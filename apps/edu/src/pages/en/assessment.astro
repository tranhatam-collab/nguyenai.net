---
import AcademyLayout from '../../layouts/AcademyLayout.astro';
import AssessmentForm from '../../components/AssessmentForm.astro';

const title = 'Entry Assessment';
const description = 'Assess your skills and career direction — get your 90-day map.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="assessment">
  <main class="edu-page">
    <section class="hero" aria-label="Entry Assessment">
      <h1>Entry Assessment</h1>
      <p>10 questions to understand you — about 5 minutes. Results create your 90-day map.</p>
    </section>
    <AssessmentForm />
  </main>
</AcademyLayout>
