---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Projects';
const description = 'Real project marketplace — 9 required fields, real owner, verifiable receipt.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="projects">
  <main class="edu-page">
    <section class="hero">
      <h1>Projects</h1>
      <p>Real project marketplace — 9 required fields, real owner, verifiable receipt.</p>
    </section>
    <section class="content-section">
      <h2>About</h2>
      <p>9 required fields: Project name, Problem, Solution, Owner, Customer, Timeline, Budget, Expected outcome, Verification receipt. No fake projects allowed.</p>
    </section>
    <section class="cta-section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
