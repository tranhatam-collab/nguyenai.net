---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Projects';
const description = 'Real project marketplace — 9 required fields, real owner, verifiable receipt.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="projects">
  <main class="edu-page">
    <section class="hero">
      <h1>Projects</h1>
      <p>Real project marketplace — 9 required fields, real owner, verifiable receipt.</p>
    </section>
    <section class="content-placeholder">
      <p>Content under construction per Master Plan V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
