---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Mentors';
const description = 'Mentors and experts — guide by questions, constructive feedback.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="mentors">
  <main class="edu-page">
    <section class="hero">
      <h1>Mentors</h1>
      <p>Mentors and experts — guide by questions, constructive feedback.</p>
    </section>
    <section class="content-section">
      <h2>About</h2>
      <p>Mentor role: Guide by questions, constructive feedback per rubric, review products, 1:1 every 2 weeks. Become mentor: complete Level 3+, 2 referrals, council approval.</p>
    </section>
    <section class="cta-section">
      <a href="/en/start" class="edu-btn edu-btn-primary">Start learning →</a>
    </section>
  </main>
</AcademyLayout>
