---
import AcademyLayout from '../../layouts/AcademyLayout.astro';
import SubmissionForm from '../../components/SubmissionForm.astro';

const title = 'Tasks';
const description = 'Hands-on tasks with Nguyen AI Computer — real work, real submission.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="tasks">
  <main class="edu-page">
    <section class="hero" aria-label="Hands-on Tasks">
      <h1>Hands-on Tasks</h1>
      <p>Hands-on tasks with Nguyen AI Computer — real work, real submission.</p>
    </section>
    <SubmissionForm assignmentTitle="Sample task — Build a small product" />
  </main>
</AcademyLayout>
