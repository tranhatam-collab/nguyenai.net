---
import AcademyLayout from '../../layouts/AcademyLayout.astro';

const title = 'Start';
const description = 'Register and take the entry assessment — start your 90-day journey.';
const locale = 'en';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="start">
  <main class="edu-page">
    <section class="hero">
      <h1>Start</h1>
      <p>Register and take the entry assessment — start your 90-day journey.</p>
    </section>
    <section class="content-placeholder">
      <p>Content under construction per Master Plan V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
