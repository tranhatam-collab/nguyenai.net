---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Bắt đầu';
const description = 'Đăng ký và đánh giá đầu vào — bắt đầu hành trình 90 ngày.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="bat-dau">
  <main class="edu-page">
    <section class="hero">
      <h1>Bắt đầu</h1>
      <p>Đăng ký và đánh giá đầu vào — bắt đầu hành trình 90 ngày.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
