---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Việc làm';
const description = 'Sàn việc làm xác minh doanh nghiệp — cấm việc ảo.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="viec-lam">
  <main class="edu-page">
    <section class="hero">
      <h1>Việc làm</h1>
      <p>Sàn việc làm xác minh doanh nghiệp — cấm việc ảo.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
