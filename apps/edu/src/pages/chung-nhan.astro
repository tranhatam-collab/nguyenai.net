---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Chứng nhận';
const description = '7 loại chứng nhận — tra cứu công khai tại /xac-minh/.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="chung-nhan">
  <main class="edu-page">
    <section class="hero">
      <h1>Chứng nhận</h1>
      <p>7 loại chứng nhận — tra cứu công khai tại /xac-minh/.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
