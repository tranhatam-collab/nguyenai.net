---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Bài học';
const description = 'Mỗi bài học có đủ 8 thành phần: giảng, đọc, kiểm tra, nhiệm vụ, sản phẩm, rubric, duyệt, biên nhận.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="bai-hoc">
  <main class="edu-page">
    <section class="hero">
      <h1>Bài học</h1>
      <p>Mỗi bài học có đủ 8 thành phần: giảng, đọc, kiểm tra, nhiệm vụ, sản phẩm, rubric, duyệt, biên nhận.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
