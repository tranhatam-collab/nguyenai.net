---
import AcademyLayout from '../layouts/AcademyLayout.astro';
import CareerMapPanel from '../components/CareerMapPanel.astro';

const title = 'Bản đồ 90 ngày';
const description = 'Bản đồ hành động 30-60-90 ngày — mục tiêu, mốc, lộ trình.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="ban-do-90-ngay">
  <main class="edu-page">
    <section class="hero" aria-label="Bản đồ 90 ngày">
      <h1>Bản đồ 90 ngày</h1>
      <p>Mục tiêu, mốc 30-60-90 ngày, lộ trình hành động.</p>
    </section>
    <CareerMapPanel />
  </main>
</AcademyLayout>
