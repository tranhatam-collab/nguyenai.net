---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Xác minh';
const description = 'Tra cứu biên nhận năng lực — mã tra cứu công khai.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="xac-minh">
  <main class="edu-page">
    <section class="hero">
      <h1>Xác minh</h1>
      <p>Tra cứu biên nhận năng lực — mã tra cứu công khai.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
