---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Tuổi Trẻ Tương Lai';
const description = 'Tuổi Trẻ Tương Lai và Công Nghệ Tới Đời Sống — chương trình mẹ.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="tuoi-tre-tuong-lai">
  <main class="edu-page">
    <section class="hero" aria-label="Tuổi Trẻ Tương Lai">
      <h1>Tuổi Trẻ Tương Lai</h1>
      <p>Tuổi Trẻ Tương Lai và Công Nghệ Tới Đời Sống — chương trình mẹ của Người Trẻ Làm.</p>
    </section>
    <section class="content-section" aria-label="Sứ mệnh">
      <h2>Sứ mệnh</h2>
      <p>Giúp người trẻ Việt Nam sử dụng công nghệ AI để giải quyết vấn đề thật, tạo cơ hội việc làm thật, và sống có trách nhiệm trong thời đại AI.</p>
    </section>
    <section class="content-section" aria-label="Sứ mệnh">
      <h2>Người Trẻ Làm — chương trình con</h2>
      <p><a href="/nguoi-tre-lam" class="edu-link">Người Trẻ Làm</a> là chương trình hành động trực tiếp của Tuổi Trẻ Tương Lai, với 5 cấp học, 90 ngày, và yêu cầu sản phẩm thật.</p>
    </section>
    <section class="content-section" aria-label="Sứ mệnh">
      <h2>Đà Lạt — chương trình offline</h2>
      <p><a href="/da-lat" class="edu-link">Chương trình Đà Lạt</a> — 7 ngày sống và làm cùng nhau, dự án địa phương thật.</p>
    </section>
    <section class="cta-section" aria-label="Cta Section">
      <a href="/nguoi-tre-lam" class="edu-btn edu-btn-primary">Vào Người Trẻ Làm →</a>
      <a href="/bat-dau" class="edu-btn edu-btn-secondary">Bắt đầu hành trình</a>
    </section>
  </main>
</AcademyLayout>
