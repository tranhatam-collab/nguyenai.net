---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Học bổng';
const description = 'Học bổng, tài trợ, hỗ trợ — quy trình xét duyệt minh bạch.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="hoc-bong">
  <main class="edu-page">
    <section class="hero">
      <h1>Học bổng</h1>
      <p>Học bổng, tài trợ, hỗ trợ — quy trình xét duyệt minh bạch.</p>
    </section>
    <section class="content-section">
      <h2>Loại học bổng</h2>
      <ul class="scholarship-list">
        <li><strong>Học bổng toàn phần</strong> — miễn phí Academy Pass + mentor 1:1.</li>
        <li><strong>Học bổng một phần</strong> — giảm 50% Academy Pass.</li>
        <li><strong>Tài trợ dự án</strong> — hỗ trợ chi phí dự án Đà Lạt hoặc dự án địa phương.</li>
        <li><strong>Hỗ trợ khó khăn</strong> — cho người học vùng khó, hoàn cảnh đặc biệt.</li>
      </ul>
    </section>
    <section class="content-section">
      <h2>Quy trình xét duyệt</h2>
      <ol class="process-list">
        <li>Người học nộp đơn (profile + đánh giá đầu vào + lý do).</li>
        <li>Mentor xem xét, phỏng vấn ngắn (15 phút).</li>
        <li>Hội đồng duyệt (mentor + founder liaison).</li>
        <li>Thông báo kết quả trong 7 ngày.</li>
      </ol>
      <p>Quy trình minh bạch, kết quả công khai (không công khai thông tin cá nhân).</p>
    </section>
    <section class="content-section">
      <h2>@nai/scholarship</h2>
      <p>Hệ thống học bổng dùng package <code>@nai/scholarship</code> với 7 exports chính. Interface học bổng đang được build thêm trong Sprint 3-4.</p>
    </section>
    <section class="cta-section">
      <a href="/bat-dau" class="edu-btn edu-btn-primary">Bắt đầu học →</a>
    </section>
  </main>
</AcademyLayout>
