---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Học bổng';
const description = 'Học bổng, tài trợ, hỗ trợ — quy trình xét duyệt minh bạch.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="hoc-bong">
  <main class="edu-page">
    <section class="hero">
      <h1>Học bổng</h1>
      <p>Học bổng, tài trợ, hỗ trợ — quy trình xét duyệt minh bạch.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
