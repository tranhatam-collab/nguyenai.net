---
import AcademyLayout from '../layouts/AcademyLayout.astro';
---

<AcademyLayout title="404 — Không tìm thấy trang / Page Not Found" description="Trang bạn tìm không tồn tại.">
  <div class="academy-container flex flex-col items-center justify-center min-h-[60vh] text-center py-20">
    <div class="text-6xl font-bold text-academy-accent mb-4">404</div>
    <h1 class="text-2xl font-semibold mb-2">Không tìm thấy trang</h1>
    <p class="text-gray-600 mb-2">Page not found</p>
    <p class="text-gray-500 mb-8">Trang bạn tìm không tồn tại hoặc đã được di chuyển.<br />The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="academy-btn">← Về trang chủ / Back to Home</a>
  </div>
</AcademyLayout>
