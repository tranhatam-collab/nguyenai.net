---
import AcademyLayout from '../layouts/AcademyLayout.astro';
import CertBadge from '../components/CertBadge.astro';
---

<AcademyLayout
  title="Verify Certificate"
  description="Verify a Nguyen AI Academy certificate by ID."
  activeNav="certification"
>
  <section class="academy-container py-12 max-w-2xl" aria-label="Form xác minh chứng chỉ">
    <h1 class="text-3xl font-bold text-academy-text mb-3">Xác minh chứng chỉ</h1>
    <p class="text-academy-muted mb-8">
      Nhập ID chứng chỉ (*certificate ID*) để kiểm tra tính hợp lệ.
    </p>

    <!-- Verify form -->
    <div class="academy-card p-8 mb-8">
      <form id="verify-form" class="space-y-4">
        <div>
          <label for="cert-id" class="block text-sm font-semibold text-academy-text mb-2">
            Certificate ID
          </label>
          <input
            type="text"
            id="cert-id"
            name="id"
            placeholder="VD: NAI-Academy-XXXX-XXXX"
            class="w-full px-4 py-3 rounded-lg border border-academy-border bg-academy-bg text-academy-text focus:outline-none focus:ring-2 focus:ring-academy-accent focus:border-transparent"
            required
          />
        </div>

        <button type="submit" class="academy-btn academy-btn-primary w-full">
          Xác minh
        </button>
      </form>

      <!-- Result -->
      <div id="verify-result" class="hidden mt-6">
        <!-- Populated by JS -->
      </div>
    </div>

    <!-- Info -->
    <div class="text-sm text-academy-muted space-y-2">
      <p>
        <strong class="text-academy-text">Lưu ý:</strong> Đây là hệ thống placeholder. API xác minh đầy đủ sẽ hoạt động sau khi triển khai.
      </p>
      <p>
        <strong class="text-academy-text">Note:</strong> This is a placeholder system. The full verification API will be available after deployment.
      </p>
    </div>
  </section>
</AcademyLayout>

<script>
  const form = document.getElementById('verify-form') as HTMLFormElement | null;
  const result = document.getElementById('verify-result');

  // SEC-P0-5: Never use innerHTML with API data — use textContent and
  // DOM construction so certificate fields are treated as text, not HTML.
  // Previously the API response was interpolated into innerHTML, allowing
  // XSS via a malicious certificate holder name / id / track title.
  function setText(el: HTMLElement, text: string): void {
    el.textContent = text;
  }

  function clearResult(): void {
    if (!result) return;
    while (result.firstChild) result.removeChild(result.firstChild);
  }

  function showLoading(): void {
    if (!result) return;
    clearResult();
    const p = document.createElement('p');
    p.className = 'text-sm text-academy-muted';
    p.textContent = 'Đang xác minh...';
    result.appendChild(p);
  }

  function showValid(cert: { id?: string; holder?: string; trackTitle?: string; issuedDate?: string }): void {
    if (!result) return;
    clearResult();
    const wrap = document.createElement('div');
    wrap.className = 'border border-green-200 bg-green-50 rounded-lg p-5';

    const head = document.createElement('div');
    head.className = 'flex items-center gap-2 mb-3';
    const icon = document.createElement('span');
    icon.className = 'text-green-600 text-xl';
    icon.textContent = '✓';
    const label = document.createElement('span');
    label.className = 'font-semibold text-green-800';
    label.textContent = 'Chứng chỉ hợp lệ';
    head.appendChild(icon);
    head.appendChild(label);
    wrap.appendChild(head);

    const dl = document.createElement('dl');
    dl.className = 'space-y-1 text-sm';
    const rows: Array<[string, string]> = [
      ['ID', String(cert.id ?? '')],
      ['Holder', String(cert.holder ?? '')],
      ['Track', String(cert.trackTitle ?? '')],
      ['Issued', String(cert.issuedDate ?? '')],
    ];
    for (const [dt, dd] of rows) {
      const row = document.createElement('div');
      const dtEl = document.createElement('dt');
      dtEl.className = 'inline font-medium text-gray-700';
      dtEl.textContent = `${dt}: `;
      const ddEl = document.createElement('dd');
      ddEl.className = 'inline text-gray-600';
      ddEl.textContent = dd;
      row.appendChild(dtEl);
      row.appendChild(ddEl);
      dl.appendChild(row);
    }
    wrap.appendChild(dl);
    result.appendChild(wrap);
  }

  function showInvalid(id: string): void {
    if (!result) return;
    clearResult();
    const wrap = document.createElement('div');
    wrap.className = 'border border-red-200 bg-red-50 rounded-lg p-5';

    const head = document.createElement('div');
    head.className = 'flex items-center gap-2';
    const icon = document.createElement('span');
    icon.className = 'text-red-600 text-xl';
    icon.textContent = '✗';
    const label = document.createElement('span');
    label.className = 'font-semibold text-red-800';
    label.textContent = 'Không tìm thấy chứng chỉ';
    head.appendChild(icon);
    head.appendChild(label);
    wrap.appendChild(head);

    const p = document.createElement('p');
    p.className = 'text-sm text-red-600 mt-2';
    // textContent — id is treated as text, never parsed as HTML
    p.textContent = `ID "${id}" không hợp lệ hoặc không tồn tại.`;
    wrap.appendChild(p);
    result.appendChild(wrap);
  }

  function showError(): void {
    if (!result) return;
    clearResult();
    const p = document.createElement('p');
    p.className = 'text-sm text-red-600';
    p.textContent = 'Lỗi xác minh. Vui lòng thử lại.';
    result.appendChild(p);
  }

  if (form && result) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const id = String(formData.get('id') ?? '');

      showLoading();

      try {
        const res = await fetch(`/api/verify?id=${encodeURIComponent(id)}`);
        const data = await res.json();

        if (data.valid && data.certificate) {
          showValid(data.certificate);
        } else {
          showInvalid(id);
        }
      } catch {
        showError();
      }
    });
  }
</script>
