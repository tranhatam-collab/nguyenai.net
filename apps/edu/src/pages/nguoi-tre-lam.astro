---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Người Trẻ Làm';
const description = 'Cộng đồng hành động: học thật, làm thật, sống có trách nhiệm.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="nguoi-tre-lam">
  <main class="edu-page">
    <section class="hero">
      <h1>Người Trẻ Làm</h1>
      <p>Cộng đồng hành động: học thật, làm thật, sống có trách nhiệm.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
