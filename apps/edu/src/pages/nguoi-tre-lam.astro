---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Người Trẻ Làm';
const description = 'Cộng đồng hành động: học thật, làm thật, sống có trách nhiệm.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="nguoi-tre-lam">
  <main class="edu-page">
    <section class="hero">
      <h1>Người Trẻ Làm</h1>
      <p>Cộng đồng hành động: học thật, làm thật, sống có trách nhiệm.</p>
    </section>
    <section class="content-section">
      <h2>Người Trẻ Làm là gì?</h2>
      <p>Người Trẻ Làm là cộng đồng người trẻ hành động — không chỉ học lý thuyết, mà làm ra sản phẩm thật, giải quyết vấn đề thật, tạo giá trị thật cho cộng đồng.</p>
      <p>Chương trình thuộc Tuổi Trẻ Tương Lai — công nghệ tới đời sống.</p>
    </section>
    <section class="content-section">
      <h2>3 giá trị cốt lõi</h2>
      <ul class="values-list">
        <li><strong>Học thật</strong> — không học vẹt, không học để thi. Học để làm được việc.</li>
        <li><strong>Làm thật</strong> — mỗi bài học có sản phẩm. Không sản phẩm = chưa hoàn thành.</li>
        <li><strong>Sống có trách nhiệm</strong> — riêng tư mặc định, đồng ý rõ ràng, minh bạch về AI.</li>
      </ul>
    </section>
    <section class="content-section">
      <h2>5 cấp học</h2>
      <ol class="levels-list">
        <li><strong>Cấp 0 — Khởi động</strong>: 4 bài nền, đánh giá đầu vào, bản đồ 90 ngày.</li>
        <li><strong>Cấp 1 — Trụ cột</strong>: 4 trụ cột (AI Office, Content, Code, Founder).</li>
        <li><strong>Cấp 2 — Chuyên sâu</strong>: chọn track, dự án thật.</li>
        <li><strong>Cấp 3 — Dẫn dắt</strong>: mentor người mới, dẫn xưởng.</li>
        <li><strong>Cấp 4 — Chuyên gia</strong>: đóng góp chuẩn giáo trình, hội đồng duyệt.</li>
      </ol>
    </section>
    <section class="cta-section">
      <a href="/bat-dau" class="edu-btn edu-btn-primary">Bắt đầu ngay →</a>
      <a href="/tuoi-tre-tuong-lai" class="edu-btn edu-btn-secondary">Về Tuổi Trẻ Tương Lai</a>
    </section>
  </main>
</AcademyLayout>
