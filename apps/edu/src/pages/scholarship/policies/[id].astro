---
import AcademyLayout from '../../../layouts/AcademyLayout.astro';

export function getStaticPaths() {
  const ids = ['01', '02', '03', '04', '05', '06', '07', '08', '09', '10', '11', '12'];
  return ids.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;

const policyMap: Record<string, { title: string; file: string }> = {
  '01': { title: 'Chính sách học bổng', file: '01_SCHOLARSHIP_POLICY.md' },
  '02': { title: 'Tiêu chí và quy trình nộp đơn', file: '02_APPLICATION_CRITERIA.md' },
  '03': { title: 'Quy trình kiểm duyệt nội dung', file: '03_MODERATION_POLICY.md' },
  '04': { title: 'Quyền riêng tư và dữ liệu', file: '04_PRIVACY_AND_DATA.md' },
  '05': { title: 'Hội đồng đánh giá (Council)', file: '05_COUNCIL_GOVERNANCE.md' },
  '06': { title: 'Quy trình tài trợ và đầu tư', file: '06_SPONSORSHIP_POLICY.md' },
  '07': { title: 'Quyền lợi học bổng', file: '07_ENTITLEMENT_RIGHTS.md' },
  '08': { title: 'Quy trình khiếu nại và kháng cáo', file: '08_APPEAL_PROCESS.md' },
  '09': { title: 'Chính sách bảo mật và an ninh', file: '09_SECURITY_POLICY.md' },
  '10': { title: 'Chính sách giữ dữ liệu và xóa', file: '10_DATA_RETENTION.md' },
  '11': { title: 'Điều khoản sử dụng', file: '11_TERMS_OF_SERVICE.md' },
  '12': { title: 'Chính sách thay đổi và phiên bản', file: '12_CHANGE_POLICY.md' },
};

const policy = id ? policyMap[id] : null;
---

<AcademyLayout
  title={policy ? `${policy.title} — Nguyễn AI` : 'Policy not found'}
  description={policy?.title || 'Policy not found'}
  activeNav="scholarship"
>
  <section class="academy-container py-8 max-w-3xl" aria-label="Scholarship policy">
    {policy ? (
      <>
        <a href="/scholarship/policies" class="text-blue-600 text-sm mb-4 inline-block">← Tất cả chính sách</a>
        <h1 class="text-3xl font-bold mb-2">#{id} — {policy.title}</h1>
        <p class="text-gray-600 mb-8">Phiên bản 1.0.0 — Hiệu lực 2026-07-04 — BINDING</p>

        <div class="prose max-w-none">
          <p class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
            Đây là tài liệu chính thức. Nội dung đầy đủ xem tại file markdown:
            <code class="bg-gray-100 px-2 py-1 rounded">docs/scholarship/policies/{policy.file}</code>
          </p>

          <h2>Tóm tắt</h2>
          <p>
            Policy #{id} — {policy.title}. Chi tiết đầy đủ trong file markdown.
            Mọi thay đổi phải tuân thủ Policy #12 (Chính sách thay đổi và phiên bản).
          </p>

          <h2>Liên kết</h2>
          <ul>
            <li><a href="/scholarship/policies">Tất cả 12 chính sách</a></li>
            <li><a href="/scholarship/changelog">Changelog</a></li>
            <li><a href="/scholarship/acceptance-log">Acceptance Log</a></li>
          </ul>
        </div>
      </>
    ) : (
      <div class="text-center py-16">
        <h1 class="text-2xl font-bold mb-4">Policy not found</h1>
        <a href="/scholarship/policies" class="text-blue-600">← Quay lại danh sách</a>
      </div>
    )}
  </section>
</AcademyLayout>
