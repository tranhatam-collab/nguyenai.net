---
import AcademyLayout from '../layouts/AcademyLayout.astro';
import AssessmentForm from '../components/AssessmentForm.astro';

const title = 'Đánh giá đầu vào';
const description = 'Đánh giá năng lực và hướng nghề — nhận bản đồ 90 ngày.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="danh-gia">
  <main class="edu-page">
    <section class="hero" aria-label="Đánh giá đầu vào">
      <h1>Đánh giá đầu vào</h1>
      <p>10 câu hỏi để hiểu bạn — mất khoảng 5 phút. Kết quả tạo bản đồ 90 ngày.</p>
    </section>
    <AssessmentForm />
  </main>
</AcademyLayout>
