---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Đánh giá đầu vào';
const description = 'Đánh giá năng lực và hướng nghề — nhận bản đồ 90 ngày.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="danh-gia">
  <main class="edu-page">
    <section class="hero">
      <h1>Đánh giá đầu vào</h1>
      <p>Đánh giá năng lực và hướng nghề — nhận bản đồ 90 ngày.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
