---
import AcademyLayout from '../layouts/AcademyLayout.astro';
import { scholarshipConfig, programs } from '../data/programs';

const formatVND = (n: number) => n.toLocaleString('vi-VN') + '₫';
const formatUSD = (n: number) => '$' + n.toLocaleString('en-US');
---

<AcademyLayout
  title="Học bổng 1.000 xuất/năm"
  description="Nguyen AI Academy cam kết 1.000 học bổng AI mỗi năm — ưu tiên dòng họ Nguyễn tại Việt Nam. 99 học bổng/program, nhóm 11 người, tuổi 20–49."
  activeNav="scholarship"
>
  <section class="academy-container py-12">
    <!-- Hero -->
    <div class="max-w-4xl mb-12">
      <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-green-600 bg-green-50 rounded-full">
        🎓 Học bổng Nguyen AI Academy
      </div>
      <h1 class="text-3xl md:text-5xl font-bold text-academy-text mb-4">
        1.000 học bổng AI mỗi năm
      </h1>
      <p class="text-xl text-academy-muted">
        Cam kết trao 1.000 học bổng certification AI hàng năm — ưu tiên dòng họ Nguyễn tại Việt Nam.
      </p>
      <p class="text-lg text-academy-muted mt-2">
        1,000 AI certification scholarships annually — prioritizing the Nguyen family in Vietnam.
      </p>
    </div>

    <!-- Key numbers -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <div class="academy-card p-6 text-center">
        <div class="text-4xl font-bold text-academy-accent">1.000</div>
        <div class="text-sm text-academy-muted mt-1">Học bổng/năm</div>
      </div>
      <div class="academy-card p-6 text-center">
        <div class="text-4xl font-bold text-academy-accent">9</div>
        <div class="text-sm text-academy-muted mt-1">Programs</div>
      </div>
      <div class="academy-card p-6 text-center">
        <div class="text-4xl font-bold text-academy-accent">99</div>
        <div class="text-sm text-academy-muted mt-1">Học bổng/program</div>
      </div>
      <div class="academy-card p-6 text-center">
        <div class="text-4xl font-bold text-academy-accent">20–49</div>
        <div class="text-sm text-academy-muted mt-1">Tuổi</div>
      </div>
    </div>

    <!-- Allocation -->
    <div class="academy-card p-8 mb-8">
      <h2 class="text-xl font-bold text-academy-text mb-2">Phân bổ học bổng</h2>
      <p class="text-academy-muted text-sm mb-6">Scholarship allocation — ưu tiên họ Nguyễn Việt Nam</p>
      <div class="space-y-4">
        {scholarshipConfig.allocation.map((a) => (
          <div>
            <div class="flex justify-between mb-1">
              <span class="text-sm font-semibold text-academy-text">{a.group}</span>
              <span class="text-sm text-academy-muted">{a.count} xuất ({a.percent}%)</span>
            </div>
            <div class="w-full bg-academy-bg rounded-full h-3">
              <div class="bg-academy-accent h-3 rounded-full" style={`width: ${a.percent}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Group structure -->
    <div class="academy-card p-8 mb-8">
      <h2 class="text-xl font-bold text-academy-text mb-2">Cấu trúc nhóm 11 người</h2>
      <p class="text-academy-muted text-sm mb-6">Mỗi nhóm 11 người nhận tất cả 9 programs (full bundle)</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="p-4 bg-academy-bg rounded-lg text-center">
          <div class="text-3xl font-bold text-academy-accent">1</div>
          <div class="text-sm font-semibold text-academy-text">Team Lead</div>
          <div class="text-xs text-academy-muted">Cohort + mentor</div>
        </div>
        <div class="p-4 bg-academy-bg rounded-lg text-center">
          <div class="text-3xl font-bold text-academy-accent">8</div>
          <div class="text-sm font-semibold text-academy-text">Core Member</div>
          <div class="text-xs text-academy-muted">Self-paced + cohort</div>
        </div>
        <div class="p-4 bg-academy-bg rounded-lg text-center">
          <div class="text-3xl font-bold text-academy-accent">2</div>
          <div class="text-sm font-semibold text-academy-text">Observer</div>
          <div class="text-xs text-academy-muted">Self-paced</div>
        </div>
      </div>
      <p class="mt-4 text-sm text-academy-muted">
        Nhóm học cùng nhau, làm dự án cùng, nhận certificate cùng.
        <span class="block">Each group learns together, builds projects together, certifies together.</span>
      </p>
    </div>

    <!-- Batches -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-academy-text mb-4">Lịch phát học bổng</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {scholarshipConfig.batches.map((batch) => (
          <div class="academy-card p-6">
            <h3 class="font-bold text-academy-text">{batch.name}</h3>
            <p class="text-sm text-academy-muted">{batch.period}</p>
            <div class="text-2xl font-bold text-academy-accent mt-3">{batch.slots}</div>
            <p class="text-xs text-academy-muted">học bổng</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Eligibility -->
    <div class="academy-card p-8 mb-8">
      <h2 class="text-xl font-bold text-academy-text mb-4">Tiêu chí</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { label: 'Họ', value: 'Nguyễn (ưu tiên) hoặc tên khác' },
          { label: 'Quốc tịch', value: 'Việt Nam (ưu tiên) hoặc diaspora' },
          { label: 'Tuổi', value: '20–49' },
          { label: 'Trình độ', value: 'Tốt nghiệp THPT trở lên' },
          { label: 'Cam kết', value: 'Hoàn thành 9 programs trong 12 tháng' },
          { label: 'Đóng góp', value: 'Chia sẻ kiến thức, mentor người sau' },
          { label: 'Không yêu cầu', value: 'Không yêu cầu kinh nghiệm AI' },
          { label: 'Không yêu cầu', value: 'Không yêu cầu tiếng Anh' },
        ].map((c) => (
          <div class="flex items-start gap-3">
            <span class="text-academy-accent mt-0.5">✓</span>
            <div>
              <span class="text-sm font-semibold text-academy-text">{c.label}:</span>
              <span class="text-sm text-academy-muted"> {c.value}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Programs covered -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-academy-text mb-4">9 Programs được học bổng bao phủ</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        {programs.map((p) => (
          <a href={`/programs/${p.slug}`} class="academy-card p-4 card-hover">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{p.icon}</span>
              <div>
                <div class="text-xs text-academy-muted font-mono">{p.code}</div>
                <div class="font-semibold text-academy-text text-sm">{p.title.vi}</div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Fund info -->
    <div class="academy-card p-8 mb-8 border-2 border-academy-accent/20">
      <h2 class="text-xl font-bold text-academy-text mb-2">Quỹ học bổng</h2>
      <p class="text-academy-muted text-sm mb-6">
        Tổng quỹ: <strong class="text-academy-accent">{formatVND(scholarshipConfig.fund.annualTargetVND)}</strong> (~{formatUSD(scholarshipConfig.fund.annualTargetUSD)})/năm
      </p>
      <p class="text-sm text-academy-muted mb-4">
        Quỹ học bổng được quản lý bởi invest.nguyenai.net — kêu gọi từ Founder, nhà đầu tư, nhà tài trợ doanh nghiệp và đóng góp cộng đồng.
      </p>
      <a href="https://invest.nguyenai.net/scholarship" class="inline-block academy-btn academy-btn-primary text-sm">
        Xem chiến lược quỹ tại invest.nguyenai.net →
      </a>
    </div>

    <!-- CTA -->
    <div class="text-center py-12">
      <a href="/programs" class="inline-block academy-btn academy-btn-primary text-lg px-8 py-3">
        Xem 9 programs →
      </a>
      <p class="mt-3 text-sm text-academy-muted">Đăng ký học bổng mở khi Đợt 1 bắt đầu (Tết Nguyễn)</p>
    </div>
  </section>
</AcademyLayout>
