---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Dự án';
const description = 'Sàn dự án thật — đủ 9 trường, có người chịu trách nhiệm, có biên nhận.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="du-an">
  <main class="edu-page">
    <section class="hero">
      <h1>Dự án</h1>
      <p>Sàn dự án thật — đủ 9 trường, có người chịu trách nhiệm, có biên nhận.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
