---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Khởi nghiệp';
const description = 'Vườn ươm khởi nghiệp — vấn đề thật, khách thật, dòng tiền đầu tiên.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="khoi-nghiep">
  <main class="edu-page">
    <section class="hero" aria-label="Khởi nghiệp">
      <h1>Khởi nghiệp</h1>
      <p>Vườn ươm khởi nghiệp — vấn đề thật, khách thật, dòng tiền đầu tiên.</p>
    </section>
    <section class="content-section" aria-label="3 điều kiện khởi nghiệp">
      <h2>3 điều kiện khởi nghiệp</h2>
      <ol class="conditions-list">
        <li><strong>Vấn đề thật</strong> — có người thật đang gặp, đang chịu đựng.</li>
        <li><strong>Khách thật</strong> — có người sẵn sàng trả tiền (hoặc đổi giá trị).</li>
        <li><strong>Dòng tiền đầu tiên</strong> — thu được tiền đầu tiên trong 90 ngày.</li>
      </ol>
    </section>
    <section class="content-section" aria-label="3 điều kiện khởi nghiệp">
      <h2>Quy trình vườn ươm</h2>
      <ul class="process-list">
        <li>Cấp 1: Học nền tảng + tạo sản phẩm mẫu.</li>
        <li>Cấp 2: Chọn vấn đề, tìm khách, thử nghiệm giải pháp.</li>
        <li>Cấp 3: Đóng gói sản phẩm, bán đầu tiên, thu dòng tiền.</li>
        <li>Cấp 4: Scale, mentor người mới, đóng góp hệ sinh thái.</li>
      </ul>
    </section>
    <section class="content-section" aria-label="3 điều kiện khởi nghiệp">
      <h2>Hỗ trợ</h2>
      <p>Mentor khởi nghiệp, kết nối doanh nghiệp đối tác, không cấp vốn trực tiếp — tập trung vào <strong>khách thật, dòng tiền thật</strong>.</p>
    </section>
    <section class="cta-section" aria-label="Cta Section">
      <a href="/bat-dau" class="edu-btn edu-btn-primary">Bắt đầu học →</a>
      <a href="/doanh-nghiep" class="edu-btn edu-btn-secondary">Doanh nghiệp đối tác</a>
    </section>
  </main>
</AcademyLayout>
