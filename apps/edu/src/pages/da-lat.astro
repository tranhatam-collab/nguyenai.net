---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Đà Lạt';
const description = 'Chương trình Đà Lạt — sống và làm 7 ngày, dự án địa phương thật.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="da-lat">
  <main class="edu-page">
    <section class="hero">
      <h1>Đà Lạt</h1>
      <p>Chương trình Đà Lạt — sống và làm 7 ngày, dự án địa phương thật.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
