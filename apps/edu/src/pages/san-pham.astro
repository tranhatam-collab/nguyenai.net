---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Sản phẩm';
const description = 'Sản phẩm nhỏ đủ thật — không sản phẩm = chưa hoàn thành.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="san-pham">
  <main class="edu-page">
    <section class="hero">
      <h1>Sản phẩm</h1>
      <p>Sản phẩm nhỏ đủ thật — không sản phẩm = chưa hoàn thành.</p>
    </section>
    <section class="content-section">
      <h2>Quy tắc sản phẩm</h2>
      <ul class="rules-list">
        <li>Mỗi bài học có 1 sản phẩm yêu cầu.</li>
        <li>Sản phẩm phải <strong>đủ thật</strong> — dùng được, không phải demo giả.</li>
        <li>Sản phẩm nhỏ cũng được — miễn là thật.</li>
        <li>Không có sản phẩm = bài học chưa hoàn thành.</li>
        <li>Sản phẩm được mentor duyệt theo <a href="/bai-hoc" class="edu-link">rubric 4 mức</a>.</li>
      </ul>
    </section>
    <section class="content-section">
      <h2>Ví dụ sản phẩm</h2>
      <ul class="examples-list">
        <li>1 email giới thiệu bản thân (Cấp 0)</li>
        <li>1 tài liệu Google Docs chia sẻ quy trình (Cấp 1)</li>
        <li>1 command pack cho Máy Tính AI Nguyễn (Cấp 1)</li>
        <li>1 bài viết content chuẩn thương hiệu (Cấp 1)</li>
        <li>1 script tự động hóa (Cấp 1)</li>
        <li>1 pitch deck 5 slide (Cấp 1)</li>
      </ul>
    </section>
    <section class="cta-section">
      <a href="/nhiem-vu" class="edu-btn edu-btn-primary">Nộp sản phẩm →</a>
    </section>
  </main>
</AcademyLayout>
