---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Lộ trình học';
const description = '5 cấp học từ Khởi động đến Chuyên Gia — chọn lộ trình phù hợp.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="lo-trinh">
  <main class="edu-page">
    <section class="hero">
      <h1>Lộ trình học</h1>
      <p>5 cấp học từ Khởi động đến Chuyên Gia — chọn lộ trình phù hợp.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
