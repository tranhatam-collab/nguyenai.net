---
import AcademyLayout from '../layouts/AcademyLayout.astro';

const title = 'Tác động';
const description = 'Báo cáo tác động 90 ngày — số thật, có bằng chứng.';
const locale = 'vi';
---

<AcademyLayout title={title} description={description} locale={locale} activeNav="tac-dong">
  <main class="edu-page">
    <section class="hero">
      <h1>Tác động</h1>
      <p>Báo cáo tác động 90 ngày — số thật, có bằng chứng.</p>
    </section>
    <section class="content-placeholder">
      <p>Nội dung đang được xây dựng theo Kế hoạch V2 — Sprint 1 route skeleton.</p>
    </section>
  </main>
</AcademyLayout>
