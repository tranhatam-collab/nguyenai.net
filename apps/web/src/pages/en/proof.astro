---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicClaimBlock from '../../components/PublicClaimBlock.astro';

const title = 'Proof of Independence — Nguyen AI';
const description = 'Evidence of full operational independence. Every claim has a verification receipt.';
---
<BaseLayout locale="en" routeKey="proof" title={title} description={description}>
  <main class="proof-page">
    <section class="hero">
      <h1>Proof of independent operation</h1>
      <p>Nguyen AI runs on its own backend, fully self-sufficient. Every claim below has a verification receipt.</p>
    </section>
    <section class="claims">
      <h2>Public claims</h2>
      <PublicClaimBlock claimId="independent-backend" text="Nguyen AI owns its own backend, fully self-sufficient." grade="R1" locale="en" evidenceUrl="/en/receipts/" />
      <PublicClaimBlock claimId="no-gen1-dependency" text="No legacy system dependency in default operation." grade="R1" locale="en" evidenceUrl="/en/receipts/" />
      <PublicClaimBlock claimId="evidence-receipts" text="Every important command has a verification receipt." grade="R1" locale="en" evidenceUrl="/en/receipts/" />
      <PublicClaimBlock claimId="bilingual" text="Bilingual Vietnamese — English interface, no language mixing." grade="R1" locale="en" />
      <PublicClaimBlock claimId="heritage-not-bloodline" text="Heritage and genealogy are important Super Apps, not the whole product." grade="R2" locale="en" />
      <PublicClaimBlock claimId="no-profit-promise" text="Financial tools support analysis only, not licensed advisory services." grade="R2" locale="en" />
    </section>
    <section class="charter">
      <h2>Charter sentence</h2>
      <blockquote>Machines work — humans sign — everything has a receipt.</blockquote>
    </section>
  </main>
</BaseLayout>

<style>
  .proof-page { max-width: 768px; margin: 0 auto; padding: 2rem 1rem; }
  .hero h1 { font-size: 1.875rem; font-weight: 700; margin-bottom: 0.5rem; }
  .hero p { color: #4b5563; line-height: 1.6; }
  .claims h2, .charter h2 { font-size: 1.25rem; font-weight: 600; margin: 2rem 0 1rem; }
  .charter blockquote { font-size: 1.125rem; font-style: italic; color: #7c3aed; border-left: 3px solid #7c3aed; padding-left: 1rem; }
</style>
