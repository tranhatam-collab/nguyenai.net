---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RGradeBadge from '../../components/RGradeBadge.astro';

const title = 'Capability Demo — Nguyen AI';
const description = 'Live capability demo: call API, see results, check receipts.';
---
<BaseLayout locale="en" routeKey="demo" title={title} description={description}>
  <main class="demo-page">
    <section class="hero" aria-label="Hero section">
      <h1>Capability demo</h1>
      <p>Live capability demo. Call the API, see results, check receipts.</p>
    </section>
    <section class="demos" aria-label="List of API demos">
      <div class="demo-card">
        <h3>POST /v1/chat <RGradeBadge grade="R1" locale="en" /></h3>
        <p>Call chat API with own model. Response from direct provider (OpenAI/Anthropic/Google), no Gen1 proxy.</p>
        <pre><code>curl -X POST https://api.nguyenai.net/v1/chat \
  -H "Content-Type: application/json" \
  -d '&#123;"model":"auto-route","messages":[&#123;"role":"user","content":"Hello"&#125;]&#125;'</code></pre>
      </div>
      <div class="demo-card">
        <h3>GET /v1/gen1/models <RGradeBadge grade="R0" locale="en" /></h3>
        <p>Gen1 route disabled by default. Returns 404 when LEGACY_BRIDGE_ENABLED is not set.</p>
        <pre><code>curl https://api.nguyenai.net/v1/gen1/models
# 404 &#123;"error":"legacy_bridge_disabled"&#125;</code></pre>
      </div>
      <div class="demo-card">
        <h3>GET /v1/incidents <RGradeBadge grade="R0" locale="en" /></h3>
        <p>Incident management route mounted. Returns incident list.</p>
        <pre><code>curl https://api.nguyenai.net/v1/incidents</code></pre>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .demo-page { max-width: 768px; margin: 0 auto; padding: 2rem 1rem; }
  .hero h1 { font-size: 1.875rem; font-weight: 700; margin-bottom: 0.5rem; }
  .hero p { color: #4b5563; line-height: 1.6; }
  .demos { margin-top: 2rem; display: grid; gap: 1.5rem; }
  .demo-card { border: 1px solid #e5e7eb; border-radius: 0.5rem; padding: 1.25rem; }
  .demo-card h3 { display: flex; align-items: center; gap: 0.5rem; font-size: 1.125rem; font-weight: 600; margin: 0 0 0.5rem; }
  .demo-card p { color: #4b5563; font-size: 0.875rem; line-height: 1.5; margin: 0 0 0.75rem; }
  .demo-card pre { background: #1f2937; color: #e5e7eb; padding: 0.75rem; border-radius: 0.375rem; overflow-x: auto; font-size: 0.8125rem; }
  .demo-card code { font-family: 'JetBrains Mono', monospace; }
</style>
