---
/**
 * /verify — chuyển hướng client cho CTA email cũ
 * Token xác minh email là bí mật dùng một lần (không phải ID chứng chỉ công khai).
 * Xóa token khỏi URL ngay; không đặt token vào tiêu đề/OG/thống kê.
 */
---
<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="referrer" content="no-referrer" />
    <link rel="alternate" hreflang="vi" href="https://nguyenai.net/verify" />
    <link rel="alternate" hreflang="en" href="https://nguyenai.net/en/verify" />
    <link rel="alternate" hreflang="x-default" href="https://nguyenai.net/verify" />
    <link rel="canonical" href="https://nguyenai.net/verify" />
    <title>Đang chuyển hướng xác minh…</title>
    <script>
      (function () {
        const params = new URLSearchParams(window.location.search);
        const token = params.get('token');
        // Xóa bí mật khỏi thanh địa chỉ trước khi chuyển hướng
        try {
          params.delete('token');
          const clean = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
          window.history.replaceState({}, '', clean);
        } catch (_) {}
        const dest = token
          ? 'https://auth.nguyenai.net/verify?token=' + encodeURIComponent(token)
          : 'https://auth.nguyenai.net/auth';
        window.location.replace(dest);
      })();
    </script>
  </head>
  <body>
    <p>Đang chuyển đến trang xác minh email…</p>
    <p><a href="https://auth.nguyenai.net/auth">Tiếp tục</a></p>
    <p><a href="/en/verify" class="language-switch">English</a></p>
  </body>
</html>
