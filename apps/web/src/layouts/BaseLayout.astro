---
import '../styles/global.css';
import { absoluteUrl, routeFor, routes, site, type Locale, type RouteKey } from '../data/site';

export interface Props {
  locale: Locale;
  routeKey: RouteKey;
  title: string;
  description: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  ogImage?: string;
}

const { locale, routeKey, title, description, jsonLd, ogImage = '/og-default.png' } = Astro.props;
const currentPath = routeFor(routeKey, locale);
const alternateLocale = locale === 'vi' ? 'en' : 'vi';
const langLabel = locale === 'vi' ? 'English' : 'Tiếng Việt';
const navItems = routes.filter((route) => ['ai-computer', 'super-apps', 'agents', 'plans', 'about', 'contact'].includes(route.key));
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name.en,
  alternateName: site.name.vi,
  url: site.url,
  slogan: site.tagline[locale]
};
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name[locale],
  url: site.url,
  inLanguage: locale === 'vi' ? 'vi-VN' : 'en'
};
const productJsonLd = routeKey === 'home' ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Nguyen AI Computer',
  description: site.heroDescription[locale],
  brand: { '@type': 'Brand', name: site.name[locale] },
  url: site.url,
  category: 'AI Computer',
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'VND',
    lowPrice: '0',
    highPrice: '7999000',
    offerCount: 9
  }
} : undefined;
const graph = [
  organizationJsonLd,
  websiteJsonLd,
  ...(productJsonLd ? [productJsonLd] : []),
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])
];
---
<!doctype html>
<html lang={locale === 'vi' ? 'vi' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl(currentPath)} />
    <link rel="alternate" hreflang="vi-VN" href={absoluteUrl(routeFor(routeKey, 'vi'))} />
    <link rel="alternate" hreflang="en" href={absoluteUrl(routeFor(routeKey, 'en'))} />
    <link rel="alternate" hreflang="x-default" href={absoluteUrl(routeFor(routeKey, 'vi'))} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nguyen AI" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={absoluteUrl(currentPath)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#7A2212" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/icon-48x48.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/icon-64x64.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180x180.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:image" content={absoluteUrl(ogImage)} />
    <meta name="twitter:image" content={absoluteUrl(ogImage)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(graph)} />
  </head>
  <body>
    <a class="skip-link" href="#main">{locale === 'vi' ? 'Bỏ qua điều hướng' : 'Skip to content'}</a>
    <header class="site-header">
      <a class="brand" href={routeFor('home', locale)} aria-label={site.name[locale]}>
        <img class="brand-logo" src="/logo-mark-mono-white.svg" alt="" width="36" height="36" />
        <span>
          <strong>{site.name[locale]}</strong>
          <small>{locale === 'vi' ? 'Nguyen AI Computer' : 'Nguyen AI Computer'}</small>
        </span>
      </a>
      <nav class="main-nav" aria-label={locale === 'vi' ? 'Điều hướng chính' : 'Main navigation'}>
        {navItems.map((item) => <a href={item[locale]}>{locale === 'vi' ? item.labelVi : item.labelEn}</a>)}
      </nav>
      <a class="language-switch" href={routeFor(routeKey, alternateLocale)}>{langLabel}</a>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>{site.name[locale]}</strong>
        <p>{site.tagline[locale]}</p>
      </div>
      <nav aria-label={locale === 'vi' ? 'Điều hướng chân trang' : 'Footer navigation'}>
        <a href={routeFor('trust', locale)}>{locale === 'vi' ? 'Minh chứng' : 'Trust'}</a>
        <a href={routeFor('security', locale)}>{locale === 'vi' ? 'Bảo mật' : 'Security'}</a>
        <a href={routeFor('docs', locale)}>{locale === 'vi' ? 'Tài liệu' : 'Docs'}</a>
        <a href={routeFor('contact', locale)}>{locale === 'vi' ? 'Liên hệ' : 'Contact'}</a>
      </nav>
    </footer>
  </body>
</html>
