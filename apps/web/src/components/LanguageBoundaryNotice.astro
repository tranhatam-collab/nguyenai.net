---
/**
 * LanguageBoundaryNotice — Ghi chú ranh giới ngôn ngữ
 * Displays a notice about the bilingual language policy.
 */
export interface Props {
  locale?: 'vi' | 'en';
}

const { locale = 'vi' } = Astro.props;

const text = locale === 'vi'
  ? 'Trang này song ngữ Việt — Anh. Không trộn ngôn ngữ trong cùng câu. Chuyển ngôn ngữ qua nút góc trên.'
  : 'This page is bilingual Vietnamese — English. No language mixing within a sentence. Switch language via the button in the top corner.';
---

<aside class="language-boundary-notice" role="note">
  <span class="notice-icon" aria-hidden="true">🌐</span>
  <span class="notice-text">{text}</span>
</aside>

<style>
  .language-boundary-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    color: #92400e;
    line-height: 1.4;
  }
  .notice-icon {
    flex-shrink: 0;
  }
</style>
