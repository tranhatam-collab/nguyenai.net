#!/usr/bin/env node
/**
 * FOUNDER LANGUAGE AND CONTENT LOCK AUDIT - SEO Bilingual
 * Checks hreflang tags and canonical URLs.
 * Recognizes layout inheritance: pages using PageShell/BaseLayout
 * automatically inherit hreflang and canonical from the layout.
 */

import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const COLORS = { red: '\x1b[31m', green: '\x1b[32m', yellow: '\x1b[33m', reset: '\x1b[0m' };
let errorsFound = 0;

// Layouts that already include hreflang and canonical
const LAYOUTS_WITH_SEO = ['PageShell', 'BaseLayout', 'AcademyLayout', 'InvestLayout'];

function pageHasLayoutInheritance(content: string): boolean {
  return LAYOUTS_WITH_SEO.some(layout => content.includes(layout));
}

function checkHreflang() {
  console.log('=== Checking hreflang tags ===');
  
  const pagesDir = path.join(__dirname, '..', 'apps', 'web', 'src', 'pages');
  if (!fs.existsSync(pagesDir)) {
    console.log(`${COLORS.yellow}⚠ Pages directory not found${COLORS.reset}`);
    return;
  }
  
  let checked = 0;
  let passed = 0;
  
  function checkPage(filePath: string, pageName: string) {
    const content = fs.readFileSync(filePath, 'utf-8');
    checked++;
    
    // Page has hreflang if it uses a layout that includes hreflang
    if (pageHasLayoutInheritance(content)) {
      passed++;
      return;
    }
    
    // Check for hreflang in the page itself
    if (content.includes('hreflang')) {
      passed++;
    } else {
      console.log(`${COLORS.red}✗ Missing hreflang in: ${pageName}${COLORS.reset}`);
      errorsFound++;
    }
  }
  
  // Check Vietnamese pages
  const viPages = fs.readdirSync(pagesDir).filter(f => f.endsWith('.astro') && !f.startsWith('en.'));
  for (const page of viPages) {
    checkPage(path.join(pagesDir, page), page);
  }
  
  // Check English pages
  const enDir = path.join(pagesDir, 'en');
  if (fs.existsSync(enDir)) {
    const enPages = fs.readdirSync(enDir).filter(f => f.endsWith('.astro'));
    for (const page of enPages) {
      checkPage(path.join(enDir, page), `en/${page}`);
    }
  }
  
  console.log(`${COLORS.green}✓ ${passed}/${checked} pages have hreflang (via layout inheritance or direct)${COLORS.reset}`);
}

function checkCanonical() {
  console.log('\n=== Checking canonical URLs ===');
  
  const pagesDir = path.join(__dirname, '..', 'apps', 'web', 'src', 'pages');
  if (!fs.existsSync(pagesDir)) {
    console.log(`${COLORS.yellow}⚠ Pages directory not found${COLORS.reset}`);
    return;
  }
  
  let checked = 0;
  let passed = 0;
  
  function checkPage(filePath: string, pageName: string) {
    const content = fs.readFileSync(filePath, 'utf-8');
    checked++;
    
    // Page has canonical if it uses a layout that includes canonical
    if (pageHasLayoutInheritance(content)) {
      passed++;
      return;
    }
    
    // Check for canonical in the page itself
    if (content.includes('canonical')) {
      passed++;
    } else {
      console.log(`${COLORS.red}✗ Missing canonical URL in: ${pageName}${COLORS.reset}`);
      errorsFound++;
    }
  }
  
  // Check Vietnamese pages
  const viPages = fs.readdirSync(pagesDir).filter(f => f.endsWith('.astro') && !f.startsWith('en.'));
  for (const page of viPages) {
    checkPage(path.join(pagesDir, page), page);
  }
  
  // Check English pages
  const enDir = path.join(pagesDir, 'en');
  if (fs.existsSync(enDir)) {
    const enPages = fs.readdirSync(enDir).filter(f => f.endsWith('.astro'));
    for (const page of enPages) {
      checkPage(path.join(enDir, page), `en/${page}`);
    }
  }
  
  console.log(`${COLORS.green}✓ ${passed}/${checked} pages have canonical URLs (via layout inheritance or direct)${COLORS.reset}`);
}

// Run all checks
console.log('=== FOUNDER LANGUAGE AND CONTENT LOCK AUDIT - SEO Bilingual ===\n');
checkHreflang();
checkCanonical();

console.log('\n=== AUDIT SUMMARY ===');
if (errorsFound === 0) {
  console.log(`${COLORS.green}✓ No SEO bilingual violations found${COLORS.reset}`);
  process.exit(0);
} else {
  console.log(`${COLORS.red}✗ Found ${errorsFound} SEO bilingual violations${COLORS.reset}`);
  process.exit(1);
}
