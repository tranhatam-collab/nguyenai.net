{
  "schemaVersion": 1,
  "updatedAt": "2026-07-17",
  "productionAccountId": "62d57eaa548617aeecac766e5a1cb98e",
  "authModel": "d1_opaque_session_cookie_hmac",
  "services": {
    "auth": {
      "worker": "nguyenai-auth",
      "directory": "apps/auth",
      "requiredCore": ["AUTH_SECRET"],
      "requiredOAuth": ["GOOGLE_CLIENT_ID", "GOOGLE_CLIENT_SECRET"],
      "emailAnyOf": ["MAIL_GATEWAY_API_KEY", "RESEND_API_KEY"],
      "unusedOrForbidden": ["JWT_SECRET"]
    },
    "api": {
      "worker": "nguyenai-api-gateway",
      "directory": "apps/api",
      "requiredCore": ["AUTH_SECRET", "EVIDENCE_SIGNING_KEY"],
      "emailAnyOf": ["MAIL_GATEWAY_API_KEY", "RESEND_API_KEY"],
      "aiProviderGateway": {
        "urlVar": "AI_PROVIDER_GATEWAY_URL",
        "apiKeySecret": "AI_PROVIDER_API_KEY",
        "owner": "aiagent.iai.one"
      },
      "forbiddenDirectProviderSecrets": ["OPENAI_API_KEY", "ANTHROPIC_API_KEY", "GOOGLE_AI_API_KEY"],
      "commerceAnyCompleteGroup": [
        ["PAY_GATEWAY_API_KEY", "PAY_NAI_HMAC"],
        ["STRIPE_SECRET_KEY", "STRIPE_WEBHOOK_SECRET"],
        ["VNPAY_TMN_CODE", "VNPAY_HASH_SECRET"]
      ],
      "commerceGroupLabels": {
        "PAY_GATEWAY_API_KEY+PAY_NAI_HMAC": "PayOS/VietQR (KASAN JSC merchant of record)",
        "STRIPE_SECRET_KEY+STRIPE_WEBHOOK_SECRET": "Stripe (international, VIET CAN NEW CORP)",
        "VNPAY_TMN_CODE+VNPAY_HASH_SECRET": "VNPay (Vietnam domestic)"
      },
      "commerceNote": "At least ONE complete group must be set for commerce. All three can be set for multi-gateway. Non-secret vars (set in wrangler.jsonc): VNPAY_PAY_URL, VNPAY_RETURN_URL, PAY_GATEWAY_PROVIDER, PAY_GATEWAY_CALLBACK_BASE, PAY_GATEWAY_BASE_URL, PAY_GATEWAY_TENANT_CODE, PAY_GATEWAY_SITE_CODE.",
      "unusedOrForbidden": ["JWT_SECRET"]
    }
  }
}

