import {
  PACKAGE_INFO,
  pushLog,
  logInfo,
  logError,
  logWarn,
  logDebug,
  queryLogs,
  countByLevel,
  getLogRate,
  clearLogs,
  getLogCount,
} from './index.js';

let passed = 0;
let failed = 0;
const steps: string[] = [];

function assert(cond: boolean, msg: string): void {
  if (cond) {
    passed++;
    steps.push(`  \u2713 ${msg}`);
  } else {
    failed++;
    steps.push(`  \u2717 ${msg}`);
    console.error(`  \u2717 ${msg}`);
  }
}

async function main(): Promise<void> {
  clearLogs();

  // Smoke
  assert(PACKAGE_INFO.name === '@nai/loki', 'PACKAGE_INFO.name is @nai/loki');
  assert(PACKAGE_INFO.upstream.startsWith('https://'), 'PACKAGE_INFO.upstream is https URL');

  // ============================================================
  // pushLog + convenience
  // ============================================================

  const log1 = pushLog({ level: 'info', message: 'Server started', labels: { service: 'api' } });
  assert(log1.id.length === 16, 'pushLog generates id');
  assert(log1.level === 'info', 'pushLog sets level');
  assert(log1.message === 'Server started', 'pushLog sets message');
  assert(log1.labels.service === 'api', 'pushLog sets labels');
  assert(log1.timestamp > 0, 'pushLog sets timestamp');

  logInfo('User logged in', { user: 'u1' });
  logError('Database connection failed', { service: 'db' });
  logWarn('Rate limit approaching', { service: 'api' });
  logDebug('Cache miss', { key: 'user:42' });

  assert(getLogCount() === 5, '5 logs after 5 pushes');

  // With tenant_id and trace_id
  pushLog({ level: 'error', message: 'Command failed', tenant_id: 't1', trace_id: 'tr1', span_id: 'sp1' });
  const withTenant = queryLogs({ tenant_id: 't1' });
  assert(withTenant.length === 1, 'queryLogs filters by tenant_id');
  assert(withTenant[0]?.trace_id === 'tr1', 'log has trace_id');

  // ============================================================
  // queryLogs
  // ============================================================

  clearLogs();
  logInfo('Info message 1');
  logInfo('Info message 2');
  logError('Error message 1');
  logWarn('Warn message 1');
  logDebug('Debug message 1');

  // By level
  assert(queryLogs({ level: 'info' }).length === 2, 'queryLogs level=info returns 2');
  assert(queryLogs({ level: 'error' }).length === 1, 'queryLogs level=error returns 1');
  assert(queryLogs({ level: 'fatal' }).length === 0, 'queryLogs level=fatal returns 0');

  // Message contains
  assert(queryLogs({ message_contains: 'Info' }).length === 2, 'queryLogs message_contains=Info returns 2');
  assert(queryLogs({ message_contains: 'error' }).length === 1, 'queryLogs message_contains=error returns 1 (case insensitive)');

  // Limit
  assert(queryLogs({ limit: 2 }).length === 2, 'queryLogs limit=2 returns 2');

  // Labels
  clearLogs();
  logInfo('API log', { service: 'api', env: 'prod' });
  logInfo('DB log', { service: 'db', env: 'prod' });
  logInfo('API dev log', { service: 'api', env: 'dev' });
  assert(queryLogs({ labels: { service: 'api' } }).length === 2, 'queryLogs labels service=api returns 2');
  assert(queryLogs({ labels: { service: 'api', env: 'prod' } }).length === 1, 'queryLogs labels service=api+env=prod returns 1');

  // Time range
  clearLogs();
  const now = Date.now();
  pushLog({ level: 'info', message: 'old log' });
  await new Promise((r) => setTimeout(r, 10));
  pushLog({ level: 'info', message: 'new log' });
  const recentLogs = queryLogs({ start_time: now + 5 });
  assert(recentLogs.length === 1, 'queryLogs time range returns 1');
  assert(recentLogs[0]?.message === 'new log', 'time range returns newer log');

  // ============================================================
  // countByLevel
  // ============================================================

  clearLogs();
  logInfo('a'); logInfo('b'); logInfo('c');
  logError('e1'); logError('e2');
  logWarn('w1');
  logDebug('d1');

  const counts = countByLevel();
  assert(counts.info === 3, 'countByLevel info = 3');
  assert(counts.error === 2, 'countByLevel error = 2');
  assert(counts.warn === 1, 'countByLevel warn = 1');
  assert(counts.debug === 1, 'countByLevel debug = 1');
  assert(counts.fatal === 0, 'countByLevel fatal = 0');

  // countByLevel with tenant
  clearLogs();
  logInfo('a');
  pushLog({ level: 'info', message: 'b', tenant_id: 't1' });
  pushLog({ level: 'error', message: 'c', tenant_id: 't1' });
  const t1Counts = countByLevel('t1');
  assert(t1Counts.info === 1, 'countByLevel t1 info = 1');
  assert(t1Counts.error === 1, 'countByLevel t1 error = 1');

  // ============================================================
  // getLogRate
  // ============================================================

  clearLogs();
  const start = Date.now();
  for (let i = 0; i < 10; i++) pushLog({ level: 'info', message: `log ${i}` });
  const end = Date.now();
  const rate = getLogRate({ start_time: start, end_time: end });
  assert(rate > 0, 'getLogRate > 0 for 10 logs in a window');

  // ============================================================
  // clearLogs
  // ============================================================

  clearLogs();
  assert(getLogCount() === 0, 'clearLogs empties logs');
  assert(queryLogs({}).length === 0, 'clearLogs → queryLogs returns empty');

  // Print results
  console.log('\n@nai/echo tests:');
  for (const s of steps) console.log(s);
  console.log(`\n${passed} passed, ${failed} failed`);
  if (failed > 0) process.exit(1);
}

main().catch((err) => {
  console.error('FATAL:', err);
  process.exit(1);
});
